test("nominal record literals and projection infer field types", () => {
  let source =
    "
record Location = { x: Number, y: Bool };
let r: Location = .{ x = 1, y = true };
let x = r.x;
"
  let state = inferSource(source)
  let xScheme = expectTopBinding(state, "x")
  assertEquals("Number", Types.typeToString(xScheme.ty))
  let hasProjectionErrors = List.some(
    (entry: Infer.TypeMark) => String.contains("record projection", entry.message),
    state.marks
  )
  assertFalse(hasProjectionErrors)
})

test("structural records are not supported (nominal context required)", () => {
  let source =
    "
let start = .{ x = 1, y = 2 };
"
  let state = inferSource(source)
  let hasNominalContextError = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("record literal requires nominal type context", entry.message),
    state.marks
  )
  let startScheme = expectTopBinding(state, "start")
  all([
    assertTrue(hasNominalContextError),
    assertTrue(String.startsWith("?[", Types.typeToString(startScheme.ty))),
  ])
})

test("record literals infer unique nominal record and report missing/type errors", () => {
  let source =
    "
record Location = { x: Int, y: Int };
let start = .{ x = \"x\" };
"
  let state = inferSource(source)
  let startScheme = expectTopBinding(state, "start")
  let hasMissingY = List.some(
    (entry: Infer.TypeMark) => String.contains("missing record field y", entry.message),
    state.marks
  )
  let hasTypeMismatch = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("cannot unify String with Int", entry.message)
        || String.contains("cannot unify Int with String", entry.message),
    state.marks
  )
  all([
    assertEquals("Location", Types.typeToString(startScheme.ty)),
    assertTrue(hasMissingY),
    assertTrue(hasTypeMismatch),
  ])
})

test("constructor-style nominal record construction supports punning", () => {
  let source =
    "
record Operation = { direction: Int, distance: Int };
let direction = 1;
let distance = 2;
let op = Operation{ direction, distance };
"
  let state = inferSource(source)
  let opScheme = expectTopBinding(state, "op")
  assertEquals("Operation", Types.typeToString(opScheme.ty))
})

test("constructor-style nominal record construction reports field errors", () => {
  let source =
    "
record Operation = { direction: Int, distance: Int };
let op = Operation{ direction = \"x\" };
"
  let state = inferSource(source)
  let opScheme = expectTopBinding(state, "op")
  let hasMissingDistance = List.some(
    (entry: Infer.TypeMark) => String.contains("missing record field distance", entry.message),
    state.marks
  )
  let hasTypeMismatch = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("cannot unify String with Int", entry.message)
        || String.contains("cannot unify Int with String", entry.message),
    state.marks
  )
  all([
    assertEquals("Operation", Types.typeToString(opScheme.ty)),
    assertTrue(hasMissingDistance),
    assertTrue(hasTypeMismatch),
  ])
})

test("match clause guard parses and types as bool", () => {
  let source =
    "
let guarded = (x) => {
  match(x) {
    Var(n) when true => { n }
  }
};
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "guarded")
  assertFunScheme(scheme)
})

test("type mismatch records mark and continues inference", () => {
  let source =
    "
let bad = (x) => { if (1) { x } else { x } };
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "bad")
  assertFunctionShape(scheme)
  assertTrue(List.length(state.marks) > 0)
  let hasInconsistent = List.some(
    (entry: Infer.TypeMark) =>
      match (entry.mark) {
        CoreAst.Inconsistent => true,
        _ => false,
      },
    state.marks
  )
  assertTrue(hasInconsistent)
})

test("nominal type mismatch reports concrete conflicting types", () => {
  let source =
    "
record Left = { x: Int };
record Right = { x: Int };
let bad = if (true) { Left{ x = 1 } } else { Right{ x = 1 } };
"
  let state = inferSource(source)
  let hasNominalMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("cannot unify nominal types Left and Right", entry.message),
    state.marks
  )
  assertTrue(hasNominalMismatch)
})

test("unknown identifier records free-var mark and continues", () => {
  let source =
    "
let bad = missingValue;
let keep = 1;
"
  let state = inferSource(source)
  let keepScheme = expectTopBinding(state, "keep")
  assertEquals("U8", Types.typeToString(keepScheme.ty))
  let hasUnknownIdentifier = List.some(
    (entry: Infer.TypeMark) => entry.reason == Infer.UnknownIdentifier,
    state.marks
  )
  let hasFreeVar = List.some(
    (entry: Infer.TypeMark) =>
      match (entry.mark) {
        CoreAst.FreeVar(_) => true,
        _ => false,
      },
    state.marks
  )
  all([assertTrue(hasUnknownIdentifier), assertTrue(hasFreeVar)])
})

test("conflicting hole obligations mark unfillable hole", () => {
  let source =
    "
let h = ?;
let _a = if (h) { 1 } else { 2 };
let _b = h(1);
"
  let state = inferSource(source)
  let hasUnfillable = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnfillableHole
        && match (entry.mark) {
          CoreAst.UnfillableHole => true,
          _ => false,
        },
    state.marks
  )
  assertTrue(hasUnfillable)
})

test("constructor pattern arity mismatch records mark and does not crash", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let broken = (x) => {
  match(x) {
    None(v) => { v }
    _ => { 0 }
  }
};
let keep = 1;
"
  let state = inferSource(source)
  let keepScheme = expectTopBinding(state, "keep")
  assertEquals("U8", Types.typeToString(keepScheme.ty))
  let hasPatternArityMark = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && match (entry.mark) {
          CoreAst.PatternError => true,
          _ => false,
        },
    state.marks
  )
  assertTrue(hasPatternArityMark)
})

test("unknown constructor pattern with payload does not crash", () => {
  let source =
    "
let broken = (x) => {
  match(x) {
    Some(v) => { v }
    _ => { 0 }
  }
};
let keep = 1;
"
  let state = inferSource(source)
  let keepScheme = expectTopBinding(state, "keep")
  assertEquals("U8", Types.typeToString(keepScheme.ty))
  let hasUnknownOrPatternMark = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnknownIdentifier
        || match (entry.mark) {
          CoreAst.PatternError => true,
          _ => false,
        },
    state.marks
  )
  assertTrue(hasUnknownOrPatternMark)
})

test("let tuple pattern destructuring binds names in scope", () => {
  let source =
    "
let first = (pair) => {
  let (xs, ys) = pair;
  xs
};
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "first")
  match (scheme.ty) {
    Types.TFun(Types.TTuple([Types.TVar(a), Types.TVar(_b)]), Types.TVar(result)) =>
      assertEquals(a, result),
    _ => fail "expected first : ('a, 'b) -> 'a",
  }
  let hasUnknownIdentifier = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnknownIdentifier
        && match (entry.mark) {
          CoreAst.FreeVar(name) => name.text == "xs" || name.text == "ys",
          _ => false,
        },
    state.marks
  )
  assertFalse(hasUnknownIdentifier)
})

test("length over List<T> remains polymorphic with constructor shorthand payload", () => {
  let source =
    "
type List<T> = Empty | Link<T, List<T>>;
let rec length = match(list) => {
  Empty => { 0 },
  Link(_, rest) => { length(rest) }
};
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "length")
  match (scheme.ty) {
    Types.TFun(Types.TNominal("List", [Types.TVar(elem)]), Types.TNumber) =>
      assertTrue(List.length(scheme.quantifiers) >= 1 && Types.containsVar(scheme.quantifiers, elem)),
    _ => fail "expected length : List<'a> -> Number",
  }
})

test("local let rec binding resolves self-reference in expression scope", () => {
  let source =
    "
let outer = (x) => {
  let rec helper = (n) => { helper(n) };
  helper(x)
};
"
  let state = inferSource(source)
  let hasUnknownHelper = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnknownIdentifier
        && entry.message == "Type error: unknown identifier helper",
    state.marks
  )
  assertFalse(hasUnknownHelper)
})

test("layered pipeline matches direct infer result", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let id = (x) => { x };
let out = id(1);
let fromSome = (o) => {
  match(o) {
    Some(v) => { v }
    None => { 0 }
  }
};
"
  let program = Frontend.parseAndLower(source)
  let direct = Infer.inferProgram(program)
  let layered = Layer2.solve(Layer1.inferProgram(program))

  let directOut = expectTopBinding(direct, "out")
  let layeredOut = expectTopBinding(layered, "out")
  assertEquals(Types.typeToString(directOut.ty), Types.typeToString(layeredOut.ty))

  let directFromSome = expectTopBinding(direct, "fromSome")
  let layeredFromSome = expectTopBinding(layered, "fromSome")
  assertEquals(
    Types.typeToString(directFromSome.ty),
    Types.typeToString(layeredFromSome.ty)
  )
})

test("match bare identifier pins outer value while Var introduces binder", () => {
  let source =
    "
let sentinel = 1;
let classify = (x) => {
  match(x) {
    sentinel => { true },
    Var(bound) => { !bound }
  }
};
"
  let state = inferSource(source)
  let hasTypeMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch,
    state.marks
  )
  let hasUnknownBound = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnknownIdentifier
        && String.contains("bound", entry.message),
    state.marks
  )
  all([
    assertTrue(hasTypeMismatch),
    assertFalse(hasUnknownBound),
  ])
})

test("constructor pattern argument stays binder even with same outer name", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let y = true;
let pick = (x) => {
  match(x) {
    Some(y) => { y }
    None => { 0 }
  }
};
"
  let state = inferSource(source)
  let pickScheme = expectTopBinding(state, "pick")
  let hasHardTypeMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && !String.contains("unresolved numeric", entry.message),
    state.marks
  )
  match (pickScheme.ty) {
    Types.TFun(Types.TNominal("Option", [Types.TNominal("U8", [])]), Types.TNominal("U8", [])) =>
      all([
        assertFalse(hasHardTypeMismatch),
        assertTrue(true),
      ]),
    _ => fail("expected pick : Option<U8> -> U8"),
  }
})

test("tuple bare identifiers in match patterns are pins, not binders", () => {
  let source =
    "
let x = true;
let y = false;
let onlyPair = (p) => {
  match(p) {
    (x, y) => { 1 }
    _ => { 0 }
  }
};
"
  let state = inferSource(source)
  let onlyPairScheme = expectTopBinding(state, "onlyPair")
  let hasUnknownIdentifier = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnknownIdentifier
        && (String.contains("x", entry.message) || String.contains("y", entry.message)),
    state.marks
  )
  match (onlyPairScheme.ty) {
    Types.TFun(Types.TTuple([Types.TBool, Types.TBool]), Types.TNominal("U8", [])) =>
      all([
        assertFalse(hasUnknownIdentifier),
        assertTrue(true),
      ]),
    _ => fail("expected onlyPair : (Bool, Bool) -> U8"),
  }
})

test("Panic is typed as polymorphic abort expression", () => {
  let source =
    "
let choose = (b) => {
  if (b) {
    Panic(\"boom\")
  } else {
    1
  }
};
"
  let state = inferSource(source)
  let chooseScheme = expectTopBinding(state, "choose")
  let hasUnknownPanic = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.UnknownIdentifier
        && String.contains("Panic", entry.message),
    state.marks
  )
  match (chooseScheme.ty) {
    Types.TFun(Types.TBool, Types.TNominal("U8", [])) =>
      all([
        assertFalse(hasUnknownPanic),
        assertTrue(true),
      ]),
    _ => fail "expected choose : Bool -> U8",
  }
})

test("reserved Panic cannot be rebound by let declaration", () => {
  let source =
    "
let Panic = (msg) => { msg };
let y = Panic(\"boom\");
"
  let state = inferSource(source)
  let hasReservedNameDiag = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("reserved identifier Panic cannot be declared", entry.message),
    state.marks
  )
  assertTrue(hasReservedNameDiag)
})

test("reserved Panic cannot be declared as constructor name", () => {
  let source =
    "
type X = Panic<String> | Other;
let x = Panic(\"boom\");
"
  let state = inferSource(source)
  let hasReservedNameDiag = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("reserved identifier Panic cannot be declared", entry.message),
    state.marks
  )
  assertTrue(hasReservedNameDiag)
})

test("imported env cannot override reserved Panic builtin", () => {
  let source =
    "
let y = Panic(1);
"
  let importedEnv = Map.make()
  let identityVar = Types.TVar(7001)
  let shadowScheme: Types.Scheme = {
    quantifiers: [7001],
    ty: Types.TFun(identityVar, identityVar),
  }
  Map.set("Panic", shadowScheme, importedEnv)
  let state = inferSourceWithEnv(source, importedEnv)
  let hasStringConstraintMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && (
          (String.contains("cannot unify", entry.message) && String.contains("String", entry.message))
            || String.contains("not numeric", entry.message)
        ),
    state.marks
  )
  assertTrue(hasStringConstraintMismatch)
})

test("empty function clauses emit diagnostic and inference continues", () => {
  let source =
    "
let f = match { };
let x = f(1);
"
  let state = inferSource(source)
  let fScheme = expectTopBinding(state, "f")
  let _ = expectTopBinding(state, "x")
  let hasEmptyClauseDiag = List.some(
    (entry: Infer.TypeMark) => String.contains("empty function clauses", entry.message),
    state.marks
  )
  all([
    assertTrue(hasEmptyClauseDiag),
    assertFunctionShape(fScheme),
    assertTrue(true),
  ])
})

test("non-exhaustive match emits diagnostic and inference continues", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let onlySome = (o) => {
  match(o) {
    Some(v) => { v }
  }
};
let keep = 1;
"
  let state = inferSource(source)
  let keepScheme = expectTopBinding(state, "keep")
  let hasNonExhaustive = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("non-exhaustive match for type Option", entry.message),
    state.marks
  )
  all([
    assertEquals("U8", Types.typeToString(keepScheme.ty)),
    assertTrue(hasNonExhaustive),
  ])
})

test("guarded constructor arm does not satisfy exhaustiveness", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let guardedOnly = (o) => {
  match(o) {
    Some(v) when true => { v }
  }
};
"
  let state = inferSource(source)
  let hasNonExhaustive = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("non-exhaustive match for type Option", entry.message),
    state.marks
  )
  assertTrue(hasNonExhaustive)
})

test("wildcard arm satisfies exhaustiveness for closed sum", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let withFallback = (o) => {
  match(o) {
    Some(v) => { v }
    _ => { 0 }
  }
};
"
  let state = inferSource(source)
  let hasNonExhaustive = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("non-exhaustive match for type Option", entry.message),
    state.marks
  )
  assertFalse(hasNonExhaustive)
})

test("match over constructors from multiple nominal types emits diagnostic", () => {
  let source =
    "
type Option<T> = Some<T> | None;
type Result<T, E> = Ok<T> | Err<E>;
let bad = (x) => {
  match(x) {
    Some(v) => { v }
    Ok(v) => { v }
  }
};
let keep = 1;
"
  let state = inferSource(source)
  let keepScheme = expectTopBinding(state, "keep")
  let hasMixedTypeDiag = List.some(
    (entry: Infer.TypeMark) =>
      String.contains("match clauses reference multiple nominal types", entry.message),
    state.marks
  )
  all([
    assertEquals("U8", Types.typeToString(keepScheme.ty)),
    assertTrue(hasMixedTypeDiag),
  ])
})

test("lowered match keeps blame on the constraining use-site", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let takesInt = (x) => { x + 1 };
let read = (x) => {
  let file = x;
  let _n = takesInt(file);
  match(file) {
    Some(file) => {
      file
    }
    None => { 1 }
  }
};
"
  let state = inferSource(source)
  let hasConstrainedBlame = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("Type error (match scrutinee)", entry.message)
        && (
          match (entry.blame) {
            Some(blameOrigin) =>
              blameOrigin.nodeId >= 0 && blameOrigin.description == "function argument",
            None => false,
          }
        ),
    state.marks
  )
  assertTrue(hasConstrainedBlame)
})

test("non-callable callee in function application blames the callee", () => {
  let source =
    "
let f = true;
let bad = f(1);
"
  let state = inferSource(source)
  let hasCalleeBlame = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("Type error (function application)", entry.message)
        && (
          match (entry.blame) {
            Some(blameOrigin) => blameOrigin.description == "function callee",
            None => false,
          }
        ),
    state.marks
  )
  assertTrue(hasCalleeBlame)
})

let results = runTests()
printResultsAndExit(results)
