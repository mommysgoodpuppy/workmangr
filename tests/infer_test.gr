module InferTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "../src/frontend/frontend.gr" include Frontend
from "../src/core/infer.gr" include Infer
from "../src/core/layer1/mod.gr" include Layer1
from "../src/core/layer2/mod.gr" include Layer2
from "../src/core/core_ast.gr" include CoreAst
from "../src/core/types.gr" include Types
from "../src/core/infection_registry.gr" include InfectionRegistry
from "../src/core/constraints.gr" include Constraints
from "map" include Map
from "list" include List
from "string" include String

setSourceFile("./tests/infer_test.gr")

let inferSource = (source: String) => {
  let program = Frontend.parseAndLower(source)
  Infer.inferProgram(program)
}

let inferSourceWithEnv = (source: String, env: Types.Env) => {
  let program = Frontend.parseAndLower(source)
  Infer.inferProgramWithEnv(program, env)
}

let assertFunScheme = (scheme: Types.Scheme) => {
  let quantCount = List.length(scheme.quantifiers)
  assertTrue(quantCount >= 1)

  match (scheme.ty) {
    Types.TFun(Types.TVar(arg), Types.TVar(result)) =>
      assertEquals(arg, result),
    _ => fail "expected function scheme",
  }
}

let expectTopBinding = (state: Infer.InferState, name: String) =>
  match (Map.get(name, state.topBindings)) {
    Some(scheme) => scheme,
    None => fail "missing binding: " ++ name,
  }

let assertFunctionShape = (scheme: Types.Scheme) =>
  match (scheme.ty) {
    Types.TFun(_, _) => assertTrue(true),
    _ => fail "expected function type",
  }

test("let generalization produces polymorphic scheme", () => {
let source =
    "
let id = (x) => { x };
let useNumber = (n) => { id(n) };
let useFunction = (f) => { id(f) };
"

  let state = inferSource(source)
  let scheme = expectTopBinding(state, "id")
  assertFunScheme(scheme)
  assertEquals(0, List.length(state.constraints))
})

test("tuple expressions infer tuple element types", () => {
  let source =
    "
let pair = (x) => { (x, x) };
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "pair")

  match (scheme.ty) {
    Types.TFun(Types.TVar(arg), Types.TTuple([Types.TVar(a), Types.TVar(b)])) => {
      assertEquals(arg, a)
      assertEquals(arg, b)
      assertTrue(List.length(scheme.quantifiers) >= 1)
    },
    _ => fail "expected pair : 'a -> ('a, 'a)",
  }
})

test("let rec infers recursive function via placeholder", () => {
  let source =
    "
let rec loop = (n) => { loop(n) };
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "loop")
  assertFunctionShape(scheme)
})

test("let rec and infers mutual recursion in one group", () => {
  let source =
    "
let rec isEven = (n) => { isOdd(n) } and isOdd = (n) => { isEven(n) };
"
  let state = inferSource(source)
  let evenScheme = expectTopBinding(state, "isEven")
  let oddScheme = expectTopBinding(state, "isOdd")
  assertFunctionShape(evenScheme)
  assertFunctionShape(oddScheme)
})

test("let rec and generalizes mutual group for polymorphic downstream uses", () => {
  let source =
    "
let rec id = (x) => { x } and keep = (v) => { id(v) };
let one = keep(1);
let truth = keep(true);
"
  let state = inferSource(source)
  let idScheme = expectTopBinding(state, "id")
  let keepScheme = expectTopBinding(state, "keep")
  let oneScheme = expectTopBinding(state, "one")
  let truthScheme = expectTopBinding(state, "truth")
  let hasHardTypeMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && !String.contains("unresolved numeric", entry.message),
    state.marks
  )
  let idPoly = List.length(idScheme.quantifiers) >= 1
  let keepPoly = List.length(keepScheme.quantifiers) >= 1
  all([
    assertTrue(idPoly),
    assertTrue(keepPoly),
    assertFalse(hasHardTypeMismatch),
    assertEquals("U8", Types.typeToString(oneScheme.ty)),
    assertEquals("Bool", Types.typeToString(truthScheme.ty)),
  ])
})

test("type decl registers constructor schemes for expression typing", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let wrap = (x) => { Some(x) };
let none = None;
"
  let state = inferSource(source)
  let wrapScheme = expectTopBinding(state, "wrap")
  let noneScheme = expectTopBinding(state, "none")

  match (wrapScheme.ty) {
    Types.TFun(Types.TVar(a), Types.TNominal("Option", [Types.TVar(b)])) => {
      assertEquals(a, b)
      assertTrue(List.length(wrapScheme.quantifiers) >= 1)
    },
    _ => fail "expected wrap : 'a -> Option<'a>",
  }

  match (noneScheme.ty) {
    Types.TNominal("Option", [_]) =>
      assertTrue(List.length(noneScheme.quantifiers) >= 1),
    _ => fail "expected none : Option<'a>",
  }
})

test("constructor patterns typecheck in match clauses", () => {
  let source =
    "
type Option<T> = Some<T> | None;
let unwrapOr = (pair) => {
  match(pair) {
    (Some(v), fallback) => { v }
    (None, fallback) => { fallback }
  }
};
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "unwrapOr")
  assertFunctionShape(scheme)
  assertEquals(0, List.length(state.constraints))
})

test("index:Int annotation accepts numeric literals in match params", () => {
  let source =
    "
let classify = match(index:Int) => {
  0 => { true }
  _ => { false }
};
"
  let state = inferSource(source)
  let hasHardMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("cannot unify", entry.message),
    state.marks
  )
  assertFalse(hasHardMismatch)
})

test("expression annotation constrains arithmetic result type", () => {
  let source =
    "
let x = 1 + 1: U8;
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "x")
  let hasHardMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("cannot unify", entry.message),
    state.marks
  )
  all([
    assertFalse(hasHardMismatch),
    assertEquals("U8", Types.typeToString(scheme.ty)),
  ])
})

test("zeros cast permits omitted zero-valid record fields", () => {
  let source =
    "
record Pair = {
  x: U8,
  y: U8,
};
let pair = Pair{} as Zeros;
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "pair")
  let hasMissingField = List.some(
    (entry: Infer.TypeMark) => String.contains("missing record field", entry.message),
    state.marks
  )
  let hasInvalidZerosCast = List.some(
    (entry: Infer.TypeMark) => String.contains("invalid cast to Zeros", entry.message),
    state.marks
  )
  all([
    assertFalse(hasMissingField),
    assertFalse(hasInvalidZerosCast),
    assertEquals("Pair", Types.typeToString(scheme.ty)),
  ])
})

test("zeros cast rejects non-zero-valid record layouts", () => {
  let source =
    "
record Named = {
  text: String,
};
let named = Named{} as Zeros;
"
  let state = inferSource(source)
  let hasInvalidZerosCast = List.some(
    (entry: Infer.TypeMark) => String.contains("invalid cast to Zeros", entry.message),
    state.marks
  )
  assertTrue(hasInvalidZerosCast)
})

test("string literals coerce to C string pointer params in function application", () => {
  let env = Map.make()
  Map.set(
    "fopen",
    ({
      quantifiers: [0],
      ty: Types.TFun(
        Types.TTuple([
          Types.TNominal("ManyPtr", [Types.TNominal("U8", []), Types.TVar(0)]),
          Types.TNominal("ManyPtr", [Types.TNominal("U8", []), Types.TVar(0)]),
        ]),
        Types.TNominal(
          "Option",
          [Types.TNominal("Ptr", [Types.TNominal("IO_FILE", []), Types.TVar(0)])],
        )
      ),
    }: Types.Scheme),
    env
  )

  let state = inferSourceWithEnv(
    "
let file = fopen(\"simple.wm\", \"rb\");
",
    env
  )
  let scheme = expectTopBinding(state, "file")
  let hasHardMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("cannot unify", entry.message),
    state.marks
  )

  all([
    assertFalse(hasHardMismatch),
    assertEquals("Option<Ptr<IO_FILE, T>>", Types.typeToString(scheme.ty)),
  ])
})

test("matching Some over optional pointer feeds raw pointer params", () => {
  let env = Map.make()
  let stateVar = Types.TVar(0)
  Map.set(
    "fopen",
    ({
      quantifiers: [0],
      ty: Types.TFun(
        Types.TTuple([
          Types.TNominal("ManyPtr", [Types.TNominal("U8", []), stateVar]),
          Types.TNominal("ManyPtr", [Types.TNominal("U8", []), stateVar]),
        ]),
        Types.TNominal(
          "Option",
          [Types.TNominal("Ptr", [Types.TNominal("IO_FILE", []), stateVar])],
        )
      ),
    }: Types.Scheme),
    env
  )
  Map.set(
    "fseek",
    ({
      quantifiers: [1],
      ty: Types.TFun(
        Types.TTuple([
          Types.TNominal("Ptr", [Types.TNominal("IO_FILE", []), Types.TVar(1)]),
          Types.TNominal("CLong", []),
          Types.TNominal("CInt", []),
        ]),
        Types.TNominal("CInt", [])
      ),
    }: Types.Scheme),
    env
  )
  let state = inferSourceWithEnv(
    "
let useFile = (path) => {
  let fh = fopen(path, \"rb\");
  match(fh) {
    Some(file) => { fseek(file, 0, 0) }
    None => { 0 }
  }
};
",
    env
  )
  let scheme = expectTopBinding(state, "useFile")
  let hasHardMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && String.contains("cannot unify", entry.message),
    state.marks
  )

  all([
    assertFalse(hasHardMismatch),
    match (scheme.ty) {
      Types.TFun(
        Types.TNominal("ManyPtr", [Types.TNominal("U8", []), Types.TVar(_)]),
        Types.TNominal("CInt", [])
      ) => assertTrue(true),
      _ => fail("expected useFile : ManyPtr<U8, _> -> CInt"),
    },
  ])
})

test("literal patterns use their literal type", () => {
  let source =
    "
let choose = (x) => {
  match(x) {
    true => { 1 }
    false => { 0 }
  }
};
"
  let state = inferSource(source)
  let scheme = expectTopBinding(state, "choose")
  match (scheme.ty) {
    Types.TFun(Types.TBool, Types.TNominal("U8", [])) => assertTrue(true),
    _ => fail "expected choose : Bool -> U8",
  }
})

test("inferProgramWithEnv seeds cross-module schemes", () => {
  let source = "let make = (x) => { Some(x) };"
  let importedEnv = Map.make()
  let optionVar = Types.TVar(999)
  let someScheme: Types.Scheme = {
    quantifiers: [999],
    ty: Types.TFun(optionVar, Types.TNominal("Option", [optionVar])),
  }
  Map.set("Some", someScheme, importedEnv)

  let state = inferSourceWithEnv(source, importedEnv)
  let scheme = expectTopBinding(state, "make")
  assertFunctionShape(scheme)
})

test("inferProgramWithEnv resolves qualified module symbol names", () => {
  let source = "let first = (xs) => { List.at((xs, 0)) };"
  let importedEnv = Map.make()
  let tElem = Types.TVar(700)
  let tList = Types.TNominal("List", [tElem])
  let atScheme: Types.Scheme = {
    quantifiers: [700],
    ty: Types.TFun(Types.TTuple([tList, Types.TNumber]), tElem),
  }
  Map.set("List.at", atScheme, importedEnv)

  let state = inferSourceWithEnv(source, importedEnv)
  let scheme = expectTopBinding(state, "first")
  assertTrue(List.length(state.marks) == 0)
  assertFunctionShape(scheme)
})

test("layer1 collects infection registry declarations", () => {
  let source =
    "
domain effect {
  mergeRow union;
  conflict [(Open, Closed)];
  infectsReturn true;
  default {
    target arg0;
    requiresNot [Closed];
  };
};
policy pure {
  domain effect;
  rejectsAllDomains;
};
op plusNum {
  domain effect;
  target arg0;
  adds [Open];
};
annotate io.read {
  pure,
};
"
  let state = inferSource(source)
  let domainDef = Map.get("effect", state.infectionRegistry.domains)
  let policyDef = Map.get("pure", state.infectionRegistry.policies)
  let opDef = Map.get("plusNum", state.infectionRegistry.opRules)
  let annotationDef = Map.get("io.read", state.infectionRegistry.annotations)

  assertTrue(domainDef != None)
  assertTrue(policyDef != None)
  assertTrue(opDef != None)
  assertTrue(annotationDef != None)
})

test("infectious type usage emits deferred domain constraint", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let ok = IOk(1);
"
  let state = inferSource(source)
  let hasShortCircuitConstraint = List.some(
    (constraint: Constraints.Constraint) =>
      match (constraint) {
        Constraints.Domain(label, _) => label == "shortCircuit",
        _ => false,
      },
    state.constraints
  )

  assertTrue(hasShortCircuitConstraint)
})

test("infectious type declaration requires a declared domain", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let ok = IOk(1);
"
  let state = inferSource(source)
  let hasUndefinedDomain = List.some(
    (mark: Infer.TypeMark) =>
      mark.reason == Infer.TypeMismatch
        && String.contains("uses undefined infection domain shortCircuit", mark.message),
    state.marks
  )

  assertTrue(hasUndefinedDomain)
})

test("row-union infection domains do not force nominal state arg unification", () => {
  let source =
    "
domain effect {
  stateKind rowSet;
  mergeRow union;
};
type A = | A;
type B = | B;
type infectious effect IResult<T, E> = | IOk(T) | IErr(E);
let choose = (flag) => {
  if (flag) {
    IErr(A)
  } else {
    IErr(B)
  }
};
"
  let state = inferSource(source)
  assertTrue(List.length(state.marks) == 0)
})

test("op rule adds emits domain constraint at call site", () => {
  let source =
    "
op taint {
  adds [shortCircuit];
};
let taint = (x) => { x };
let out = taint(1);
"
  let state = inferSource(source)
  let hasAddedConstraint = List.some(
    (constraint: Constraints.Constraint) =>
      match (constraint) {
        Constraints.Domain(label, _) => label == "shortCircuit",
        _ => false,
      },
    state.constraints
  )
  assertTrue(hasAddedConstraint)
})

test("op callPolicy rejects matching infectious argument domain", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
policy pure {
  rejectDomains [shortCircuit];
};
op lift {
  callPolicy pure;
};
let lift = (x) => { x };
let out = lift(IOk(1));
"
  let state = inferSource(source)
  let rejected = List.some(
    (mark: Infer.TypeMark) =>
      mark.reason == Infer.TypeMismatch
        && String.contains("rejects infection domain shortCircuit", mark.message),
    state.marks
  )
  assertTrue(rejected)
})

test("op requiresAny/requiresNot/requiresExact are enforced", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
op needsInfection {
  target arg0;
  requiresAny [shortCircuit];
};
op needsClean {
  target arg0;
  requiresNot [shortCircuit];
};
op needsExact {
  target arg0;
  requiresExact [shortCircuit];
};
let needsInfection = (x) => { x };
let needsClean = (x) => { x };
let needsExact = (x) => { x };
let badAny = needsInfection(1);
let badNot = needsClean(IOk(1));
let goodExact = needsExact(IOk(1));
let badExact = needsExact(1);
"
  let state = inferSource(source)
  let hasAnyFailure = List.some(
    (mark: Infer.TypeMark) => String.contains("requires one matching infection state", mark.message),
    state.marks
  )
  let hasNotFailure = List.some(
    (mark: Infer.TypeMark) => String.contains("forbids current infection state", mark.message),
    state.marks
  )
  let hasExactFailure = List.some(
    (mark: Infer.TypeMark) => String.contains("requires exact infection state", mark.message),
    state.marks
  )
  assertTrue(hasAnyFailure)
  assertTrue(hasNotFailure)
  assertTrue(hasExactFailure)
})

test("op target arg1 uses tuple element infection domain", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
op takeSecond {
  target arg1;
  requiresAny [shortCircuit];
};
let takeSecond = (pair) => { pair };
let ok = takeSecond((1, IOk(2)));
let bad = takeSecond((IOk(1), 2));
"
  let state = inferSource(source)
  let requireAnyFailures = List.length(
    List.filter(
      (mark: Infer.TypeMark) => String.contains("requires one matching infection state", mark.message),
      state.marks
    )
  )
  assertEquals(1, requireAnyFailures)
})

test("op removes updates policy visibility before callPolicy checks", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
policy pure {
  rejectDomains [shortCircuit];
};
op sanitize {
  target arg0;
  removes [shortCircuit];
  callPolicy pure;
};
let sanitize = (x) => { x };
let out = sanitize(IOk(1));
"
  let state = inferSource(source)
  let rejected = List.some(
    (mark: Infer.TypeMark) =>
      mark.reason == Infer.TypeMismatch
        && String.contains("rejects infection domain shortCircuit", mark.message),
    state.marks
  )
  assertFalse(rejected)
})

test("IResult infects plain unary function application result", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let add1 = (n) => { nativeAdd((n, 1)) };
let out = add1(IOk(1));
"
  let state = inferSource(source)
  let outScheme = expectTopBinding(state, "out")
  match (outScheme.ty) {
    Types.TNominal("IResult", [Types.TNominal("Int", []), _]) => assertTrue(true),
    _ => fail "expected out : IResult<Number, _>",
  }
})

test("IResult infects tuple-arg binary function application result", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let out = nativeAdd((IOk(1), 2));
"
  let state = inferSource(source)
  let outScheme = expectTopBinding(state, "out")
  match (outScheme.ty) {
    Types.TNominal("IResult", [Types.TNominal("Int", []), _]) => assertTrue(true),
    _ => fail "expected out : IResult<Number, _>",
  }
})

test("IResult discharge via match remains plain value", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let strip = (input) => {
  match(input) {
    IOk(value) => { value }
    IErr(_) => { 0 }
  }
};
let out = strip(IOk(1));
"
  let state = inferSource(source)
  let outScheme = expectTopBinding(state, "out")
  assertEquals("Number", Types.typeToString(outScheme.ty))
})

test("IResult-producing let binding generalizes and remains infectious", () => {
  let source =
    "
domain shortCircuit { mergeRow union; };
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let lift = (x) => { IOk(x) };
let n = lift(1);
let b = lift(true);
"
  let state = inferSource(source)
  let liftScheme = expectTopBinding(state, "lift")
  let nScheme = expectTopBinding(state, "n")
  let bScheme = expectTopBinding(state, "b")
  let hasHardTypeMismatch = List.some(
    (entry: Infer.TypeMark) =>
      entry.reason == Infer.TypeMismatch
        && !String.contains("unresolved numeric", entry.message),
    state.marks
  )
  let liftIsPolyInPayload = match (liftScheme.ty) {
    Types.TFun(Types.TVar(payloadIn), Types.TNominal("IResult", [Types.TVar(payloadOut), _])) =>
      payloadIn == payloadOut && Types.containsVar(liftScheme.quantifiers, payloadIn),
    _ => false,
  }
  let nTypeOk = match (nScheme.ty) {
    Types.TNominal("IResult", [Types.TNumber, _]) => true,
    _ => false,
  }
  let bTypeOk = match (bScheme.ty) {
    Types.TNominal("IResult", [Types.TBool, _]) => true,
    _ => false,
  }
  all([
    assertTrue(liftIsPolyInPayload),
    assertTrue(nTypeOk),
    assertTrue(bTypeOk),
    assertFalse(hasHardTypeMismatch),
  ])
})

test("propagation records effect event metadata at call site", () => {
  let source =
    "
type infectious shortCircuit IResult<T, E> = | IOk(T) | IErr(E);
let add1 = (n) => { nativeAdd((n, 1)) };
let out = add1(IOk(1));
"
  let state = inferSource(source)
  let hasPropagationEvent = List.some(
    ((_, events): (Number, List<Infer.EffectEvent>)) =>
      List.some(
        (event: Infer.EffectEvent) =>
          event.kind == "propagation"
            && String.contains("charged by IResult", event.message),
        events
      ),
    Map.toList(state.effectEventsByNode)
  )
  assertTrue(hasPropagationEvent)
})

test("layer1 then layer2 pipeline works explicitly", () => {
  let source =
    "
let id = (x) => { x };
let out = id(1);
"
  let program = Frontend.parseAndLower(source)
  let layer1State = Layer1.inferProgram(program)
  assertTrue(List.length(layer1State.constraints) > 0)

  let layer2State = Layer2.solve(layer1State)
  assertEquals(0, List.length(layer2State.constraints))
  let outScheme = expectTopBinding(layer2State, "out")
  assertEquals("U8", Types.typeToString(outScheme.ty))
})

