  let source =
    "
let b = true;
let s = \"abc\";
"
  let state = inferSource(source)
  assertEquals("Bool", Types.typeToString(expectTopBinding(state, "b").ty))
  assertEquals("String", Types.typeToString(expectTopBinding(state, "s").ty))
})

