module LoweringTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "../src/frontend/frontend.gr" include Frontend
from "../src/core/core_ast.gr" include CoreAst
from "../src/core/error.gr" include Error
from "list" include List
from "string" include String

setSourceFile("./tests/lowering_test.gr")

let expectSingleDeclGroup = (program: CoreAst.Program) => {
  match (program.items) {
    [CoreAst.DeclGroup(dg)] => Ok(dg),
    _ => Err("expected single decl group"),
  }
}

let expectSingleLetDecl = (dg: CoreAst.DeclGroup) => {
  match (dg.decls) {
    [CoreAst.LetDecl(ld)] => Ok(ld),
    _ => Err("expected single let decl"),
  }
}

let expectSingleBinding = (ld: CoreAst.LetDecl) => {
  match (ld.bindings) {
    [binding] => Ok(binding),
    _ => Err("expected single let binding"),
  }
}

let bind = (res, f) => {
  match (res) {
    Ok(v) => f(v),
    Err(e) => Err(e),
  }
}

test("match lowers to apply and pins pattern", () => {
  let source = "
  let x3 = (y) => {
    match(y) { y => {\"t\"} } 
  };
  "
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Fn(fnOuter) => match (fnOuter.items) {
          [item] => match (item.kind) {
            CoreAst.Clause(outerClause) =>
              match (outerClause.body.kind) {
                CoreAst.Apply(innerCallee, _) =>
                  match (innerCallee.kind) {
                    CoreAst.Fn(fnInner) => match (fnInner.items) {
                      [innerItem] => match (innerItem.kind) {
                        CoreAst.Clause(innerClause) =>
                          match (innerClause.param.kind) {
                            CoreAst.Pin({ _, text }) =>
                              if (text == "y") { Ok(void) } else { Err("expected pin 'y'") },
                            _ => Err("expected pin pattern"),
                          },
                        _ => Err("expected inner clause"),
                      },
                      _ => Err("expected single inner item"),
                    },
                    _ => Err("expected inner fn"),
                  },
                _ => Err("expected apply in outer clause body"),
              },
            _ => Err("expected outer clause"),
          },
          _ => Err("expected single outer item"),
        },
        _ => Err("expected outer fn"),
      }
    },
  )
})

test("constructor argument identifier lowers as binder var not pin", () => {
  let source = "
  let x3 = (y) => {
    match(y) { Some(y) => {y} } 
  };
  "
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Fn(fnOuter) => match (fnOuter.items) {
          [item] => match (item.kind) {
            CoreAst.Clause(outerClause) =>
              match (outerClause.body.kind) {
                CoreAst.Apply(innerCallee, _) =>
                  match (innerCallee.kind) {
                    CoreAst.Fn(fnInner) => match (fnInner.items) {
                      [innerItem] => match (innerItem.kind) {
                        CoreAst.Clause(innerClause) =>
                          match (innerClause.param.kind) {
                            CoreAst.Constructor(_, [arg]) =>
                              match (arg.kind) {
                                CoreAst.Var({ _, text }) =>
                                  if (text == "y") { Ok(void) } else { Err("expected var 'y'") },
                                _ => Err("expected constructor arg binder var"),
                              },
                            _ => Err("expected constructor pattern"),
                          },
                        _ => Err("expected inner clause"),
                      },
                      _ => Err("expected single inner item"),
                    },
                    _ => Err("expected inner fn"),
                  },
                _ => Err("expected apply in outer clause body"),
              },
            _ => Err("expected outer clause"),
          },
          _ => Err("expected single outer item"),
        },
        _ => Err("expected outer fn"),
      }
    },
  )
})

test("unsupported => parameter expression lowers to marked wildcard and diagnostic", () => {
  Error.clearErrors()
  let source = "let f = (x.y) => {1};"
  let program = Frontend.parseAndLower(source)
  let diagnostics = Error.getErrors()

  let hasLoweringError = List.some((diag: Error.CompilerError) =>
    diag.stage == Error.Lowering
      && String.contains("Unsupported expression in pattern position", diag.message),
    diagnostics
  )

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      if (!hasLoweringError) {
        Err("expected lowering diagnostic for unsupported => parameter")
      } else {
        match (binding.value.kind) {
          CoreAst.Fn(fnExpr) => match (fnExpr.items) {
            [item] => match (item.kind) {
              CoreAst.Clause(clause) => match (clause.param.kind) {
                CoreAst.Mark(CoreAst.UnsupportedExpr, inner) =>
                  match (inner.kind) {
                    CoreAst.Wildcard => Ok(void),
                    _ => Err("expected wildcard fallback inside mark"),
                  },
                _ => Err("expected marked fallback parameter pattern"),
              },
              _ => Err("expected fn clause"),
            },
            _ => Err("expected single fn clause"),
          },
          _ => Err("expected lowered function"),
        }
      }
    },
  )
})

test("zero-arg => sugar lowers to unit-parameter function", () => {
  let source = "let main = => { 1 + 1 };"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) =>
      match (binding.value.kind) {
        CoreAst.Fn(fnExpr) => match (fnExpr.items) {
          [item] => match (item.kind) {
            CoreAst.Clause(clause) => match (clause.param.kind) {
              CoreAst.Lit(CoreAst.Unit) => Ok(void),
              _ => Err("expected zero-arg sugar to lower as unit parameter"),
            },
            _ => Err("expected fn clause"),
          },
          _ => Err("expected single fn clause"),
        },
        _ => Err("expected lowered function"),
      },
  )
})

test("call with multiple args lowers to tuple", () => {
  let source = "let x = f(1, 2);"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(_, arg) =>
          match (arg.kind) {
            CoreAst.Tuple(items) =>
              if (List.length(items) == 2) { Ok(void) } else { Err("expected 2 tuple args") },
            _ => Err("expected tuple arg"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

test("mut let group lowers with mut group kind", () => {
  let source = "let mut counter = 0;"
  let program = Frontend.parseAndLower(source)

  bind(
    expectSingleDeclGroup(program),
    (dg) =>
      match (dg.kind) {
        CoreAst.LetGroup(CoreAst.Mut) => Ok(void),
        _ => Err("expected lowered let group kind Mut"),
      },
  )
})

test("pipe prepends arg when rhs is apply", () => {
  let source = "let x = 1 :> g(2);"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(_, arg) =>
          match (arg.kind) {
            CoreAst.Tuple([first, _]) =>
              match (first.kind) {
                CoreAst.Lit(CoreAst.Int(1)) => Ok(void),
                _ => Err("expected lhs to be first tuple arg"),
              },
            _ => Err("expected tuple arg"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

test("pipe preserves left-to-right argument order with existing rhs args", () => {
  let source = "let x = seed :> f(one, two);"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(_, arg) =>
          match (arg.kind) {
            CoreAst.Tuple([a, b, c]) =>
              match ((a.kind, b.kind, c.kind)) {
                (
                  CoreAst.Ident({ text: "seed", _ }),
                  CoreAst.Ident({ text: "one", _ }),
                  CoreAst.Ident({ text: "two", _ }),
                ) => Ok(void),
                _ => Err("expected pipe to lower as f(seed, one, two)"),
              },
            _ => Err("expected tuple arg"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

test("qualified dot call lowers to qualified identifier apply", () => {
  let source = "let x = List.at(xs, 0);"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(callee, arg) =>
          match (callee.kind) {
            CoreAst.Ident({ _, text }) =>
              if (text == "List.at") {
                match (arg.kind) {
                  CoreAst.Tuple([_, second]) =>
                    match (second.kind) {
                      CoreAst.Lit(CoreAst.Int(0)) => Ok(void),
                      _ => Err("expected second tuple arg to be 0"),
                    },
                  _ => Err("expected tuple args to List.at"),
                }
              } else {
                Err("expected callee List.at")
              },
            _ => Err("expected ident callee"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

test("call argument order is preserved left-to-right in lowered tuple", () => {
  let source = "let x = f(first, second, third);"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(_, arg) =>
          match (arg.kind) {
            CoreAst.Tuple([a, b, c]) =>
              match ((a.kind, b.kind, c.kind)) {
                (
                  CoreAst.Ident({ text: "first", _ }),
                  CoreAst.Ident({ text: "second", _ }),
                  CoreAst.Ident({ text: "third", _ }),
                ) => Ok(void),
                _ => Err("expected call args in source order first, second, third"),
              },
            _ => Err("expected tuple arg"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

test("record literal field order is preserved under nominal annotation context", () => {
  let source = "let x: Triple = .{ a = first, b = second, c = third };"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.RecordLit([
          CoreAst.Field(nameA, exprA),
          CoreAst.Field(nameB, exprB),
          CoreAst.Field(nameC, exprC),
        ]) =>
          match ((nameA.text, exprA.kind, nameB.text, exprB.kind, nameC.text, exprC.kind)) {
            (
              "a",
              CoreAst.Ident({ text: "first", _ }),
              "b",
              CoreAst.Ident({ text: "second", _ }),
              "c",
              CoreAst.Ident({ text: "third", _ }),
            ) => Ok(void),
            _ => Err("expected record fields in source order: a, b, c"),
          },
        _ => Err("expected ordered record literal fields"),
      }
    },
  )
})

test("match scrutinee lowers as single apply argument", () => {
  let source = "
let pick = (x) => {
  match(f(x)) {
    Var(v) => { v }
  }
};
"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Fn(fnOuter) => match (fnOuter.items) {
          [item] => match (item.kind) {
            CoreAst.Clause(outerClause) =>
              match (outerClause.body.kind) {
                CoreAst.Apply(_bundle, scrutinee) =>
                  match (scrutinee.kind) {
                    CoreAst.Apply(callee, arg) =>
                      match ((callee.kind, arg.kind)) {
                        (
                          CoreAst.Ident({ text: "f", _ }),
                          CoreAst.Ident({ text: "x", _ }),
                        ) => Ok(void),
                        _ => Err("expected scrutinee f(x)"),
                      },
                    _ => Err("expected lowered scrutinee apply"),
                  },
                _ => Err("expected match lowered to apply"),
              },
            _ => Err("expected outer clause"),
          },
          _ => Err("expected single outer item"),
        },
        _ => Err("expected outer fn"),
      }
    },
  )
})

test("panic call lowers to apply of Panic identifier with string argument", () => {
  let source = "let boom = Panic(\"boom\");"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(callee, arg) =>
          match ((callee.kind, arg.kind)) {
            (
              CoreAst.Ident({ text: "Panic", _ }),
              CoreAst.Lit(CoreAst.Str("boom")),
            ) => Ok(void),
            _ => Err("expected Panic(\"boom\") apply lowering"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

test("assignment lowers to assign(target, value) in source order", () => {
  let source = "
let x = {
  place = value;
  0
};
"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Let(seqBinding, seqBody) =>
          match (seqBinding.value.kind) {
            CoreAst.Apply(callee, arg) =>
              match ((callee.kind, arg.kind, seqBody.kind)) {
                (
                  CoreAst.Ident({ text: "assign", _ }),
                  CoreAst.Tuple([lhs, rhs]),
                  CoreAst.Lit(CoreAst.Int(0)),
                ) =>
                  match ((lhs.kind, rhs.kind)) {
                    (
                      CoreAst.Ident({ text: "place", _ }),
                      CoreAst.Ident({ text: "value", _ }),
                    ) => Ok(void),
                    _ => Err("expected assignment tuple args (place, value)"),
                  },
                _ => Err("expected assign call in lowered block sequence"),
              },
            _ => Err("expected assign apply"),
          },
        _ => Err("expected block sequence lowering via let"),
      }
    },
  )
})

test("match clause order and guard are preserved in lowered function bundle", () => {
  let source = "
let classify = (x) => {
  match(x) {
    Some(v) when cond(v) => { first(v) }
    Some(v) => { second(v) }
    _ => { fallback(x) }
  }
};
"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Fn(fnOuter) => match (fnOuter.items) {
          [item] => match (item.kind) {
            CoreAst.Clause(outerClause) =>
              match (outerClause.body.kind) {
                CoreAst.Apply(bundleExpr, _) =>
                  match (bundleExpr.kind) {
                    CoreAst.Fn(bundle) =>
                      match (bundle.items) {
                        [item1, item2, item3] =>
                          match ((item1.kind, item2.kind, item3.kind)) {
                            (
                              CoreAst.Clause(c1),
                              CoreAst.Clause(c2),
                              CoreAst.Clause(c3),
                            ) =>
                              if (c1.guard == None || c2.guard != None || c3.guard != None) {
                                Err("expected guard on first clause only")
                              } else {
                                let calleeName = (expr: CoreAst.Expr) =>
                                  match (expr.kind) {
                                    CoreAst.Apply(callee, _) =>
                                      match (callee.kind) {
                                        CoreAst.Ident({ text, _ }) => Ok(text),
                                        _ => Err("expected ident callee in clause body apply"),
                                      },
                                    _ => Err("expected clause body apply"),
                                  }
                                let firstName = calleeName(c1.body)
                                let secondName = calleeName(c2.body)
                                let fallbackName = calleeName(c3.body)
                                match ((firstName, secondName, fallbackName)) {
                                  (Ok("first"), Ok("second"), Ok("fallback")) => Ok(void),
                                  _ =>
                                    Err(
                                      "expected clause body order first -> second -> fallback"
                                    ),
                                }
                              },
                            _ => Err("expected lowered clause items"),
                          },
                        _ => Err("expected three lowered match clauses"),
                      },
                    _ => Err("expected lowered match bundle function"),
                  },
                _ => Err("expected match lowered to apply"),
              },
            _ => Err("expected outer clause"),
          },
          _ => Err("expected single outer item"),
        },
        _ => Err("expected outer fn"),
      }
    },
  )
})

test("call argument lowering preserves nested evaluation shape order", () => {
  let source = "let x = f(g(first), h(second));"
  let program = Frontend.parseAndLower(source)

  bind(
    bind(
      bind(
        expectSingleDeclGroup(program),
        (dg) => expectSingleLetDecl(dg),
      ),
      (ld) => expectSingleBinding(ld),
    ),
    (binding) => {
      match (binding.value.kind) {
        CoreAst.Apply(calleeF, argTuple) =>
          match ((calleeF.kind, argTuple.kind)) {
            (
              CoreAst.Ident({ text: "f", _ }),
              CoreAst.Tuple([arg1, arg2]),
            ) =>
              match ((arg1.kind, arg2.kind)) {
                (
                  CoreAst.Apply(gCallee, gArg),
                  CoreAst.Apply(hCallee, hArg),
                ) =>
                  match ((gCallee.kind, gArg.kind, hCallee.kind, hArg.kind)) {
                    (
                      CoreAst.Ident({ text: "g", _ }),
                      CoreAst.Ident({ text: "first", _ }),
                      CoreAst.Ident({ text: "h", _ }),
                      CoreAst.Ident({ text: "second", _ }),
                    ) => Ok(void),
                    _ => Err("expected nested args g(first), h(second)"),
                  },
                _ => Err("expected tuple args lowered as g(...) then h(...)"),
              },
            _ => Err("expected f applied to 2-tuple args"),
          },
        _ => Err("expected apply"),
      }
    },
  )
})

let results = runTests()
printResultsAndExit(results)
