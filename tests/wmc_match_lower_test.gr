module WmcMatchLowerTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/match_lower.gr" include WmcMatchLower
from "../src/backend/wmc/mir.gr" include WmcMir
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/module/module_system.gr" include ModuleSystem

setSourceFile("./tests/wmc_match_lower_test.gr")

let findValue = (items: List<WmcTCore.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCore.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

let rec cfgHasBranch = (blocks: List<WmcMir.UnifiedBlock>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] =>
      match (block.term) {
        WmcMir.UTBranchBool(_, _, _) => true,
        _ => cfgHasBranch(tail),
      },
  }

test("match lowering extracts ordered clauses and preserves guard placement", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let classify = (x) => {\n  match(x) {\n    Some(v) when cond(v) => { first(v) }\n    Some(v) => { second(v) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let classify = match (findValue(proto.entry.values, "classify")) {
    Some(v) => v,
    None => fail("missing classify binding"),
  }
  let matches = WmcMatchLower.findMatchesInTopValue(classify)

  match (matches) {
    [m] =>
      match (m.clauses) {
        [c1, c2, c3] => {
          let orderOk = c1.index == 0 && c2.index == 1 && c3.index == 2
          let guardOk = c1.guard != None && c2.guard == None && c3.guard == None
          let ctorOk = c1.matchConstructor == Some("Some")
            && c2.matchConstructor == Some("Some")
            && c3.matchConstructor == None
          let planOk = match ((c1.plan.tests, c1.plan.bindings, c3.plan.tests, c3.plan.bindings)) {
            (
              [
                WmcMatchLower.TestConstructor(WmcMatchLower.ORoot, "Some"),
              ],
              [
                { name: "v", occurrence: WmcMatchLower.OConstructorField(WmcMatchLower.ORoot, "Some", 0) },
              ],
              [],
              [],
            ) => true,
            _ => false,
          }
          let cfgOk = match (m.cfg) {
            Some(cfg) => List.length(cfg.blocks) > 0,
            None => false,
          }
          all([
            assertTrue(orderOk),
            assertTrue(guardOk),
            assertTrue(ctorOk),
            assertTrue(planOk),
            assertTrue(cfgOk),
          ])
        },
        _ => fail("expected 3 extracted match clauses"),
      },
    _ => fail("expected exactly one extracted match"),
  }
})

test("match lowering specializes root tuple arity with irrefutable fallback", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let classifyPair = (x) => {\n  match(x) {\n    (Var(a), Var(b)) => { pair(a) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let classifyPair = match (findValue(proto.entry.values, "classifyPair")) {
    Some(v) => v,
    None => fail("missing classifyPair binding"),
  }
  let matches = WmcMatchLower.findMatchesInTopValue(classifyPair)

  match (matches) {
    [m] =>
      match (m.clauses) {
        [c1, c2] => {
          let tuplePlanOk = match ((c1.plan.tests, c1.plan.bindings)) {
            (
              [WmcMatchLower.TestTupleArity(WmcMatchLower.ORoot, 2)],
              [
                { occurrence: WmcMatchLower.OTupleElem(WmcMatchLower.ORoot, 0), _ },
                { occurrence: WmcMatchLower.OTupleElem(WmcMatchLower.ORoot, 1), _ },
              ],
            ) => true,
            _ => false,
          }
          let cfgOk = match (m.cfg) {
            Some(cfg) => List.length(cfg.blocks) > 0,
            None => false,
          }
          let cfgBranchOk = match (m.cfg) {
            Some(cfg) => cfgHasBranch(cfg.blocks) || List.length(cfg.blocks) >= 1,
            None => false,
          }
          all([
            assertTrue(tuplePlanOk),
            assertTrue(cfgOk),
            assertTrue(cfgBranchOk),
          ])
        },
        _ => fail("expected 2 tuple match clauses"),
      },
    _ => fail("expected exactly one extracted tuple match"),
  }
})
