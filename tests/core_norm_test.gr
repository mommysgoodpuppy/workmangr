module CoreNormTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List

from "../src/core/core_ast.gr" include CoreAst
from "../src/core/source.gr" include Source
from "../src/core/surface_ast.gr" include SurfaceAst
from "../src/backend/wmc/core_ir.gr" include WmcCoreIr
from "../src/backend/wmc/core_norm.gr" include WmcCoreNorm

setSourceFile("./tests/core_norm_test.gr")

let span = { line: 1, col: 1, start: 0, end: 0 }: Source.Span

let typedNode = (id: Number) => { id, span, ty: None }: WmcCoreIr.TypedNode

let pattern = (id: Number, kind: WmcCoreIr.PatternKind) =>
  { node: typedNode(id), kind }: WmcCoreIr.Pattern

let expr = (id: Number, kind: WmcCoreIr.ExprKind) =>
  { node: typedNode(id), kind }: WmcCoreIr.Expr

let clause = (
  id: Number,
  param: WmcCoreIr.Pattern,
  guard: Option<WmcCoreIr.Expr>,
  matchConstructor: Option<String>,
  body: WmcCoreIr.Expr,
) =>
  {
    node: typedNode(id),
    param,
    guard,
    matchConstructor,
    body,
  }: WmcCoreIr.FnClause

let topValue = (name: String, value: WmcCoreIr.Expr) =>
  {
    name,
    exported: false,
    groupId: 1,
    groupKind: CoreAst.Plain,
    binding: {
      node: typedNode(1),
      name: pattern(2, WmcCoreIr.PVar(name)),
      annotation: None,
      value,
    }: WmcCoreIr.LetBinding,
  }: WmcCoreIr.TopValueBinding

let topValueWithGroup = (
  name: String,
  groupId: Number,
  groupKind: CoreAst.LetGroupMods,
  value: WmcCoreIr.Expr,
) =>
  {
    name,
    exported: false,
    groupId,
    groupKind,
    binding: {
      node: typedNode(groupId),
      name: pattern(groupId + 1, WmcCoreIr.PVar(name)),
      annotation: None,
      value,
    }: WmcCoreIr.LetBinding,
  }: WmcCoreIr.TopValueBinding

let singleValueModule = (binding: WmcCoreIr.TopValueBinding) =>
  {
    id: "test",
    sourcePath: "test.wm",
    surfaceProgram: { items: [], core: false }: SurfaceAst.Program,
    resolvedImports: [],
    imports: [],
    reexports: [],
    valueNames: [binding.name],
    typeDecls: [],
    values: [binding],
    diagnostics: [],
    status: WmcCoreIr.StatusOk,
  }: WmcCoreIr.CoreModule

test("core norm keeps simple single-clause lambda direct", () => {
  let fnExpr = expr(
    10,
    WmcCoreIr.EFn({
      node: typedNode(10),
      items: [
        {
          node: typedNode(11),
          kind: WmcCoreIr.FClause(
            clause(
              12,
              pattern(13, WmcCoreIr.PVar("x")),
              None,
              None,
              expr(14, WmcCoreIr.EIdent("x")),
            )
          ),
        }: WmcCoreIr.FnItem,
      ],
    }: WmcCoreIr.FnExpr),
  )
  let result = WmcCoreNorm.normalizeModuleDetailed(singleValueModule(topValue("id", fnExpr)))
  assertEquals(0, List.length(result.issues))
  match (result.normalized.values) {
    [binding] =>
      match (binding.value.kind) {
        WmcCoreNorm.NELambda(["x"], body) =>
          match (body.kind) {
            WmcCoreNorm.NEIdent("x") => assertTrue(true),
            _ => fail "expected direct identifier body",
          },
        _ => fail "expected direct lambda normalization",
      },
    _ => fail "expected single normalized binding",
  }
})

test("core norm rewrites recursive top-level groups into let_rec clusters", () => {
  let evenFn = expr(
    50,
    WmcCoreIr.EFn({
      node: typedNode(50),
      items: [
        {
          node: typedNode(51),
          kind: WmcCoreIr.FClause(
            clause(
              52,
              pattern(53, WmcCoreIr.PVar("n")),
              None,
              None,
              expr(54, WmcCoreIr.EIdent("odd")),
            )
          ),
        }: WmcCoreIr.FnItem,
      ],
    }: WmcCoreIr.FnExpr),
  )
  let oddFn = expr(
    60,
    WmcCoreIr.EFn({
      node: typedNode(60),
      items: [
        {
          node: typedNode(61),
          kind: WmcCoreIr.FClause(
            clause(
              62,
              pattern(63, WmcCoreIr.PVar("n")),
              None,
              None,
              expr(64, WmcCoreIr.EIdent("even")),
            )
          ),
        }: WmcCoreIr.FnItem,
      ],
    }: WmcCoreIr.FnExpr),
  )
  let module_ = {
    id: "test",
    sourcePath: "test.wm",
    surfaceProgram: { items: [], core: false }: SurfaceAst.Program,
    resolvedImports: [],
    imports: [],
    reexports: [],
    valueNames: ["even", "odd"],
    typeDecls: [],
    values: [
      topValueWithGroup("even", 100, CoreAst.Rec, evenFn),
      topValueWithGroup("odd", 100, CoreAst.Rec, oddFn),
    ],
    diagnostics: [],
    status: WmcCoreIr.StatusOk,
  }: WmcCoreIr.CoreModule
  let result = WmcCoreNorm.normalizeModuleDetailed(module_)
  assertEquals(0, List.length(result.issues))
  match (result.normalized.values) {
    [evenBinding, oddBinding] => {
      match (evenBinding.value.kind) {
        WmcCoreNorm.NELetRec(bindings, body) => {
          assertEquals(2, List.length(bindings))
          match (body.kind) {
            WmcCoreNorm.NEIdent("even") => assertTrue(true),
            _ => fail "expected even let_rec body to select even",
          }
        },
        _ => fail "expected recursive binding to normalize into let_rec",
      }
      match (oddBinding.value.kind) {
        WmcCoreNorm.NELetRec(bindings, body) => {
          assertEquals(2, List.length(bindings))
          match (body.kind) {
            WmcCoreNorm.NEIdent("odd") => assertTrue(true),
            _ => fail "expected odd let_rec body to select odd",
          }
        },
        _ => fail "expected recursive binding to normalize into let_rec",
      }
    },
    _ => fail "expected two normalized recursive bindings",
  }
})

test("core norm rewrites guarded constructor clauses into lambda match", () => {
  let fnExpr = expr(
    20,
    WmcCoreIr.EFn({
      node: typedNode(20),
      items: [
        {
          node: typedNode(21),
          kind: WmcCoreIr.FClause(
            clause(
              22,
              pattern(
                23,
                WmcCoreIr.PConstructor("Some", [pattern(24, WmcCoreIr.PVar("value"))]),
              ),
              Some(expr(25, WmcCoreIr.EIdent("cond"))),
              Some("Some"),
              expr(26, WmcCoreIr.EIdent("first")),
            )
          ),
        }: WmcCoreIr.FnItem,
        {
          node: typedNode(27),
          kind: WmcCoreIr.FClause(
            clause(
              28,
              pattern(29, WmcCoreIr.PWildcard),
              None,
              None,
              expr(30, WmcCoreIr.EIdent("fallback")),
            )
          ),
        }: WmcCoreIr.FnItem,
      ],
    }: WmcCoreIr.FnExpr),
  )
  let result = WmcCoreNorm.normalizeModuleDetailed(singleValueModule(topValue("classify", fnExpr)))
  assertEquals(0, List.length(result.issues))
  match (result.normalized.values) {
    [binding] =>
      match (binding.value.kind) {
        WmcCoreNorm.NELambda([paramName], body) =>
          match (body.kind) {
            WmcCoreNorm.NEMatch(matchExpr) => {
              match (matchExpr.scrutinee.kind) {
                WmcCoreNorm.NEIdent(name) => assertEquals(paramName, name),
                _ => fail "expected match scrutinee to use generated parameter",
              }
              match (matchExpr.clauses) {
                [firstClause, secondClause] => {
                  assertEquals(0, firstClause.index)
                  assertEquals(1, secondClause.index)
                  match (firstClause.pattern.kind) {
                    WmcCoreNorm.NPConstructor("Some", [arg]) =>
                      match (arg.kind) {
                        WmcCoreNorm.NPVar("value") => assertTrue(true),
                        _ => fail "expected constructor binder to survive normalization",
                      },
                    _ => fail "expected constructor pattern in first clause",
                  }
                  match (firstClause.guard) {
                    Some(guardExpr) =>
                      match (guardExpr.kind) {
                        WmcCoreNorm.NEIdent("cond") => assertTrue(true),
                        _ => fail "expected normalized guard expression",
                      },
                    None => fail "expected guard on first clause",
                  }
                  match (secondClause.pattern.kind) {
                    WmcCoreNorm.NPWildcard => assertTrue(true),
                    _ => fail "expected wildcard fallback clause",
                  }
                },
                _ => fail "expected two normalized match clauses",
              }
            },
            _ => fail "expected lambda body to be a match",
          },
        _ => fail "expected function bundle to normalize into lambda",
      },
    _ => fail "expected single normalized binding",
  }
})

test("core norm groups tuple call arguments into normalized call args", () => {
  let callExpr = expr(
    40,
    WmcCoreIr.EApply(
      expr(41, WmcCoreIr.EIdent("+")),
      expr(
        42,
        WmcCoreIr.ETuple([
          expr(43, WmcCoreIr.ELit(CoreAst.Int(1))),
          expr(44, WmcCoreIr.ELit(CoreAst.Int(2))),
        ]),
      ),
    ),
  )
  let result = WmcCoreNorm.normalizeModuleDetailed(singleValueModule(topValue("sum", callExpr)))
  assertEquals(0, List.length(result.issues))
  match (result.normalized.values) {
    [binding] =>
      match (binding.value.kind) {
        WmcCoreNorm.NECall(callee, args) => {
          match (callee.kind) {
            WmcCoreNorm.NEIdent("+") => assertTrue(true),
            _ => fail "expected call callee identifier",
          }
          match (args) {
            [left, right] =>
              match ((left.kind, right.kind)) {
                (WmcCoreNorm.NELit(CoreAst.Int(1)), WmcCoreNorm.NELit(CoreAst.Int(2))) => assertTrue(true),
                _ => fail "expected flattened tuple args in normalized call",
              },
            _ => fail "expected two grouped call arguments",
          }
        },
        _ => fail "expected normalized call",
      },
    _ => fail "expected single normalized binding",
  }
})
