module LspInlayTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "string" include String
from "../src/cli/lsp/inlay.gr" include Inlay

setSourceFile("./tests/lsp_inlay_test.gr")

let noop = (_: String) => void

let escapeJson = (s: String) => {
  let step1 = String.replaceAll("\\", "\\\\", s)
  let step2 = String.replaceAll("\"", "\\\"", step1)
  let step3 = String.replaceAll("\n", "\\n", step2)
  let step4 = String.replaceAll("\r", "\\r", step3)
  String.replaceAll("\t", "\\t", step4)
}

let canonicalNonWs = (text: String) => {
  let noSpace = String.replaceAll(" ", "", text)
  let noTab = String.replaceAll("\t", "", noSpace)
  let noLf = String.replaceAll("\n", "", noTab)
  String.replaceAll("\r", "", noLf)
}

test("type inlays still render under missing semicolon recovery", () => {
  let source = "let x = 1\nlet y = x;"
  let hints = Inlay.inlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  assertTrue(String.contains(": Int", hints))
})

test("format inlays do not synthesize legacy import artifacts", () => {
  let source = "from \"std/list\" import * as List;\nlet x = 1;"
  let hints = Inlay.inlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  assertTrue(!String.contains("import std/list;", hints))
})

test("format inlays recover match arrow bare clause bodies", () => {
  let source =
    "let xample = match(in) => {\n"
      ++ "  Some(x) => x,\n"
      ++ "  None => Panic(\"panic\")\n"
      ++ "}"
  let hints = Inlay.inlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  // Expect structural insertions for synthesized clause blocks and top-level semicolon.
  let hasAnyInsertion = String.contains("\"label\":\"", hints)
  let hasImpossibleChunk = String.contains("{x,", hints)
    || String.contains("};let", hints)
  let hasMergedCloseSemi = String.contains("\"label\":\"};\"", hints)
  let hasSeparateRBrace = String.contains("\"label\":\"}\"", hints)
  let hasSeparateSemi = String.contains("\"label\":\";\"", hints)
  let hasSpuriousParen = String.contains("\"label\":\"(\"", hints)
  all([
    assertTrue(hasAnyInsertion),
    assertFalse(hasImpossibleChunk),
    assertFalse(hasMergedCloseSemi),
    assertTrue(hasSeparateRBrace),
    assertTrue(hasSeparateSemi),
    assertFalse(hasSpuriousParen),
  ])
})

test("format inlays recover missing match-arm comma as separate token", () => {
  let source =
    "let xample = match(in) => {\n"
      ++ "  Some(x) => x\n"
      ++ "  None => Panic(\"panic\")\n"
      ++ "}"
  let hints = Inlay.inlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  let hasComma = String.contains("\"label\":\",\"", hints)
    || String.contains("\"label\":\",\"", hints)
  let hasMergedComma = String.contains("\"label\":\"},\"", hints)
    || String.contains("\"label\":\",}\"", hints)
  all([
    assertTrue(hasComma),
    assertFalse(hasMergedComma),
  ])
})

test("format inlay preview keeps backend order for shared-anchor tokens", () => {
  let source =
    "let xample = match(in) => {\n"
      ++ "  Some(x) => x\n"
      ++ "  None => Panic(\"panic\")\n"
      ++ "}"
  let hints = Inlay.formatInlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  let preview = Inlay.previewFromHintsJson(source, hints, true)
  let hasBraceCommaOrder = String.contains("*}**,*", preview)
  let hasCommaBraceOrder = String.contains("*,**}*", preview)
  all([
    assertTrue(hasBraceCommaOrder),
    assertFalse(hasCommaBraceOrder),
  ])
})

test("format inlays keep inferred hole before semicolon in missing let rhs", () => {
  let source = "let thing = "
  let hints = Inlay.formatInlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  let preview = Inlay.previewFromHintsJson(source, hints, true)
  let canonicalPreview = canonicalNonWs(preview)
  let canonicalExpected = canonicalNonWs("let thing = *?**;*")
  let hasVirtualQ = String.contains("\"label\":\"?\"", hints)
  let hasVirtualSemi = String.contains("\"label\":\";\"", hints)
  all([
    assertTrue(hasVirtualQ),
    assertTrue(hasVirtualSemi),
    assertEquals(canonicalExpected, canonicalPreview),
  ])
})

test("format inlays recover lambda arrow bare body to block", () => {
  let source = "let main = => print(thing)"
  let hints = Inlay.formatInlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  let preview = Inlay.previewFromHintsJson(source, hints, true)
  let canonicalPreview = canonicalNonWs(preview)
  let canonicalExpected = canonicalNonWs("let main = *()* => *{*print(thing)*}**;*")
  let hasVirtualLBrace = String.contains("\"label\":\"{\"", hints)
  let hasVirtualRBrace = String.contains("\"label\":\"}\"", hints)
  all([
    assertTrue(hasVirtualLBrace),
    assertTrue(hasVirtualRBrace),
    assertEquals(canonicalExpected, canonicalPreview),
  ])
})

test("format inlays keep recovered wildcard binder virtual", () => {
  let source = "let ="
  let hints = Inlay.formatInlayHintsForSource(
    source,
    0,
    String.length(source),
    noop,
    escapeJson,
    false
  )
  let preview = Inlay.previewFromHintsJson(source, hints, true)
  let canonicalPreview = canonicalNonWs(preview)
  let canonicalExpected = canonicalNonWs("let *_* = *?**;*")
  let hasWildcardInlay = String.contains("\"label\":\"_\"", hints)
  all([
    assertTrue(hasWildcardInlay),
    assertEquals(canonicalExpected, canonicalPreview),
  ])
})

let results = runTests()
printResultsAndExit(results)
