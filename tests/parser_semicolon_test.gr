test("only @core directive enables canonical core mode", () => {
  clearErrors()
  let coreProgram = Parser.parse("@core;\nlet x = 1;")
  let fooProgram = Parser.parse("@foo;\nlet x = 1;")
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(coreProgram.core),
    assertFalse(fooProgram.core),
    assertFalse(hasErrors),
  ])
})

test("unknown directives parse as top-level directives without panicking", () => {
  clearErrors()
  let parsed = Parser.parse("@future;\nlet x = 1;")
  let hasDirective = List.some(
    (item: SurfaceAst.TopItem) => match (item) {
      SurfaceAst.Directive({ name, _ }) => name.text == "future",
      _ => false,
    },
    parsed.items
  )
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(hasDirective),
    assertFalse(hasErrors),
    assertFalse(parsed.core),
  ])
})

test("parser supports domain/policy/op/annotate rule declarations", () => {
  clearErrors()
  let source =
    "domain effect { mergeRow union; conflict [(A, B)]; default { target arg0; requiresNot [Closed]; }; };"
      ++ "\npolicy pure { rejectsAllDomains; };"
      ++ "\nop io.read { callPolicy pure; rejectDomains [effect, mem]; };"
      ++ "\nannotate io.read { pure, noLeakMem };"
  let parsed = Parser.parse(source)
  let hasDomain = List.some((item: SurfaceAst.TopItem) => match (item) {
    SurfaceAst.DeclGroup(group) => match (group.decls) {
      [SurfaceAst.DomainDecl(_)] => true,
      _ => false,
    },
    _ => false,
  }, parsed.items)
  let hasPolicy = List.some((item: SurfaceAst.TopItem) => match (item) {
    SurfaceAst.DeclGroup(group) => match (group.decls) {
      [SurfaceAst.PolicyDecl(_)] => true,
      _ => false,
    },
    _ => false,
  }, parsed.items)
  let hasOp = List.some((item: SurfaceAst.TopItem) => match (item) {
    SurfaceAst.DeclGroup(group) => match (group.decls) {
      [SurfaceAst.OpDecl(_)] => true,
      _ => false,
    },
    _ => false,
  }, parsed.items)
  let hasAnnotate = List.some((item: SurfaceAst.TopItem) => match (item) {
    SurfaceAst.DeclGroup(group) => match (group.decls) {
      [SurfaceAst.AnnotateDecl(_)] => true,
      _ => false,
    },
    _ => false,
  }, parsed.items)
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(hasDomain),
    assertTrue(hasPolicy),
    assertTrue(hasOp),
    assertTrue(hasAnnotate),
    assertFalse(hasErrors),
  ])
})

test("parser disambiguates match bundle literal vs scrutinee vs arrow sugar", () => {
  clearErrors()
  let bundleProgram = Parser.parse("let m = match { Var(x) => { x } };")
  let scrutineeProgram = Parser.parse("let m = match(input) { Var(x) => { x } };")
  let arrowProgram = Parser.parse("let m = match(input) => { Var(x) => { x } };")

  let matchShape = (program: SurfaceAst.Program) =>
    match (program.items) {
      [SurfaceAst.DeclGroup(group)] => match (group.decls) {
        [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
          [binding] => match (binding.value.kind) {
            SurfaceAst.Match(m) => Some((m.scrutinee, m.arrowSugar)),
            _ => None,
          },
          _ => None,
        },
        _ => None,
      },
      _ => None,
    }

  let bundleOk = match (matchShape(bundleProgram)) {
    Some((None, false)) => true,
    _ => false,
  }
  let scrutineeOk = match (matchShape(scrutineeProgram)) {
    Some((Some(_), false)) => true,
    _ => false,
  }
  let arrowOk = match (matchShape(arrowProgram)) {
    Some((Some(_), true)) => true,
    _ => false,
  }
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(bundleOk),
    assertTrue(scrutineeOk),
    assertTrue(arrowOk),
    assertFalse(hasErrors),
  ])
})

test("parser recovers match arrow clauses with non-block bodies", () => {
  clearErrors()
  let source =
    "let xample = match(in) => {\n"
      ++ "  Some(x) => x,\n"
      ++ "  None => Panic(\"panic\")\n"
      ++ "}"
  let parsed = Parser.parse(source)

  let shapeOk = match (parsed.items) {
    [SurfaceAst.DeclGroup(group)] => match (group.decls) {
      [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
        [binding] => match (binding.value.kind) {
          SurfaceAst.Match(m) => match (m.bundle.items) {
            [
              { kind: SurfaceAst.Clause(c1), _ },
              { kind: SurfaceAst.Clause(c2), _ },
            ] =>
              match ((c1.body.items, c2.body.items)) {
                (
                  [
                    SurfaceAst.MarkItem({ kind: SurfaceAst.MissingToken("{"), _ }),
                    SurfaceAst.ExprItem({ kind: SurfaceAst.Ident({ text: "x", _ }), _ }),
                    SurfaceAst.MarkItem({ kind: SurfaceAst.MissingToken("}"), _ }),
                  ],
                  [
                    SurfaceAst.MarkItem({ kind: SurfaceAst.MissingToken("{"), _ }),
                    SurfaceAst.ExprItem({ kind: SurfaceAst.Postfix(_), _ }),
                    SurfaceAst.MarkItem({ kind: SurfaceAst.MissingToken("}"), _ }),
                  ],
                ) => true,
                _ => false,
              },
            _ => false,
          },
          _ => false,
        },
        _ => false,
      },
      _ => false,
    },
    _ => false,
  }

  let marked = getMarkedErrors()
  let missingBraceWarnings = List.length(List.filter(
    (entry: Error.MarkedError) => match (entry) {
      { mark, error } => match ((mark.kind, error.severity)) {
        (SurfaceAst.MissingToken("{"), Error.Warning) => true,
        (SurfaceAst.MissingToken("}"), Error.Warning) => true,
        _ => false,
      },
    },
    marked
  ))
  assertTrue(shapeOk)
  assertTrue(missingBraceWarnings >= 4)
})

test("parser recovers lambda arrow body without braces", () => {
  clearErrors()
  let source = "let main = => print(thing)"
  let parsed = Parser.parse(source)

  let shapeOk = match (parsed.items) {
    [SurfaceAst.DeclGroup(group)] => match (group.decls) {
      [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
        [binding] => match (binding.value.kind) {
          SurfaceAst.Fn(fnExpr) => match (fnExpr.items) {
            [{ kind: SurfaceAst.Clause(clause), _ }] => match (clause.body.items) {
              [
                SurfaceAst.MarkItem({ kind: SurfaceAst.MissingToken("{"), _ }),
                SurfaceAst.ExprItem({ kind: SurfaceAst.Postfix(_), _ }),
                SurfaceAst.MarkItem({ kind: SurfaceAst.MissingToken("}"), _ }),
              ] => true,
              _ => false,
            },
            _ => false,
          },
          _ => false,
        },
        _ => false,
      },
      _ => false,
    },
    _ => false,
  }

  let marked = getMarkedErrors()
  let missingBraceWarnings = List.length(List.filter(
    (entry: Error.MarkedError) => match (entry) {
      { mark, error } => match ((mark.kind, error.severity)) {
        (SurfaceAst.MissingToken("{"), Error.Warning) => true,
        (SurfaceAst.MissingToken("}"), Error.Warning) => true,
        _ => false,
      },
    },
    marked
  ))
  assertTrue(shapeOk)
  assertTrue(missingBraceWarnings >= 2)
})

test("raw-like directives remain non-canonical in WMC parser mode", () => {
  clearErrors()
  let parsed = Parser.parse("@raw;\n@backend;\nlet x = 1;")
  let directiveNames = List.filterMap((item: SurfaceAst.TopItem) =>
    match (item) {
      SurfaceAst.Directive({ name, _ }) => Some(name.text),
      _ => None,
    }, parsed.items)
  let hasRaw = List.some((name: String) => name == "raw", directiveNames)
  let hasBackend = List.some((name: String) => name == "backend", directiveNames)
  let marked = getMarkedErrors()
  let hasRawWarning = List.some(
    (entry: Error.MarkedError) =>
      String.contains("Directive @raw is non-canonical and ignored", entry.error.message),
    marked
  )
  let hasBackendWarning = List.some(
    (entry: Error.MarkedError) =>
      String.contains("Directive @backend is non-canonical and ignored", entry.error.message),
    marked
  )
  all([
    assertTrue(hasRaw),
    assertTrue(hasBackend),
    assertFalse(parsed.core),
    assertTrue(hasRawWarning),
    assertTrue(hasBackendWarning),
  ])
})

test("parser records mut let group modifier", () => {
  clearErrors()
  let parsed = Parser.parse("let mut counter = 0;")
  let hasMutLetGroup = match (parsed.items) {
    [SurfaceAst.DeclGroup(group)] => match (group.kind) {
      SurfaceAst.LetGroup(SurfaceAst.Mut) => true,
      _ => false,
    },
    _ => false,
  }
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(hasMutLetGroup),
    assertFalse(hasErrors),
  ])
})

test("backend-target directive syntax with args is rejected in canonical parser", () => {
  clearErrors()
  let parsed = Parser.parseResult("@backend(\"zig\");\nlet x = 1;")
  let marked = getMarkedErrors()
  let hasDirective = List.some(
    (item: SurfaceAst.TopItem) => match (item) {
      SurfaceAst.Directive({ name, _ }) => name.text == "backend",
      _ => false,
    },
    parsed.program.items
  )
  let hasError = List.length(marked) > 0
  all([
    assertTrue(hasDirective),
    assertTrue(hasError),
    assertFalse(parsed.program.core),
  ])
})

test("parser supports less-than comparisons inside match conditions", () => {
  clearErrors()
  let source = "let abs = (n) => { match(n < 0) { true => { 0 - n }, false => { n } } };"
  let parsed = Parser.parse(source)
  let hasLessThanInMatch = match (parsed.items) {
    [SurfaceAst.DeclGroup(group)] => match (group.decls) {
      [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
        [binding] => match (binding.value.kind) {
          SurfaceAst.InfixChain({ rest: [({ text: "=>", _ }, rhs)], _ }) =>
            match (rhs.kind) {
              SurfaceAst.Block(block) => match (block.body.kind) {
                SurfaceAst.Match(matchExpr) => match (matchExpr.scrutinee) {
                  Some({ kind: SurfaceAst.Paren({ kind: SurfaceAst.InfixChain({ rest: [({ text: "<", _ }, _)], _ }), _ }), _ }) => true,
                  _ => false,
                },
                _ => false,
              },
              _ => false,
            },
          _ => false,
        },
        _ => false,
      },
      _ => false,
    },
    _ => false,
  }
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(hasLessThanInMatch),
    assertFalse(hasErrors),
  ])
})

test("parser keeps full postfix call span for rhs of infix expression", () => {
  clearErrors()
  let source = "let z = abs(finalLoc.x) + abs(finalLoc.y);"
  let parsed = Parser.parse(source)
  let rhsSpanText = match (parsed.items) {
    [SurfaceAst.DeclGroup(group)] => match (group.decls) {
      [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
        [binding] => match (binding.value.kind) {
          SurfaceAst.InfixChain({ rest: [(_op, rhs)], _ }) =>
            Some(Source.slice(source, rhs.node.span)),
          _ => None,
        },
        _ => None,
      },
      _ => None,
    },
    _ => None,
  }
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertEquals(Some("abs(finalLoc.y)"), rhsSpanText),
    assertFalse(hasErrors),
  ])
})

test("parser keeps module-qualified call separate from plain field projection", () => {
  clearErrors()
  let source = "let a = List.length(xs);\nlet b = rec.field;"
  let parsed = Parser.parse(source)
  let shapeOk = match (parsed.items) {
    [SurfaceAst.DeclGroup(g1), SurfaceAst.DeclGroup(g2)] => {
      let aOk = match (g1.decls) {
        [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
          [binding] => match (binding.value.kind) {
            SurfaceAst.Postfix({ target, segments }) =>
              match ((target.kind, segments)) {
                (
                  SurfaceAst.Ident({ text: "List", _ }),
                  [
                    SurfaceAst.Project({ text: "length", _ }),
                    SurfaceAst.Call([{ kind: SurfaceAst.Ident({ text: "xs", _ }), _ }]),
                  ],
                ) => true,
                _ => false,
              },
            _ => false,
          },
          _ => false,
        },
        _ => false,
      }
      let bOk = match (g2.decls) {
        [SurfaceAst.LetDecl(ld)] => match (ld.bindings) {
          [binding] => match (binding.value.kind) {
            SurfaceAst.Postfix({ target, segments }) =>
              match ((target.kind, segments)) {
                (
                  SurfaceAst.Ident({ text: "rec", _ }),
                  [SurfaceAst.Project({ text: "field", _ })],
                ) => true,
                _ => false,
              },
            _ => false,
          },
          _ => false,
        },
        _ => false,
      }
      aOk && bOk
    },
    _ => false,
  }
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(shapeOk),
    assertFalse(hasErrors),
  ])
})

test("parser accepts constructor-style nominal record literal syntax", () => {
  clearErrors()
  let source = "let op = Operation{ direction, distance, step = 1 };"
  let parsed = Parser.parse(source)
  let hasBinding = match (parsed.items) {
    [SurfaceAst.DeclGroup(group)] => match (group.decls) {
      [SurfaceAst.LetDecl(ld)] => List.length(ld.bindings) == 1,
      _ => false,
    },
    _ => false,
  }
  let hasErrors = List.length(getMarkedErrors()) > 0
  all([
    assertTrue(hasBinding),
    assertFalse(hasErrors),
  ])
})

let results = runTests()
printResultsAndExit(results)
