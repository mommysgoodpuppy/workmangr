module WmcTCoreNormTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "map" include Map
from "list" include List

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/backend/wmc/tcore_norm.gr" include WmcTCoreNorm
from "../src/module/module_system.gr" include ModuleSystem
from "../src/core/core_ast.gr" include CoreAst

setSourceFile("./tests/wmc_tcore_norm_test.gr")

let findValue = (items: List<WmcTCore.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCore.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

let findNormValue = (items: List<WmcTCoreNorm.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCoreNorm.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

test("tcore_norm normalizes if-expression into boolean match", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let choose = if cond() { first() } else { second() };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let choose = match (findValue(proto.entry.values, "choose")) {
    Some(v) => v,
    None => fail("missing choose binding"),
  }

  let norm = WmcTCoreNorm.normalizeTopValueBinding(choose)

  match (norm.value.kind) {
    WmcTCoreNorm.NEMatch(m) =>
      match (m.clauses) {
        [c1, c2] => {
          let patternOk = match ((c1.param.kind, c2.param.kind)) {
            (WmcTCoreNorm.NPLit(CoreAst.Bool(true)), WmcTCoreNorm.NPLit(CoreAst.Bool(false))) => true,
            _ => false,
          }
          all([
            assertTrue(patternOk),
            assertTrue(c1.guard == None && c2.guard == None),
          ])
        },
        _ => fail("expected two boolean match clauses"),
      },
    _ => fail("expected normalized if to become NEMatch"),
  }
})

test("tcore_norm detailed match search reports unsupported bundle include", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let shared = (x) => { _ => { x } };\nlet classify = (x) => {\n  match(x) {\n    shared\n    Some(v) => { first(v) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let classify = match (findValue(proto.entry.values, "classify")) {
    Some(v) => v,
    None => fail("missing classify binding"),
  }

  let detailed = WmcTCoreNorm.findMatchesInTopValueDetailed(classify)
  let issueOk = match (detailed.issues) {
    [
      { kind: WmcTCoreNorm.UnsupportedMatchBundleInclude("shared"), _ },
      ..._,
    ] => true,
    _ => false,
  }

  all([
    assertTrue(List.length(detailed.matches) == 0),
    assertTrue(issueOk),
  ])
})

test("tcore_norm keeps zero-arg lambda as canonical unit thunk marker", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let main = => { 1 + 1 };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let main = match (findNormValue(proto.normalizedEntry.values, "main")) {
    Some(v) => v,
    None => fail("missing main binding"),
  }

  let ok = match (main.value.kind) {
    WmcTCoreNorm.NELambda(param, _body) => param == WmcTCoreNorm.zeroArgThunkParamName,
    _ => false,
  }
  assertTrue(ok)
})

test("findMatchesInTopValue ignores synthetic if-match inside thunk body", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let main = => { if true { 1 } else { 2 } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let main = match (findValue(proto.entry.values, "main")) {
    Some(v) => v,
    None => fail("missing main binding"),
  }

  let matches = WmcTCoreNorm.findMatchesInTopValue(main)
  assertTrue(List.length(matches) == 0)
})
