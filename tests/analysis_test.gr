test("record projection with a bad field argument prefers the field span", () => {
  Error.clearErrors()
  let source =
    "
record Location = { x: Int, y: Int };
let r: Location = .{ x = 1, y = 2 };
let bad = project(r, 1);
"
  let _ = Analysis.analyze(source)
  let diagnostics = Error.getErrors()
  let rec findProjection = (remaining: List<Error.CompilerError>) =>
    match (remaining) {
      [] => None,
      [diag, ...rest] =>
        if (
          diag.stage == Error.TypeInference
            && String.contains("record projection expects string field name", diag.message)
        ) {
          Some(diag)
        } else {
          findProjection(rest)
        },
    }
  match (findProjection(diagnostics)) {
    Some(diag) => {
      let excerpt = Source.slice(source, diag.span)
      all([
        assertEquals("1", excerpt),
        assertEquals(4, diag.span.line),
      ])
    },
    None => fail("expected record projection field diagnostic"),
  }
})

