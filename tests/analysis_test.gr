module AnalysisTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map
from "../src/core/analysis.gr" include Analysis
from "../src/core/constraints.gr" include Constraints
from "../src/core/core_ast.gr" include CoreAst
from "../src/core/error.gr" include Error
from "../src/core/layer1/infer.gr" include Infer
from "../src/core/layer1/infer_state.gr" include InferState as Layer1InferState
from "../src/core/source.gr" include Source
from "string" include String

setSourceFile("./tests/analysis_test.gr")

test("analysis emits type inference diagnostics from infer marks", () => {
  Error.clearErrors()
  let source =
    "
let bad = (x) => { if (1) { x } else { x } };
"
  let _ = Analysis.analyze(source)
  let diagnostics = Error.getErrors()
  let hasTypeInferenceDiagnostic = List.some(
    (entry: Error.CompilerError) => match (entry.stage) {
      Error.TypeInference => true,
      _ => false,
    },
    diagnostics
  )
  assertTrue(hasTypeInferenceDiagnostic)
})

test("typeInferenceDiagnostics uses mark span for unknown identifiers", () => {
  let span = Source.makeSpan(12, 5, 120, 122)
  let node: CoreAst.Node = { id: 777, span }
  let name: CoreAst.Name = { node, text: "ys" }
  let mark: Infer.TypeMark = {
    reason: Layer1InferState.UnknownIdentifier,
    origin: Constraints.makeOrigin(-1, "unknown identifier"),
    blame: None,
    related: [],
    mark: CoreAst.FreeVar(name),
    message: "Type error: unknown identifier ys",
  }
  let diagnostics = Analysis.typeInferenceDiagnostics([mark], Map.make())
  match (diagnostics) {
    [diag] => all([
      assertEquals(12, diag.span.line),
      assertEquals(5, diag.span.col),
      assertEquals(120, diag.span.start),
      assertEquals(122, diag.span.end),
    ]),
    _ => fail("expected exactly one diagnostic"),
  }
})

test("typeInferenceDiagnostics keeps related origins as notes", () => {
  let mark: Infer.TypeMark = {
    reason: Layer1InferState.TypeMismatch,
    origin: Constraints.makeOrigin(10, "match scrutinee"),
    blame: None,
    related: [
      Constraints.makeOrigin(11, "then branch"),
      Constraints.makeOrigin(12, "else branch"),
    ],
    mark: CoreAst.Inconsistent,
    message: "Type error (match scrutinee): cannot unify nominal types Left and Right",
  }
  let diagnostics = Analysis.typeInferenceDiagnostics([mark], Map.make())
  match (diagnostics) {
    [diag] => {
      let noteCount = List.length(diag.clues)
      let hasOrigin = List.some(
        (clue: Error.ErrorClue) => clue == Error.Note("node=10 match scrutinee"),
        diag.clues
      )
      let hasThen = List.some(
        (clue: Error.ErrorClue) => clue == Error.Note("node=11 then branch"),
        diag.clues
      )
      let hasElse = List.some(
        (clue: Error.ErrorClue) => clue == Error.Note("node=12 else branch"),
        diag.clues
      )
      all([
        assertEquals(3, noteCount),
        assertTrue(hasOrigin),
        assertTrue(hasThen),
        assertTrue(hasElse),
      ])
    },
    _ => fail("expected exactly one diagnostic"),
  }
})

test("typeInferenceDiagnostics includes blame origin as note", () => {
  let mark: Infer.TypeMark = {
    reason: Layer1InferState.TypeMismatch,
    origin: Constraints.makeOrigin(10, "binding annotation"),
    blame: Some(Constraints.makeOrigin(20, "binding value")),
    related: [],
    mark: CoreAst.Inconsistent,
    message: "Type error (binding annotation): cannot unify Int with Bool",
  }
  let diagnostics = Analysis.typeInferenceDiagnostics([mark], Map.make())
  match (diagnostics) {
    [diag] => {
      let hasOrigin = List.some(
        (clue: Error.ErrorClue) => clue == Error.Note("node=10 binding annotation"),
        diag.clues
      )
      let hasBlame = List.some(
        (clue: Error.ErrorClue) => clue == Error.Note("node=20 binding value"),
        diag.clues
      )
      all([
        assertTrue(hasOrigin),
        assertTrue(hasBlame),
      ])
    },
    _ => fail("expected exactly one diagnostic"),
  }
})

test("match scrutinee mismatch reports the scrutinee span", () => {
  Error.clearErrors()
  let source =
    "
type Option<T> = Some<T> | None;
let bad = () => {
  let y = 1;
  match(y) {
    Some(v) => { v }
    None => { 0 }
  }
};
"
  let _ = Analysis.analyze(source)
  let diagnostics = Error.getErrors()
  let rec findMismatch = (remaining: List<Error.CompilerError>) =>
    match (remaining) {
      [] => None,
      [diag, ...rest] =>
        if (diag.stage == Error.TypeInference && String.contains("match scrutinee", diag.message)) {
          Some(diag)
        } else {
          findMismatch(rest)
        },
    }
  match (findMismatch(diagnostics)) {
    Some(diag) => {
      let excerpt = Source.slice(source, diag.span)
      all([
        assertEquals("y", excerpt),
        assertEquals(5, diag.span.line),
      ])
    },
    None => fail("expected match scrutinee diagnostic"),
  }
})

test("lowered match function application reports the branch argument span", () => {
  Error.clearErrors()
  let source =
    "
type Option<T> = Some<T> | None;
let takesInt = (x) => { x + 1 };
let forceSome = () => {
  let y = 1;
  match(y) {
    Some(v) => { takesInt(v) }
    None => { 0 }
  }
};
"
  let _ = Analysis.analyze(source)
  let diagnostics = Error.getErrors()
  let rec findMismatch = (remaining: List<Error.CompilerError>) =>
    match (remaining) {
      [] => None,
      [diag, ...rest] =>
        if (
          diag.stage == Error.TypeInference
            && String.contains("Type error (function application)", diag.message)
        ) {
          Some(diag)
        } else {
          findMismatch(rest)
        },
    }
  match (findMismatch(diagnostics)) {
    Some(diag) => {
      let excerpt = Source.slice(source, diag.span)
      all([
        assertEquals("v", excerpt),
        assertEquals(7, diag.span.line),
      ])
    },
    None => fail("expected function application diagnostic"),
  }
})

