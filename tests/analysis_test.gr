test("match scrutinee mismatch prefers the constraining use-site", () => {
  Error.clearErrors()
  let source =
    "
type Option<T> = Some<T> | None;
let takesInt = (x) => { x + 1 };
let read = (x) => {
  let file = x;
  let _n = takesInt(file);
  match(file) {
    Some(file) => {
      file
    }
    None => { 1 }
  }
};
"
  let _ = Analysis.analyze(source)
  let diagnostics = Error.getErrors()
  let rec findMismatch = (remaining: List<Error.CompilerError>) =>
    match (remaining) {
      [] => None,
      [diag, ...rest] =>
        if (
          diag.stage == Error.TypeInference
            && String.contains("Type error (match scrutinee)", diag.message)
        ) {
          Some(diag)
        } else {
          findMismatch(rest)
        },
    }
  match (findMismatch(diagnostics)) {
    Some(diag) => {
      let excerpt = Source.slice(source, diag.span)
      all([
        assertEquals("file", excerpt),
        assertEquals(7, diag.span.line),
      ])
    },
    None => fail("expected match scrutinee diagnostic"),
  }
})

