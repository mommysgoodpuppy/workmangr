module WmcMirDebugTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map
from "string" include String

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/match_lower.gr" include WmcMatchLower
from "../src/backend/wmc/mir_debug.gr" include WmcMirDebug
from "../src/backend/wmc/mir_lower.gr" include WmcMirLower
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/module/module_system.gr" include ModuleSystem

setSourceFile("./tests/wmc_mir_debug_test.gr")

let findValue = (items: List<WmcTCore.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCore.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

test("MIR debug printer renders switch, tests, binds, and select", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let classify = (x) => {\n  match(x) {\n    Some(v) when cond(v) => { first(v) }\n    Some(v) => { second(v) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let classify = match (findValue(proto.entry.values, "classify")) {
    Some(v) => v,
    None => fail("missing classify"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(classify)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let text = WmcMirDebug.matchMirToString(mir)

  all([
    assertTrue(String.contains("match_mir entry=b", text)),
    assertTrue(String.contains("switch_ctor", text)),
    assertTrue(String.contains("test(ctor root == Some)", text)),
    assertTrue(String.contains("bind v <- root.Some[0]", text)),
    assertTrue(String.contains("guard(expr)", text)),
    assertTrue(String.contains("select_expr clause#", text)),
    assertTrue(String.contains("apply(first, v)", text) || String.contains("apply(first,", text)),
  ])
})
