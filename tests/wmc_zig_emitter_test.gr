module WmcZigEmitterTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map
from "string" include String

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/mir_lower.gr" include WmcMirLower
from "../src/backend/wmc/emit_zig.gr" include WmcEmitZig
from "../src/backend/wmc/expr_inline.gr" include WmcExprInline
from "../src/backend/wmc/tcore_simplify.gr" include WmcTCoreSimplify
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/backend/wmc/tcore_norm.gr" include WmcTCoreNorm
from "../src/module/module_system.gr" include ModuleSystem

setSourceFile("./tests/wmc_zig_emitter_test.gr")

let findNormValue = (items: List<WmcTCoreNorm.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCoreNorm.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

let emitUnifiedNoArg = (
  rawModule: WmcTCore.Module,
  expr: WmcTCoreNorm.Expr,
  fnName: String,
) => {
  let inlined = WmcExprInline.inlineSimpleTopCallsInModuleExpr(rawModule, expr)
  let simplified = WmcTCoreSimplify.simplifyExpr(inlined)
  let executableExpr = match (simplified.kind) {
    WmcTCoreNorm.NELambda(param, body) when param == WmcTCoreNorm.zeroArgThunkParamName =>
      body,
    _ => simplified,
  }
  let cfg = match (WmcMirLower.lowerExprToCfgNoArg(executableExpr)) {
    Some(c) => c,
    None => fail("expected unified lowering to support expression"),
  }
  WmcEmitZig.emitUnifiedCfgNoArgSpecializedInt(
    cfg,
    options={
      functionName: fnName,
      includeSourceComments: false,
      includeBuiltinPrelude: true,
      sourceText: None,
      resultType: None,
    }
  )
}

test("Zig unified emitter outputs CFG block machine and avoids reserved-name collisions", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let reservedLocals = { let switch = 1 + 1; switch };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let reservedLocals = match (findNormValue(proto.normalizedEntry.values, "reservedLocals")) {
    Some(v) => v,
    None => fail("missing reservedLocals"),
  }
  let zig = emitUnifiedNoArg(proto.entry, reservedLocals.value, "reserved_locals_expr")

  let hasFunc = String.contains("pub fn reserved_locals_expr()", zig)
  let hasBlockMachine = String.contains("switch (__pc)", zig)
  let avoidsRawReserved = !String.contains("var switch:", zig) && !String.contains(" switch = ", zig)

  all([
    assertTrue(hasFunc),
    assertTrue(hasBlockMachine),
    assertTrue(avoidsRawReserved),
  ])
})

test("Zig unified emitter handles bool branch and integer result selection", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let choose = { if true { 1 } else { 2 } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let choose = match (findNormValue(proto.normalizedEntry.values, "choose")) {
    Some(v) => v,
    None => fail("missing choose"),
  }
  let zig = emitUnifiedNoArg(proto.entry, choose.value, "choose_expr")

  all([
    assertTrue(String.contains("pub fn choose_expr()", zig)),
    assertTrue(String.contains("if (", zig)),
    assertTrue(String.contains("return", zig)),
    assertTrue(String.contains("switch (__pc)", zig)),
  ])
})

test("Zig unified emitter lowers nested if and keeps deterministic arithmetic output", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let chooseNested = { if true { if true { 7 } else { 8 } } else { 0 } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let chooseNested = match (findNormValue(proto.normalizedEntry.values, "chooseNested")) {
    Some(v) => v,
    None => fail("missing chooseNested"),
  }
  let zig = emitUnifiedNoArg(proto.entry, chooseNested.value, "choose_nested_expr")

  all([
    assertTrue(String.contains("pub fn choose_nested_expr()", zig)),
    assertTrue(String.contains(" = 7;", zig) || String.contains("return 7;", zig)),
    assertTrue(String.contains("switch (__pc)", zig)),
  ])
})

