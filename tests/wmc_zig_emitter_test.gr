test("Zig unified emitter specializes small numeric branch results to i8", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let chooseSmall = { if true { 7 } else { -8 } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let chooseSmall = match (findNormValue(proto.normalizedEntry.values, "chooseSmall")) {
    Some(v) => v,
    None => fail("missing chooseSmall"),
  }
  let zig = emitUnifiedNoArg(proto.entry, chooseSmall.value, "choose_small_expr")

  all([
    assertTrue(String.contains("pub fn choose_small_expr() i8", zig)),
    assertTrue(String.contains(": i8 = 0;", zig)),
