test("Zig emitter executable subset specializes small numeric results to i8", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let chooseSmall = (x) => {\n  match(x) {\n    true => { 7 }\n    false => { -8 }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let chooseSmall = match (findValue(proto.entry.values, "chooseSmall")) {
    Some(v) => v,
    None => fail("missing chooseSmall"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(chooseSmall)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let zig = WmcEmitZig.emitMatchMirBoolToSpecializedInt(
    mir,
    options={ functionName: "choose_small_bool", includeSourceComments: false }
  )

  all([
    assertTrue(String.contains("pub fn choose_small_bool(__scrutinee: bool) i8", zig)),
    assertTrue(String.contains("var __result: i8 = 0;", zig)),
  ])
})

test("Zig emitter executable subset emits integer arithmetic from intAdd body", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let sumViaIf = if true { 1 + 1 } else { 0 };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let sumViaIf = match (findValue(proto.entry.values, "sumViaIf")) {
    Some(v) => v,
    None => fail("missing sumViaIf"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(sumViaIf)) {
    [m, ..._] => m,
    [] => fail("expected at least one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let zig = WmcEmitZig.emitMatchMirBoolToI64(
    mir,
    options={ functionName: "sum_via_if_bool", includeSourceComments: false }
  )

  all([
    assertTrue(String.contains("__result = (1 + 1);", zig)),
    assertTrue(!String.contains("unsupported body expr in executable subset", zig)),
  ])
})

test("Zig emitter direct expr subset handles local let-bound arithmetic", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let localLet = { let y = 1 + 1; y };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let localLet = match (findNormValue(proto.normalizedEntry.values, "localLet")) {
    Some(v) => v,
    None => fail("missing localLet"),
  }
  let bodyExpr = WmcMirLower.lowerExpr(localLet.value)
  let zig = match (
    WmcEmitZig.emitBodyExprNoArgSpecializedInt(
      bodyExpr,
      options={ functionName: "local_let_expr", includeSourceComments: false }
    )
  ) {
    Some(z) => z,
    None => fail("expected direct expr emitter to support local let arithmetic"),
  }

  all([
    assertTrue(String.contains("pub fn local_let_expr()", zig)),
    assertTrue(String.contains("return (1 + 1);", zig) || String.contains("return 2;", zig)),
  ])
})

test("Zig emitter direct expr subset handles immediate lambda call via let normalization", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let lambdaCall = { ((x) => { x + 1 })(1) };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let lambdaCall = match (findNormValue(proto.normalizedEntry.values, "lambdaCall")) {
    Some(v) => v,
    None => fail("missing lambdaCall"),
  }
  let bodyExpr = WmcMirLower.lowerExpr(lambdaCall.value)
  let zig = match (
    WmcEmitZig.emitBodyExprNoArgSpecializedInt(
      bodyExpr,
      options={ functionName: "lambda_call_expr", includeSourceComments: false }
    )
  ) {
    Some(z) => z,
    None => fail("expected direct expr emitter to support immediate lambda call"),
  }

  all([
    assertTrue(String.contains("pub fn lambda_call_expr()", zig)),
    assertTrue(String.contains("return ((1) + 1);", zig) || String.contains("return (1 + 1);", zig)),
  ])
})

test("Zig emitter direct expr subset handles top-level simple function call via inlining", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let inc = (x) => { x + 1 };\nlet topCall = { inc(1) };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let topCall = match (findNormValue(proto.normalizedEntry.values, "topCall")) {
    Some(v) => v,
    None => fail("missing topCall"),
  }
  let inlined = WmcExprInline.inlineSimpleTopCallsInModuleExpr(proto.entry, topCall.value)
  let simplified = WmcTCoreSimplify.simplifyExpr(inlined)
  let bodyExpr = WmcMirLower.lowerExpr(simplified)
  let zig = match (
    WmcEmitZig.emitBodyExprNoArgSpecializedInt(
      bodyExpr,
      options={ functionName: "top_call_expr", includeSourceComments: false }
    )
  ) {
    Some(z) => z,
    None => fail("expected direct expr emitter to support top-level simple function call"),
  }

  all([
    assertTrue(String.contains("pub fn top_call_expr()", zig)),
    assertTrue(String.contains("return (1 + 1);", zig)),
  ])
})

test("Zig emitter direct expr subset handles local lambda let-call via inlining", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let localFnCall = { let f = (x) => { x + 2 }; f(3) };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let localFnCall = match (findNormValue(proto.normalizedEntry.values, "localFnCall")) {
    Some(v) => v,
    None => fail("missing localFnCall"),
  }
  let inlined = WmcExprInline.inlineSimpleTopCallsInModuleExpr(proto.entry, localFnCall.value)
  let simplified = WmcTCoreSimplify.simplifyExpr(inlined)
  let bodyExpr = WmcMirLower.lowerExpr(simplified)
  let zig = match (
    WmcEmitZig.emitBodyExprNoArgSpecializedInt(
      bodyExpr,
      options={ functionName: "local_fn_call_expr", includeSourceComments: false }
    )
  ) {
    Some(z) => z,
    None => fail("expected direct expr emitter to support local lambda let-call"),
  }

  all([
    assertTrue(String.contains("pub fn local_fn_call_expr()", zig)),
    assertTrue(String.contains("return (3 + 2);", zig)),
  ])
})
