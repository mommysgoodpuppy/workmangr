module WmcZigEmitterTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map
from "string" include String

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/match_lower.gr" include WmcMatchLower
from "../src/backend/wmc/mir_lower.gr" include WmcMirLower
from "../src/backend/wmc/emit_zig.gr" include WmcEmitZig
from "../src/backend/wmc/expr_inline.gr" include WmcExprInline
from "../src/backend/wmc/tcore_simplify.gr" include WmcTCoreSimplify
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/backend/wmc/tcore_norm.gr" include WmcTCoreNorm
from "../src/module/module_system.gr" include ModuleSystem

setSourceFile("./tests/wmc_zig_emitter_test.gr")

let findValue = (items: List<WmcTCore.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCore.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

let findNormValue = (items: List<WmcTCoreNorm.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCoreNorm.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

test("Zig emitter allocates collision-safe bind names and emits source comments", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let classify = (x) => {\n  match(x) {\n    Some(Var(switch)) => { first(switch) }\n    Some(Var(switch)) => { second(switch) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let classify = match (findValue(proto.entry.values, "classify")) {
    Some(v) => v,
    None => fail("missing classify"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(classify)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let zig = WmcEmitZig.emitMatchMir(
    mir,
    options={ functionName: "__wm_match_classify", includeSourceComments: true }
  )

  let hasSourceComment = String.contains("// wm:", zig)
  let hasSafeBind = String.contains("const __bind_switch", zig)
  let avoidsRawReservedConst = !String.contains("const switch =", zig)
  let hasBlockMachine = String.contains("switch (__pc)", zig)
  let hasSelectExpr = String.contains("select_expr clause#", zig)

  all([
    assertTrue(hasSourceComment),
    assertTrue(hasSafeBind),
    assertTrue(avoidsRawReservedConst),
    assertTrue(hasBlockMachine),
    assertTrue(hasSelectExpr),
  ])
})

test("Zig emitter executable subset emits bool test and i64 result selection", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let choose = (x) => {\n  match(x) {\n    true => { 1 }\n    false => { 2 }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let choose = match (findValue(proto.entry.values, "choose")) {
    Some(v) => v,
    None => fail("missing choose"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(choose)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let zig = WmcEmitZig.emitMatchMirBoolToI64(
    mir,
    options={ functionName: "choose_bool", includeSourceComments: false }
  )

  all([
    assertTrue(String.contains("pub fn choose_bool(__scrutinee: bool) i64", zig)),
    assertTrue(String.contains("if (__scrutinee == true)", zig)),
    assertTrue(String.contains("__result = 1;", zig) || String.contains("__result = 2;", zig)),
    assertTrue(!String.contains("// TODO: emit actual test", zig)),
  ])
})

test("Zig emitter executable subset constant-folds nested bool match body", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let chooseNested = (x) => {\n  match(x) {\n    true => { if true { 7 } else { 8 } }\n    false => { 0 }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let chooseNested = match (findValue(proto.entry.values, "chooseNested")) {
    Some(v) => v,
    None => fail("missing chooseNested"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(chooseNested)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let zig = WmcEmitZig.emitMatchMirBoolToI64(
    mir,
    options={ functionName: "choose_nested_bool", includeSourceComments: false }
  )

  all([
    assertTrue(String.contains("pub fn choose_nested_bool(__scrutinee: bool) i64", zig)),
    assertTrue(String.contains("__result = 7;", zig)),
    assertTrue(!String.contains("unsupported body expr in executable subset", zig)),
  ])
})

