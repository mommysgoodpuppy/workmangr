})

test("Zig unified emitter emits integer arithmetic from normalized if body", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let sumViaIf = if true { 1 + 1 } else { 0 };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let sumViaIf = match (findNormValue(proto.normalizedEntry.values, "sumViaIf")) {
    Some(v) => v,
    None => fail("missing sumViaIf"),
  }
  let zig = emitUnifiedNoArg(proto.entry, sumViaIf.value, "sum_via_if_expr")

  all([
    assertTrue(String.contains("pub fn sum_via_if_expr()", zig)),
    assertTrue(String.contains("(1 + 1)", zig)),
    assertTrue(String.contains("switch (__pc)", zig)),
  ])
})

test("Zig emitter unified no-arg subset handles local let-bound arithmetic", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let localLet = { let y = 1 + 1; y };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let localLet = match (findNormValue(proto.normalizedEntry.values, "localLet")) {
    Some(v) => v,
    None => fail("missing localLet"),
  }
  let zig = emitUnifiedNoArg(proto.entry, localLet.value, "local_let_expr")

  all([
    assertTrue(String.contains("pub fn local_let_expr()", zig)),
    assertTrue(String.contains("return (1 + 1);", zig) || String.contains("return 2;", zig)),
  ])
})

test("Zig emitter unified no-arg subset handles immediate lambda call via let normalization", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let lambdaCall = { ((x) => { x + 1 })(1) };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let lambdaCall = match (findNormValue(proto.normalizedEntry.values, "lambdaCall")) {
    Some(v) => v,
    None => fail("missing lambdaCall"),
  }
  let zig = emitUnifiedNoArg(proto.entry, lambdaCall.value, "lambda_call_expr")

  all([
    assertTrue(String.contains("pub fn lambda_call_expr()", zig)),
    assertTrue(String.contains("return ((1) + 1);", zig) || String.contains("return (1 + 1);", zig)),
  ])
})

test("Zig emitter unified no-arg subset handles top-level simple function call via inlining", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let inc = (x) => { x + 1 };\nlet topCall = { inc(1) };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
