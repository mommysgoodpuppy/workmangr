module WmcMirTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/match_lower.gr" include WmcMatchLower
from "../src/backend/wmc/mir.gr" include WmcMir
from "../src/backend/wmc/mir_lower.gr" include WmcMirLower
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/module/module_system.gr" include ModuleSystem

setSourceFile("./tests/wmc_mir_test.gr")

let findValue = (items: List<WmcTCore.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCore.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

let rec hasSwitchCtor = (blocks: List<WmcMir.Block>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] =>
      match (block.term) {
        WmcMir.SwitchConstructor(_, _) => true,
        _ => hasSwitchCtor(tail),
      },
  }

let rec hasGuard = (blocks: List<WmcMir.Block>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] =>
      match (block.term) {
        WmcMir.Guard(_, _, _) => true,
        _ => hasGuard(tail),
      },
  }

let rec hasSelectClause = (blocks: List<WmcMir.Block>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] =>
      match (block.term) {
        WmcMir.SelectClause(_) => true,
        WmcMir.SelectExpr(_, _) => true,
        _ => hasSelectClause(tail),
      },
  }

let rec hasSelectExpr = (blocks: List<WmcMir.Block>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] =>
      match (block.term) {
        WmcMir.SelectExpr(_, _) => true,
        _ => hasSelectExpr(tail),
      },
  }

let rec hasBindInstr = (blocks: List<WmcMir.Block>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] => {
      let thisBlockHas = match (block.instrs) {
        [WmcMir.Bind(_), ..._] => true,
        _ => false,
      }
      thisBlockHas || hasBindInstr(tail)
    },
  }

let rec bodyExprHasNestedMatch = (expr: WmcMir.BodyExpr) =>
  match (expr) {
    WmcMir.BELit(_) => false,
    WmcMir.BEIdent(_) => false,
    WmcMir.BEApply(callee, arg) => bodyExprHasNestedMatch(callee) || bodyExprHasNestedMatch(arg),
    WmcMir.BELet(_, valueExpr, bodyExpr) =>
      bodyExprHasNestedMatch(valueExpr) || bodyExprHasNestedMatch(bodyExpr),
    WmcMir.BETuple(items) => List.some(bodyExprHasNestedMatch, items),
    WmcMir.BEMatch(_) => true,
    WmcMir.BEUnknown(_) => false,
  }

let rec hasNestedMatchBody = (blocks: List<WmcMir.Block>) =>
  match (blocks) {
    [] => false,
    [block, ...tail] =>
      match (block.term) {
        WmcMir.SelectExpr(_, bodyExpr) => bodyExprHasNestedMatch(bodyExpr) || hasNestedMatchBody(tail),
        _ => hasNestedMatchBody(tail),
      },
  }

test("MIR lowering builds CFG blocks for constructor match with guard", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let classify = (x) => {\n  match(x) {\n    Some(v) when cond(v) => { first(v) }\n    Some(v) => { second(v) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let classify = match (findValue(proto.entry.values, "classify")) {
    Some(v) => v,
    None => fail("missing classify"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(classify)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)
  let entryBlock = match (WmcMir.findBlock(mir, mir.entry)) {
    Some(block) => block,
    None => fail("missing MIR entry block"),
  }

  let entryLooksLikeSwitch = match (entryBlock.term) {
    WmcMir.SwitchConstructor([( "Some", _)], _) => true,
    _ => false,
  }

  all([
    assertTrue(entryLooksLikeSwitch),
    assertTrue(List.length(mir.blocks) > 4),
    assertTrue(hasSwitchCtor(mir.blocks)),
    assertTrue(hasGuard(mir.blocks)),
    assertTrue(hasSelectClause(mir.blocks)),
    assertTrue(hasSelectExpr(mir.blocks)),
    assertTrue(hasBindInstr(mir.blocks)),
  ])
})

test("MIR body lowering preserves normalized nested match (from if)", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let classify = (x) => {\n  match(x) {\n    Some(v) => { if cond(v) { first(v) } else { second(v) } }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let classify = match (findValue(proto.entry.values, "classify")) {
    Some(v) => v,
    None => fail("missing classify"),
  }
  let lowered = match (WmcMatchLower.findMatchesInTopValue(classify)) {
    [m] => m,
    _ => fail("expected one match"),
  }
  let mir = WmcMirLower.lowerMatch(lowered)

  assertTrue(hasNestedMatchBody(mir.blocks))
})
