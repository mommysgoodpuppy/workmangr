module WmcMirTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "map" include Map
from "list" include List

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/match_lower.gr" include WmcMatchLower
from "../src/backend/wmc/mir.gr" include WmcMir
from "../src/backend/wmc/mir_lower.gr" include WmcMirLower
from "../src/backend/wmc/tcore_norm.gr" include WmcTCoreNorm
from "../src/module/module_system.gr" include ModuleSystem

setSourceFile("./tests/wmc_mir_test.gr")

let findNormValue = (items: List<WmcTCoreNorm.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCoreNorm.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

let unwrapMainThunk = (value: WmcTCoreNorm.Expr) =>
  match (value.kind) {
    WmcTCoreNorm.NELambda(param, body) when param == WmcTCoreNorm.zeroArgThunkParamName => body,
    _ => value,
  }

let rec hasBinOpAdd = (blocks: List<WmcMir.UnifiedBlock>) =>
  match (blocks) {
    [] => false,
    [b, ...tail] => {
      let rec hasAddAssign = (assigns: List<WmcMir.UnifiedAssign>) =>
        match (assigns) {
          [] => false,
          [a, ...rest] =>
            match (a.rhs) {
              WmcMir.URBinOp("+", _, _) => true,
              _ => hasAddAssign(rest),
            },
        }
      if (hasAddAssign(b.assigns)) {
        true
      } else {
        hasBinOpAdd(tail)
      }
    },
  }

let rec hasUnifiedCfgBranch = (blocks: List<WmcMir.UnifiedBlock>) =>
  match (blocks) {
    [] => false,
    [b, ...tail] =>
      match (b.term) {
        WmcMir.UTBranchBool(_, _, _) => true,
        _ => hasUnifiedCfgBranch(tail),
      },
  }

test("Unified MIR CFG lowering emits bool branch for normalized if expression", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let main = => { if true { 1 + 1 } else { 0 } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let main = match (findNormValue(proto.normalizedEntry.values, "main")) {
    Some(v) => v,
    None => fail("missing main"),
  }
  let expr = unwrapMainThunk(main.value)
  let cfg = match (WmcMirLower.lowerExprToCfgNoArg(expr)) {
    Some(c) => c,
    None => fail("expected unified lowering to succeed"),
  }

  assertTrue(hasUnifiedCfgBranch(cfg.blocks))
})

test("Unified MIR lowering supports local lambda let-call", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let main = => { let f = (x) => { x + 2 }; f(3) };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let main = match (findNormValue(proto.normalizedEntry.values, "main")) {
    Some(v) => v,
    None => fail("missing main"),
  }
  let expr = unwrapMainThunk(main.value)
  let cfg = match (WmcMirLower.lowerExprToCfgNoArg(expr)) {
    Some(c) => c,
    None => fail("expected unified lowering to succeed"),
  }

  all([
    assertTrue(List.length(cfg.blocks) > 0),
    assertTrue(hasBinOpAdd(cfg.blocks)),
  ])
})

test("Unified MIR CFG lowering creates branch/goto control-flow blocks", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let main = => { if true { 1 + 1 } else { 0 } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let main = match (findNormValue(proto.normalizedEntry.values, "main")) {
    Some(v) => v,
    None => fail("missing main"),
  }
  let expr = unwrapMainThunk(main.value)
  let cfg = match (WmcMirLower.lowerExprToCfgNoArg(expr)) {
    Some(c) => c,
    None => fail("expected unified lowering to succeed"),
  }

  all([
    assertTrue(List.length(cfg.blocks) > 0),
    assertTrue(hasUnifiedCfgBranch(cfg.blocks)),
    assertTrue(WmcMir.findUnifiedBlock(cfg, cfg.entry) != None),
  ])
})

test("Match CFG bridge lowers normalized bool match into unified CFG", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let main = => { match(true) { true => { 1 } false => { 2 } } };",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }
  let main = match (findNormValue(proto.normalizedEntry.values, "main")) {
    Some(v) => v,
    None => fail("missing main"),
  }
  let expr = unwrapMainThunk(main.value)
  let cfg = match (expr.kind) {
    WmcTCoreNorm.NEMatch(m) =>
      match (WmcMatchLower.lowerNormalizedMatchToUnifiedCfg(m)) {
        Some(c) => c,
        None => fail("expected bool match to lower to CFG"),
      },
    _ => fail("expected normalized main body to be match"),
  }

  all([
    assertTrue(List.length(cfg.blocks) > 0),
    assertTrue(hasUnifiedCfgBranch(cfg.blocks)),
    assertTrue(WmcMir.findUnifiedBlock(cfg, cfg.entry) != None),
  ])
})
