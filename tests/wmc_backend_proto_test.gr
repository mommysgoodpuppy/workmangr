module WmcBackendProtoTest

from "../submodules/graintest/lib/test.gr" include Test
use Test.*

from "list" include List
from "map" include Map
from "string" include String

from "../src/backend/wmc/driver.gr" include WmcDriver
from "../src/backend/wmc/tcore.gr" include WmcTCore
from "../src/backend/wmc/tcore_norm.gr" include WmcTCoreNorm
from "../src/module/module_system.gr" include ModuleSystem
from "../src/core/types.gr" include Types

setSourceFile("./tests/wmc_backend_proto_test.gr")

let findValue = (items: List<WmcTCore.TopValueBinding>, target: String) => {
  let rec loop = (rest: List<WmcTCore.TopValueBinding>) =>
    match (rest) {
      [] => None,
      [item, ...tail] =>
        if (item.name == target) {
          Some(item)
        } else {
          loop(tail)
        },
    }
  loop(items)
}

test("wmc backend prototype builds typed entry projection", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "export let id = (x) => { x };\nlet answer = 42;",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let idBinding = match (findValue(proto.entry.values, "id")) {
    Some(binding) => binding,
    None => fail("missing id binding in prototype"),
  }
  let answerBinding = match (findValue(proto.entry.values, "answer")) {
    Some(binding) => binding,
    None => fail("missing answer binding in prototype"),
  }

  let idTyped = match (idBinding.binding.value.node.ty) {
    Some(Types.TFun(Types.TVar(_), Types.TVar(_))) => true,
    Some(Types.TFun(_, _)) => true,
    _ => false,
  }
  let answerTyped = match (answerBinding.binding.value.node.ty) {
    Some(Types.TNumber) => true,
    _ => false,
  }
  let summary = WmcDriver.debugSummary(proto)
  let summaryMentions = String.contains("export id:", summary)
    && String.contains("answer:", summary)

  all([
    assertTrue(idBinding.exported),
    assertTrue(idTyped),
    assertTrue(answerTyped),
    assertTrue(List.length(proto.normalizationIssues) == 0),
    assertTrue(List.length(proto.normalizedEntry.values) == List.length(proto.entry.values)),
    assertTrue(summaryMentions),
  ])
})

test("wmc driver surfaces normalization issues", () => {
  let overrides = Map.make()
  Map.set(
    "entry.wm",
    "let shared = (x) => { _ => { x } };\nlet classify = (x) => {\n  match(x) {\n    shared\n    Some(v) => { first(v) }\n    _ => { fallback(x) }\n  }\n};",
    overrides
  )

  let proto = match (
    WmcDriver.inferEntryPrototype(
      "entry",
      options={ ...ModuleSystem.defaultOptions(), sourceOverrides: overrides }
    )
  ) {
    Ok(p) => p,
    Err(msg) => fail(msg),
  }

  let hasIncludeIssue = List.some((issue: WmcTCoreNorm.NormalizationIssue) =>
    match (issue.kind) {
      WmcTCoreNorm.UnsupportedMatchBundleInclude("shared") => true,
      _ => false,
    }, proto.normalizationIssues)
  let summary = WmcDriver.debugSummary(proto)

  all([
    assertTrue(hasIncludeIssue),
    assertTrue(String.contains("norm_issues=", summary)),
  ])
})
