module Infer

from "list" include List
from "map" include Map
from "array" include Array
from "string" include String
from "bytes" include Bytes
from "wasi/file" include File
from "wasi/process" include Process

from "./core_ast.gr" include CoreAst
from "./constraints.gr" include Constraints
from "./env.gr" include Env
from "./flow.gr" include Flow
from "./infection_registry.gr" include InfectionRegistry
from "./solver.gr" include Solver
from "./types.gr" include Types
from "./layer1/expr.gr" include Layer1Expr
from "./layer1/patterns.gr" include Layer1Patterns
from "./layer1/declarations.gr" include Layer1Decl
from "./layer1/bindings.gr" include Layer1Bindings
from "./layer1/top.gr" include Layer1Top

provide enum TypeMarkReason {
  TypeMismatch,
  OccursCycle,
  UnknownIdentifier,
  UnfillableHole,
  Internal,
}

provide record TypeMark {
  reason: TypeMarkReason,
  origin: Constraints.Origin,
  related: List<Constraints.Origin>,
  mark: CoreAst.Mark,
  message: String,
}

provide record HoleObservation {
  observed: Types.Type,
  origin: Constraints.Origin,
}

provide record EffectEvent {
  kind: String,
  message: String,
}

record InfectionCarrierWrap {
  domain: String,
  typeName: String,
  tailArgs: List<Types.Type>,
}

record LookupResult {
  ty: Types.Type,
  bindingId: Number,
  scopeId: Number,
  identities: Flow.DomainIdentities,
}

provide record InferState {
  nextVar: Number,
  subst: Types.Subst,
  env: Env.TypingEnv,
  flow: Flow.FlowState,
  infectionRegistry: InfectionRegistry.Registry,
  nodeTypes: Map.Map<Number, Types.Type>,
  topBindings: Map.Map<String, Types.Scheme>,
  topBindingRawTypes: Map.Map<String, Types.Type>,
  constraints: List<Constraints.Constraint>,
  matchArms: Map.Map<Number, List<Layer1Patterns.MatchArmInfo>>,
  marks: List<TypeMark>,
  marksByNode: Map.Map<Number, List<TypeMark>>,
  effectEventsByNode: Map.Map<Number, List<EffectEvent>>,
  holeObservations: Map.Map<Number, List<HoleObservation>>,
}

let inferDebugEnabled = match (Process.env()) {
  Ok(vars) => List.some((entry: String) => {
    entry == "WORKMAN_INFER_DEBUG=1" || entry == "WORKMAN_INFER_DEBUG=true"
  }, Array.toList(vars)),
  Err(_) => false,
}

let inferDebug = (message: String) => {
  if (inferDebugEnabled) {
    let _ = File.fdWrite(File.stderr, Bytes.fromString("[Infer] " ++ message ++ "\n"))
    void
  } else {
    void
  }
}

let mapSize = (m) => List.length(Map.toList(m))

let isReservedValueName = (name: String) => name == "Panic"

let reservedNameError = (name: String) =>
  "Type error: reserved identifier " ++ name ++ " cannot be declared"

let renderType = (t: Types.Type, state: InferState) =>
  Types.typeToReadableString(Types.applySubstType(state.subst, t))

let seedBuiltinValues = (env: Env.TypingEnv) => {
  let intType = Types.TNominal("Int", [])
  let boolType = Types.TBool
  let charType = Types.TChar
  let stringType = Types.TString
  let voidType = Types.TVoid
  let listIntType = Types.TNominal("List", [intType])
  let orderingType = Types.TNominal("Ordering", [])
  let tNum = Types.TVar(0)
  let binaryInt: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([intType, intType]), intType),
  }
  let binaryNumeric: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TTuple([tNum, tNum]), tNum),
  }
  let cmpNumeric: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TTuple([tNum, tNum]), boolType),
  }
  let unaryBool: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(boolType, boolType),
  }
  let cmpInt: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([intType, intType]), orderingType),
  }
  let nativeStringFromLiteral: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(stringType, stringType),
  }
  let nativeStringToList: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(stringType, listIntType),
  }
  let nativeListToString: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(listIntType, stringType),
  }
  let nativeStrFromLiteral: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(stringType, listIntType),
  }
  let nativeCharEq: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([charType, charType]), boolType),
  }
  let nativePrint: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TVar(0), voidType),
  }
  let panicValue: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(stringType, Types.TVar(0)),
  }
  let define = (name: String, scheme: Types.Scheme) => {
    Env.defineValue(env, name, scheme)
    void
  }
  Env.defineValue(env, "nativeAdd", binaryInt)
  Env.defineValue(env, "nativeSub", binaryInt)
  Env.defineValue(env, "nativeMul", binaryInt)
  Env.defineValue(env, "nativeDiv", binaryInt)
  Env.defineValue(env, "nativeCmpInt", cmpInt)
  Env.defineValue(env, "nativeStringFromLiteral", nativeStringFromLiteral)
  Env.defineValue(env, "nativeStringToList", nativeStringToList)
  Env.defineValue(env, "nativeListToString", nativeListToString)
  Env.defineValue(env, "nativeStrFromLiteral", nativeStrFromLiteral)
  Env.defineValue(env, "nativeCharEq", nativeCharEq)
  Env.defineValue(env, "nativePrint", nativePrint)
  Env.defineValue(env, "print", nativePrint)
  Env.defineValue(env, "Panic", panicValue)
  // Temporary builtin operator support until std-based operator resolution lands.
  define("+", binaryNumeric)
  define("-", binaryNumeric)
  define("*", binaryNumeric)
  define("/", binaryNumeric)
  define("%", binaryNumeric)
  define("==", cmpNumeric)
  define("!=", cmpNumeric)
  define(">", cmpNumeric)
  define("<", cmpNumeric)
  define(">=", cmpNumeric)
  define("<=", cmpNumeric)
  define("!", unaryBool)
  define("not", unaryBool)
  define("&&", {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([boolType, boolType]), boolType),
  })
  define("||", {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([boolType, boolType]), boolType),
  })
  env
}

let logState = (label: String, state: InferState, nodeId: Number=-1) => {
  inferDebug(
    label
      ++ " node="
      ++ toString(nodeId)
      ++ " env="
      ++ toString(mapSize(Env.snapshotValues(state.env)))
      ++ " subst="
      ++ toString(mapSize(state.subst))
      ++ " constraints="
      ++ toString(List.length(state.constraints))
      ++ " marks="
      ++ toString(List.length(state.marks))
      ++ " nextVar="
      ++ toString(state.nextVar)
  )
}

let makeInitialState = () => {
  let subst = Types.emptySubst()
  let env = seedBuiltinValues(Env.empty())
  let flow = Flow.emptyState()
  let infectionRegistry = InfectionRegistry.empty()
  let nodeTypes = Map.make()
  let topBindings = Map.make()
  let topBindingRawTypes = Map.make()
  {
    nextVar: 0,
    subst,
    env,
    flow,
    infectionRegistry,
    nodeTypes,
    topBindings,
    topBindingRawTypes,
    constraints: [],
    matchArms: Map.make(),
    marks: [],
    marksByNode: Map.make(),
    effectEventsByNode: Map.make(),
    holeObservations: Map.make(),
  }
}

let recordConstraint = (state: InferState, constraint: Constraints.Constraint) =>
  { ...state, constraints: [constraint, ...state.constraints] }

let originForNode = (nodeId: Number, description: String) =>
  Constraints.makeOrigin(nodeId, description)

let recordNumericConstraint = (
  state: InferState,
  numeric: Constraints.NumericConstraint,
  origin: Constraints.Origin,
) => recordConstraint(state, Constraints.Numeric(numeric, origin))

let recordNumericIs = (state: InferState, ty: Types.Type, origin: Constraints.Origin) =>
  recordNumericConstraint(state, Constraints.IsNumeric(ty), origin)

let recordNumericIntLiteral = (
  state: InferState,
  ty: Types.Type,
  value: Number,
  origin: Constraints.Origin,
) => recordNumericConstraint(state, Constraints.IntLiteral(ty, value), origin)

let addTypeMark = (
  state: InferState,
  reason: TypeMarkReason,
  origin: Constraints.Origin,
  mark: CoreAst.Mark,
  message: String,
) => {
  let recent = List.filterMap((constraint: Constraints.Constraint) =>
    match (constraint) {
      Constraints.Equality(_, _, o) => Some(o),
      Constraints.Domain(_, o) => Some(o),
      Constraints.Numeric(_, o) => Some(o),
    }, state.constraints)
  let rec take = (items: List<Constraints.Origin>, n: Number, acc: List<Constraints.Origin>) =>
    if (n <= 0) {
      List.reverse(acc)
    } else {
      match (items) {
        [] => List.reverse(acc),
        [head, ...tail] => take(tail, n - 1, [head, ...acc]),
      }
    }
  let related = take(recent, 3, [])
  let entry: TypeMark = { reason, origin, related, mark, message }
  let updatedMarks = [entry, ...state.marks]
  let updatedByNode = if (origin.nodeId >= 0) {
    let existing = match (Map.get(origin.nodeId, state.marksByNode)) {
      Some(items) => items,
      None => [],
    }
    Map.set(origin.nodeId, [entry, ...existing], state.marksByNode)
    state.marksByNode
  } else {
    state.marksByNode
  }
  { ...state, marks: updatedMarks, marksByNode: updatedByNode }
}

let addReservedNameMark = (state: InferState, node: CoreAst.Node, name: String) =>
  addTypeMark(
    state,
    TypeMismatch,
    originForNode(node.id, "reserved identifier"),
    CoreAst.Inconsistent,
    reservedNameError(name)
  )

let noteHoleObservation = (
  state: InferState,
  holeId: Number,
  observed: Types.Type,
  origin: Constraints.Origin,
) => {
  let obs: HoleObservation = {
    observed: Types.applySubstType(state.subst, observed),
    origin,
  }
  let existing = match (Map.get(holeId, state.holeObservations)) {
    Some(items) => items,
    None => [],
  }
  Map.set(holeId, [obs, ...existing], state.holeObservations)
  { ...state, holeObservations: state.holeObservations }
}

let noteEffectEvent = (
  state: InferState,
  nodeId: Number,
  kind: String,
  message: String,
) => {
  let entry: EffectEvent = { kind, message }
  let existing = match (Map.get(nodeId, state.effectEventsByNode)) {
    Some(items) => items,
    None => [],
  }
  Map.set(nodeId, [entry, ...existing], state.effectEventsByNode)
  { ...state, effectEventsByNode: state.effectEventsByNode }
}

let recordMatchArms = (fnExpr: CoreAst.FnExpr, state: InferState) => {
  let analysis = Layer1Patterns.analyzeMatchArms(fnExpr, state.env)
  let state1 = List.reduce(
    (accState: InferState, diag: Layer1Patterns.MatchAnalysisDiagnostic) =>
      addTypeMark(
        accState,
        Internal,
        originForNode(diag.nodeId, "match coverage"),
        CoreAst.PatternError,
        diag.message
      ),
    state,
    analysis.diagnostics
  )
  match (analysis.armInfos) {
    None => state1,
    Some(armInfos) => {
      Map.set(fnExpr.node.id, armInfos, state1.matchArms)
      { ...state1, matchArms: state1.matchArms }
    },
  }
}

let freshVar = (state: InferState) => {
  let id = state.nextVar
  (Types.TVar(id), { ...state, nextVar: id + 1 })
}

let apply = (state: InferState, t: Types.Type) =>
  Types.applySubstType(state.subst, t)

let collectTypeInfectionDomains = (ty: Types.Type, state: InferState) => {
  let domains = Map.make()
  let rec visit = (current: Types.Type) =>
    match (apply(state, current)) {
      Types.TNominal(name, args) => {
        List.forEach(visit, args)
        match (Env.lookupType(state.env, name)) {
          Some(typeInfo) => match (typeInfo.infection) {
            Some(domain) => {
              Map.set(domain, true, domains)
              void
            },
            None => void,
          },
          None => void,
        }
      },
      Types.TFun(argTy, resultTy) => {
        visit(argTy)
        visit(resultTy)
      },
      Types.TTuple(items) => List.forEach(visit, items),
      _ => void,
    }
  visit(ty)
  domains
}

let emitDomainLabels = (
  labels: List<String>,
  nodeId: Number,
  description: String,
  state: InferState,
) =>
  List.reduce(
    (st: InferState, label: String) =>
      recordConstraint(st, Constraints.domain(label, originForNode(nodeId, description))),
    state,
    labels
  )

let emitTypeInfectionConstraints = (
  nodeId: Number,
  description: String,
  ty: Types.Type,
  state: InferState,
) => {
  let seenDomains = collectTypeInfectionDomains(ty, state)
  emitDomainLabels(
    List.map(((domain, _): (String, Bool)) => domain, Map.toList(seenDomains)),
    nodeId,
    description ++ " domain",
    state
  )
}

let hasDomain = (domains: Map.Map<String, Bool>, label: String) =>
  match (Map.get(label, domains)) {
    Some(_) => true,
    None => false,
  }

let parseTargetIndex = (target: String) =>
  if (String.startsWith("arg", target)) {
    match (String.slice(3, target)) {
      "0" => Some(0),
      "1" => Some(1),
      "2" => Some(2),
      "3" => Some(3),
      "4" => Some(4),
      "5" => Some(5),
      "6" => Some(6),
      "7" => Some(7),
      "8" => Some(8),
      "9" => Some(9),
      _ => None,
    }
  } else {
    None
  }

let tupleItemAt = (index: Number, items: List<Types.Type>) => {
  let rec go = (i: Number, rest: List<Types.Type>) =>
    match (rest) {
      [] => None,
      [head, ...tail] =>
        if (i == 0) {
          Some(head)
        } else {
          go(i - 1, tail)
        },
    }
  go(index, items)
}

let selectTargetType = (
  target: String,
  calleeType: Types.Type,
  argType: Types.Type,
  resultType: Types.Type,
  state: InferState,
) =>
  match (target) {
    "callee" => Some(apply(state, calleeType)),
    "result" => Some(apply(state, resultType)),
    "arg" => Some(apply(state, argType)),
    _ =>
      match (parseTargetIndex(target)) {
        Some(0) => Some(apply(state, argType)),
        Some(idx) =>
          match (apply(state, argType)) {
            Types.TTuple(items) => tupleItemAt(idx, items),
            _ => None,
          },
        None => None,
      },
  }

let domainMapFromLabels = (labels: List<String>) => {
  let map = Map.make()
  List.forEach((label: String) => {
    Map.set(label, true, map)
    void
  }, labels)
  map
}

let cloneDomains = (domains: Map.Map<String, Bool>) => {
  let out = Map.make()
  List.forEach(((label, _): (String, Bool)) => {
    Map.set(label, true, out)
    void
  }, Map.toList(domains))
  out
}

let labelsFromDomains = (domains: Map.Map<String, Bool>) =>
  List.map(((label, _): (String, Bool)) => label, Map.toList(domains))

let applyDomainRemoves = (domains: Map.Map<String, Bool>, removes: List<String>) => {
  let out = cloneDomains(domains)
  List.forEach((label: String) => {
    Map.remove(label, out)
    void
  }, removes)
  out
}

let applyDomainAdds = (domains: Map.Map<String, Bool>, adds: List<String>) => {
  let out = cloneDomains(domains)
  List.forEach((label: String) => {
    Map.set(label, true, out)
    void
  }, adds)
  out
}

let sameDomainSet = (left: Map.Map<String, Bool>, right: Map.Map<String, Bool>) => {
  let leftKeys = labelsFromDomains(left)
  let rightKeys = labelsFromDomains(right)
  let leftInRight = List.every((label: String) => hasDomain(right, label), leftKeys)
  let rightInLeft = List.every((label: String) => hasDomain(left, label), rightKeys)
  leftInRight && rightInLeft
}

let containsLabel = (labels: List<String>, target: String) =>
  List.some((label: String) => label == target, labels)

let classifyInfectiousNominal = (ty: Types.Type, state: InferState) =>
  match (apply(state, ty)) {
    Types.TNominal(typeName, [valueArg, ...tailArgs]) =>
      match (Env.lookupType(state.env, typeName)) {
        Some(typeInfo) => match (typeInfo.infection) {
          Some(domain) =>
            Some((valueArg, { domain, typeName, tailArgs }: InfectionCarrierWrap)),
          None => None,
        },
        None => None,
      },
    _ => None,
  }

let isInfectiousType = (ty: Types.Type, state: InferState) =>
  match (classifyInfectiousNominal(ty, state)) {
    Some(_) => true,
    None => false,
  }

let rec normalizeArgAgainstParam = (
  paramTy: Types.Type,
  argTy: Types.Type,
  state: InferState,
) =>
  match ((apply(state, paramTy), apply(state, argTy))) {
    (expected, appliedArg) when isInfectiousType(expected, state) => (appliedArg, []),
    (_expected, appliedArg) =>
      match (classifyInfectiousNominal(appliedArg, state)) {
        Some((valueType, wrap)) => (valueType, [wrap]),
        None =>
          match (apply(state, paramTy)) {
            Types.TVar(_) => (appliedArg, []),
            Types.TTuple(expectedItems) =>
              match (appliedArg) {
                Types.TTuple(argItems) when List.length(expectedItems) == List.length(argItems) => {
                  let rec zipNormalize = (
                    expectedRest: List<Types.Type>,
                    argRest: List<Types.Type>,
                    normalizedRev: List<Types.Type>,
                    wrapsRev: List<InfectionCarrierWrap>,
                  ) =>
                    match ((expectedRest, argRest)) {
                      ([], []) => (Types.TTuple(List.reverse(normalizedRev)), List.reverse(wrapsRev)),
                      ([expectedHead, ...expectedTail], [argHead, ...argTail]) => {
                        let (normalizedHead, headWraps) = normalizeArgAgainstParam(expectedHead, argHead, state)
                        zipNormalize(
                          expectedTail,
                          argTail,
                          [normalizedHead, ...normalizedRev],
                          List.append(List.reverse(headWraps), wrapsRev)
                        )
                      },
                      _ => (Types.TTuple(argItems), []),
                    }
                  zipNormalize(expectedItems, argItems, [], [])
                },
                _ => (appliedArg, []),
              },
            _ => (appliedArg, []),
          },
      },
  }

let normalizeArgForCallee = (
  calleeTy: Types.Type,
  argTy: Types.Type,
  state: InferState,
) =>
  match (apply(state, calleeTy)) {
    Types.TFun(paramTy, _resultTy) => normalizeArgAgainstParam(paramTy, argTy, state),
    _ => (apply(state, argTy), []),
  }

let wrapsCompatible = (left: InfectionCarrierWrap, right: InfectionCarrierWrap) =>
  left.domain == right.domain
    && left.typeName == right.typeName

let chooseCarrierWrap = (
  wraps: List<InfectionCarrierWrap>,
  callNodeId: Number,
  state: InferState,
) =>
  match (wraps) {
    [] => (None, state),
    [first, ...rest] => {
      let compatible = List.every((w: InfectionCarrierWrap) => wrapsCompatible(first, w), rest)
      if (compatible) {
        (Some(first), state)
      } else {
        (
          None,
          addTypeMark(
            state,
            TypeMismatch,
            originForNode(callNodeId, "infection propagation"),
            CoreAst.Inconsistent,
            "Type error: incompatible infectious argument carriers"
          ),
        )
      }
    },
  }

let wrapResultWithCarrier = (resultTy: Types.Type, wrap: InfectionCarrierWrap, state: InferState) =>
  match (apply(state, resultTy)) {
    Types.TNominal(typeName, _args) =>
      match (Env.lookupType(state.env, typeName)) {
        Some(typeInfo) => match (typeInfo.infection) {
          Some(existingDomain) =>
            if (existingDomain == wrap.domain) {
              apply(state, resultTy)
            } else {
              Types.TNominal(wrap.typeName, [apply(state, resultTy), ...wrap.tailArgs])
            },
          None => Types.TNominal(wrap.typeName, [apply(state, resultTy), ...wrap.tailArgs]),
        },
        None => Types.TNominal(wrap.typeName, [apply(state, resultTy), ...wrap.tailArgs]),
      },
    _ => Types.TNominal(wrap.typeName, [apply(state, resultTy), ...wrap.tailArgs]),
  }

let applyOpRuleAtCall = (
  callNodeId: Number,
  opName: String,
  calleeType: Types.Type,
  argType: Types.Type,
  resultType: Types.Type,
  state: InferState,
) =>
  match (Map.get(opName, state.infectionRegistry.opRules)) {
    None => state,
    Some(opRule) => {
      let targetTypeOpt = match (opRule.target) {
        Some(target) => selectTargetType(target, calleeType, argType, resultType, state),
        None => None,
      }
      let requiresTargetTypeOpt = match (targetTypeOpt) {
        Some(ty) => Some(ty),
        None =>
          if (
            opRule.requiresExact != None
              || opRule.requiresAny != None
              || opRule.requiresNot != None
          ) {
            selectTargetType("arg0", calleeType, argType, resultType, state)
          } else {
            None
          },
      }
      let requiresDomains = match (requiresTargetTypeOpt) {
        Some(targetTy) => collectTypeInfectionDomains(targetTy, state),
        None => Map.make(),
      }
      let stateReq1 = match (opRule.requiresExact) {
        None => state,
        Some(required) =>
          if (sameDomainSet(requiresDomains, domainMapFromLabels(required))) {
            state
          } else {
            addTypeMark(
              state,
              TypeMismatch,
              originForNode(callNodeId, "op requiresExact"),
              CoreAst.Inconsistent,
              "Type error: op " ++ opRule.name ++ " requires exact infection state"
            )
          },
      }
      let stateReq2 = match (opRule.requiresAny) {
        None => stateReq1,
        Some(requiredAny) =>
          if (List.some((label: String) => hasDomain(requiresDomains, label), requiredAny)) {
            stateReq1
          } else {
            addTypeMark(
              stateReq1,
              TypeMismatch,
              originForNode(callNodeId, "op requiresAny"),
              CoreAst.Inconsistent,
              "Type error: op " ++ opRule.name ++ " requires one matching infection state"
            )
          },
      }
      let stateReq3 = match (opRule.requiresNot) {
        None => stateReq2,
        Some(forbidden) =>
          if (!List.some((label: String) => hasDomain(requiresDomains, label), forbidden)) {
            stateReq2
          } else {
            addTypeMark(
              stateReq2,
              TypeMismatch,
              originForNode(callNodeId, "op requiresNot"),
              CoreAst.Inconsistent,
              "Type error: op " ++ opRule.name ++ " forbids current infection state"
            )
          },
      }
      let state1 = match (opRule.domain) {
        Some(domain) =>
          recordConstraint(
            stateReq3,
            Constraints.domain(domain, originForNode(callNodeId, "op rule domain"))
          ),
        None => stateReq3,
      }
      let policyBaseType = match (targetTypeOpt) {
        Some(targetTy) => targetTy,
        None => Types.TTuple([argType, resultType]),
      }
      let policyDomains0 = collectTypeInfectionDomains(policyBaseType, state1)
      let policyDomains1 = match (opRule.removes) {
        Some(removes) => applyDomainRemoves(policyDomains0, removes),
        None => policyDomains0,
      }
      let policyDomains2 = match (opRule.adds) {
        Some(adds) => applyDomainAdds(policyDomains1, adds),
        None => policyDomains1,
      }
      let netAdds = match (opRule.adds) {
        None => [],
        Some(adds) =>
          match (opRule.removes) {
            None => adds,
            Some(removes) =>
              List.filter((label: String) => !containsLabel(removes, label), adds),
          },
      }
      let state2 = match (opRule.adds) {
        Some(_labels) => emitDomainLabels(netAdds, callNodeId, "op rule adds", state1),
        None => state1,
      }
      let state3 = match (opRule.callPolicy) {
        None => state2,
        Some(policyName) =>
          match (Map.get(policyName, state2.infectionRegistry.policies)) {
            None => state2,
            Some(policy) => {
              let activeDomains = policyDomains2
              let policyState1 = if (
                policy.rejectsAllDomains && Map.toList(activeDomains) != []
              ) {
                addTypeMark(
                  state2,
                  TypeMismatch,
                  originForNode(callNodeId, "op call policy"),
                  CoreAst.Inconsistent,
                  "Type error: policy " ++ policy.name ++ " rejects all infection domains"
                )
              } else {
                state2
              }
              match (policy.rejectDomains) {
                None => policyState1,
                Some(rejected) =>
                  List.reduce(
                    (st, rejectedLabel) =>
                      if (hasDomain(activeDomains, rejectedLabel)) {
                        addTypeMark(
                          st,
                          TypeMismatch,
                          originForNode(callNodeId, "op call policy"),
                          CoreAst.Inconsistent,
                          "Type error: policy "
                            ++ policy.name
                            ++ " rejects infection domain "
                            ++ rejectedLabel
                        )
                      } else {
                        st
                      },
                    policyState1,
                    rejected
                  ),
              }
            },
          },
      }
      state3
    },
  }

let isNumericBinaryOp = (name: String) =>
  name == "+" || name == "-" || name == "*" || name == "/" || name == "%"

let isNumericComparisonOp = (name: String) =>
  name == "==" || name == "!=" || name == ">" || name == "<" || name == ">=" || name == "<="

let applyNumericDomainAtCall = (
  callNodeId: Number,
  opName: String,
  argType: Types.Type,
  resultType: Types.Type,
  state: InferState,
) => {
  if (!(isNumericBinaryOp(opName) || isNumericComparisonOp(opName))) {
    state
  } else {
    let origin = originForNode(callNodeId, "numeric domain")
    let argApplied = apply(state, argType)
    let rec constrainItems = (items: List<Types.Type>, st: InferState) =>
      match (items) {
        [] => st,
        [head, ...tail] => constrainItems(tail, recordNumericIs(st, head, origin)),
      }
    let state1 = match (argApplied) {
      Types.TTuple(items) => constrainItems(items, state),
      _ => recordNumericIs(state, argApplied, origin),
    }
    if (isNumericBinaryOp(opName)) {
      recordNumericIs(state1, apply(state1, resultType), origin)
    } else {
      state1
    }
  }
}

let occurs = (varId: Number, t: Types.Type, state: InferState) => {
  let fv = Types.freeVars(apply(state, t))
  Types.containsVar(fv, varId)
}

let bindVar = (
  varId: Number,
  t: Types.Type,
  state: InferState,
  origin: Constraints.Origin,
) => {
  let tApplied = apply(state, t)
  if (tApplied == Types.TVar(varId)) {
    state
  } else if (occurs(varId, tApplied, state)) {
    addTypeMark(
      state,
      OccursCycle,
      origin,
      CoreAst.OccursCheck,
      "Type error: occurs check failed"
    )
  } else {
    Types.extendSubst(state.subst, varId, tApplied)
    state
  }
}

let findRecordFieldType = (
  fields: List<(String, Types.Type)>,
  fieldName: String,
) => {
  let rec loop = (remaining: List<(String, Types.Type)>) =>
    match (remaining) {
      [] => None,
      [(name, fieldTy), ...rest] =>
        if (name == fieldName) {
          Some(fieldTy)
        } else {
          loop(rest)
        },
    }
  loop(fields)
}

let resolveNominalRecordFields = (
  typeName: String,
  args: List<Types.Type>,
  state: InferState,
) => {
  match (Env.lookupType(state.env, typeName)) {
    Some(typeInfo) =>
      match (typeInfo.recordFields) {
        None => None,
        Some(recordFields) => {
          let paramMap = Map.make()
          let rec bindParams = (
            params: List<String>,
            values: List<Types.Type>,
          ) => match ((params, values)) {
            ([paramName, ...paramRest], [argType, ...argRest]) => {
              Map.set(paramName, argType, paramMap)
              bindParams(paramRest, argRest)
            },
            _ => void,
          }
          bindParams(typeInfo.typeParams, args)
          Some(
            List.map(
              ((fieldName, fieldTypeExpr): (CoreAst.Name, CoreAst.TypeExpr)) =>
                (fieldName.text, Layer1Expr.typeExprToType(fieldTypeExpr, paramMap)),
              recordFields
            )
          )
        },
      },
    None => None,
  }
}

record NominalRecordCandidate {
  typeName: String,
  nominalType: Types.Type,
  fields: List<(String, Types.Type)>,
}

let hasRecordField = (fields: List<(String, Types.Type)>, fieldName: String) =>
  match (findRecordFieldType(fields, fieldName)) {
    Some(_) => true,
    None => false,
  }

let inferNominalRecordContext = (
  literalNodeId: Number,
  providedFields: List<(String, Types.Type)>,
  state: InferState,
  unifyFn: (Types.Type, Types.Type, Constraints.Origin, InferState) => InferState,
) => {
  let rec buildCandidates = (
    remaining: List<(String, Env.TypeInfo)>,
    nextVar: Number,
    acc: List<NominalRecordCandidate>,
  ) =>
    match (remaining) {
      [] => (List.reverse(acc), nextVar),
      [(_name, info), ...rest] =>
        match (info.recordFields) {
          None => buildCandidates(rest, nextVar, acc),
          Some(_recordFields) => {
            let (paramTypes, _paramMap, nextVar1) = Layer1Expr.instantiateTypeParams(
              info.typeParams,
              nextVar
            )
            let nominalType = Types.TNominal(info.name, paramTypes)
            match (resolveNominalRecordFields(info.name, paramTypes, state)) {
              Some(fields) => {
                let candidate: NominalRecordCandidate = {
                  typeName: info.name,
                  nominalType,
                  fields,
                }
                buildCandidates(rest, nextVar1, [candidate, ...acc])
              },
              None => buildCandidates(rest, nextVar1, acc),
            }
          },
        },
    }
  let (allCandidates, nextVarAfterCandidates) = buildCandidates(
    Map.toList(state.env.types),
    state.nextVar,
    [],
  )
  let state1 = { ...state, nextVar: nextVarAfterCandidates }
  let rec filterByProvided = (
    candidates: List<NominalRecordCandidate>,
    acc: List<NominalRecordCandidate>,
  ) =>
    match (candidates) {
      [] => List.reverse(acc),
      [candidate, ...rest] => {
        let allKnown = List.every(
          ((fieldName, _fieldType)) => hasRecordField(candidate.fields, fieldName),
          providedFields
        )
        if (allKnown) {
          filterByProvided(rest, [candidate, ...acc])
        } else {
          filterByProvided(rest, acc)
        }
      },
    }
  let candidates = filterByProvided(allCandidates, [])
  match (candidates) {
    [] => {
      let holeTy = Types.THole(literalNodeId)
      let marked = addTypeMark(
        state1,
        TypeMismatch,
        originForNode(literalNodeId, "record literal context"),
        CoreAst.Inconsistent,
        "Type error: record literal requires nominal type context"
      )
      (holeTy, marked)
    },
    [candidate] => {
      let rec unifyProvided = (
        remaining: List<(String, Types.Type)>,
        st: InferState,
      ) =>
        match (remaining) {
          [] => st,
          [(fieldName, fieldType), ...rest] =>
            match (findRecordFieldType(candidate.fields, fieldName)) {
                  Some(expectedType) =>
                    unifyProvided(
                      rest,
                      unifyFn(
                        fieldType,
                        expectedType,
                        originForNode(literalNodeId, "record literal field"),
                        st
                  )
                ),
              None =>
                unifyProvided(
                  rest,
                  addTypeMark(
                    st,
                    TypeMismatch,
                    originForNode(literalNodeId, "record literal field"),
                    CoreAst.Inconsistent,
                    "Type error: unknown record field " ++ fieldName
                  )
                ),
            },
        }
      let st2 = unifyProvided(providedFields, state1)
      let rec markMissingFields = (
        remaining: List<(String, Types.Type)>,
        st: InferState,
      ) =>
        match (remaining) {
          [] => st,
          [(expectedName, _), ...rest] =>
            if (
              List.some(
                ((providedName, _)) => providedName == expectedName,
                providedFields
              )
            ) {
              markMissingFields(rest, st)
            } else {
              markMissingFields(
                rest,
                addTypeMark(
                  st,
                  TypeMismatch,
                  originForNode(literalNodeId, "record literal missing field"),
                  CoreAst.Inconsistent,
                  "Type error: missing record field " ++ expectedName
                )
              )
            },
        }
      let st3 = markMissingFields(candidate.fields, st2)
      (candidate.nominalType, st3)
    },
    _ => {
      let holeTy = Types.THole(literalNodeId)
      let marked = addTypeMark(
        state1,
        TypeMismatch,
        originForNode(literalNodeId, "record literal ambiguous context"),
        CoreAst.Inconsistent,
        "Type error: record literal has ambiguous nominal context"
      )
      (holeTy, marked)
    },
  }
}

let inferProjectionFromFieldContext = (
  literalNodeId: Number,
  targetType: Types.Type,
  fieldName: String,
  fieldType: Types.Type,
  state: InferState,
  unifyFn: (Types.Type, Types.Type, Constraints.Origin, InferState) => InferState,
) => {
  let rec collectCandidates = (
    remaining: List<(String, Env.TypeInfo)>,
    nextVar: Number,
    acc: List<NominalRecordCandidate>,
  ) =>
    match (remaining) {
      [] => (List.reverse(acc), nextVar),
      [(_name, info), ...rest] =>
        match (info.recordFields) {
          None => collectCandidates(rest, nextVar, acc),
          Some(_) => {
            let (paramTypes, _paramMap, nextVar1) = Layer1Expr.instantiateTypeParams(
              info.typeParams,
              nextVar
            )
            let nominalType = Types.TNominal(info.name, paramTypes)
            match (resolveNominalRecordFields(info.name, paramTypes, state)) {
              Some(fields) =>
                if (hasRecordField(fields, fieldName)) {
                  let candidate: NominalRecordCandidate = {
                    typeName: info.name,
                    nominalType,
                    fields,
                  }
                  collectCandidates(rest, nextVar1, [candidate, ...acc])
                } else {
                  collectCandidates(rest, nextVar1, acc)
                },
              None => collectCandidates(rest, nextVar1, acc),
            }
          },
        },
    }
  let (candidates, nextVar) = collectCandidates(Map.toList(state.env.types), state.nextVar, [])
  let state1 = { ...state, nextVar }
  match (candidates) {
    [candidate] =>
      match (findRecordFieldType(candidate.fields, fieldName)) {
        Some(expectedFieldType) => {
          let state2 = unifyFn(
            targetType,
            candidate.nominalType,
            originForNode(literalNodeId, "record projection target"),
            state1
          )
          unifyFn(
            fieldType,
            expectedFieldType,
            originForNode(literalNodeId, "record projection field"),
            state2
          )
        },
        None =>
          addTypeMark(
            state1,
            TypeMismatch,
            originForNode(literalNodeId, "record projection missing field"),
            CoreAst.Inconsistent,
            "Type error: unknown record field " ++ fieldName
          ),
      },
    [] =>
      addTypeMark(
        state1,
        TypeMismatch,
        originForNode(literalNodeId, "record projection"),
        CoreAst.Inconsistent,
        "Type error: projection expects a nominal record value"
      ),
    _ =>
      addTypeMark(
        state1,
        TypeMismatch,
        originForNode(literalNodeId, "record projection ambiguous"),
        CoreAst.Inconsistent,
        "Type error: record projection has ambiguous nominal context"
      ),
  }
}

let inferProjectionFromCarrierContext = (
  literalNodeId: Number,
  targetType: Types.Type,
  fieldName: String,
  fieldType: Types.Type,
  state: InferState,
  unifyFn: (Types.Type, Types.Type, Constraints.Origin, InferState) => InferState,
) =>
  match (classifyInfectiousNominal(targetType, state)) {
    Some((valueType, wrap)) =>
      match (apply(state, valueType)) {
        Types.TNominal(valueName, valueArgs) =>
          match (resolveNominalRecordFields(valueName, valueArgs, state)) {
            Some(fields) =>
              match (findRecordFieldType(fields, fieldName)) {
                Some(existingType) =>
                  unifyFn(
                    fieldType,
                    wrapResultWithCarrier(existingType, wrap, state),
                    originForNode(literalNodeId, "record projection field"),
                    state
                  ),
                None =>
                  addTypeMark(
                    state,
                    TypeMismatch,
                    originForNode(literalNodeId, "record projection missing field"),
                    CoreAst.Inconsistent,
                    "Type error: unknown record field " ++ fieldName
                  ),
              },
            None =>
              addTypeMark(
                state,
                TypeMismatch,
                originForNode(literalNodeId, "record projection nominal"),
                CoreAst.Inconsistent,
                "Type error: projection expects a nominal record value"
              ),
          },
        _ =>
          addTypeMark(
            state,
            TypeMismatch,
            originForNode(literalNodeId, "record projection nominal"),
            CoreAst.Inconsistent,
            "Type error: projection expects a nominal record value"
          ),
      },
    None =>
      addTypeMark(
        state,
        TypeMismatch,
        originForNode(literalNodeId, "record projection nominal"),
        CoreAst.Inconsistent,
        "Type error: projection expects a nominal record value"
      ),
  }

let validateRecordLiteralAgainstNominal = (
  literalNodeId: Number,
  fields: List<(String, Types.Type)>,
  expectedType: Types.Type,
  state: InferState,
  unifyFn: (Types.Type, Types.Type, Constraints.Origin, InferState) => InferState,
) =>
  match (apply(state, expectedType)) {
    Types.TNominal(typeName, typeArgs) =>
      match (resolveNominalRecordFields(typeName, typeArgs, state)) {
        Some(nominalFields) => {
          let hasProvidedField = (fieldName: String) =>
            List.some(((name, _ty)) => name == fieldName, fields)
          let rec unifyFields = (
            remaining: List<(String, Types.Type)>,
            st: InferState,
          ) =>
            match (remaining) {
              [] => st,
              [(name, litTy), ...rest] =>
                match (findRecordFieldType(nominalFields, name)) {
                  Some(nominalTy) =>
                    unifyFields(
                      rest,
                      unifyFn(
                        litTy,
                        nominalTy,
                        originForNode(literalNodeId, "record field"),
                        st
                      )
                    ),
                  None =>
                    addTypeMark(
                      st,
                      TypeMismatch,
                      originForNode(literalNodeId, "record literal field"),
                      CoreAst.Inconsistent,
                      "Type error: unknown record field " ++ name
                    ),
                },
            }
          let state1 = unifyFields(fields, state)
          let rec markMissingFields = (
            remaining: List<(String, Types.Type)>,
            st: InferState,
          ) =>
            match (remaining) {
              [] => st,
              [(name, _ty), ...rest] =>
                if (hasProvidedField(name)) {
                  markMissingFields(rest, st)
                } else {
                  let st1 = addTypeMark(
                    st,
                    TypeMismatch,
                    originForNode(literalNodeId, "record literal field"),
                    CoreAst.Inconsistent,
                    "Type error: missing record field " ++ name
                  )
                  markMissingFields(rest, st1)
                },
            }
          markMissingFields(nominalFields, state1)
        },
        None =>
          addTypeMark(
            state,
            TypeMismatch,
            originForNode(literalNodeId, "record literal annotation"),
            CoreAst.Inconsistent,
            "Type error: record literal requires nominal type context"
          ),
      },
    _ =>
      addTypeMark(
        state,
        TypeMismatch,
        originForNode(literalNodeId, "record literal annotation"),
        CoreAst.Inconsistent,
        "Type error: record literal requires nominal type context"
      ),
  }

let rec unify = (
  left: Types.Type,
  right: Types.Type,
  origin: Constraints.Origin,
  state: InferState,
) => {
  let constraint = Constraints.Equality(left, right, origin)
  let state1 = recordConstraint(state, constraint)
  let l = apply(state1, left)
  let r = apply(state1, right)

  match ((l, r)) {
    (Types.TNumber, Types.TNumber) => state1,
    (Types.TNumber, Types.TNominal(name, [])) when Types.isNumericNominalName(name) => state1,
    (Types.TNominal(name, []), Types.TNumber) when Types.isNumericNominalName(name) => state1,
    (Types.TBool, Types.TBool) => state1,
    (Types.TString, Types.TString) => state1,
    (Types.TByte, Types.TByte) => state1,
    (Types.TChar, Types.TChar) => state1,
    (Types.TVoid, Types.TVoid) => state1,
    (Types.THole(holeId), observed) =>
      noteHoleObservation(state1, holeId, observed, origin),
    (observed, Types.THole(holeId)) =>
      noteHoleObservation(state1, holeId, observed, origin),
    (Types.TVar(id), t) => bindVar(id, t, state1, origin),
    (t, Types.TVar(id)) => bindVar(id, t, state1, origin),
    (Types.TFun(a1, b1), Types.TFun(a2, b2)) => {
      let state2 = unify(a1, a2, origin, state1)
      unify(b1, b2, origin, state2)
    },
    (Types.TTuple(leftItems), Types.TTuple(rightItems)) => {
      let rec unifyTuple = (
        xs: List<Types.Type>,
        ys: List<Types.Type>,
        st: InferState,
      ) => match ((xs, ys)) {
        ([], []) => st,
        ([x, ...xRest], [y, ...yRest]) =>
          unifyTuple(xRest, yRest, unify(x, y, origin, st)),
        _ =>
          addTypeMark(
            st,
            TypeMismatch,
            origin,
            CoreAst.Inconsistent,
            "Type error: cannot unify tuple/argument arity"
          ),
      }
      unifyTuple(leftItems, rightItems, state1)
    },
    (Types.TNominal(nameL, argsL), Types.TNominal(nameR, argsR)) =>
      if (nameL == nameR) {
        match (Env.lookupType(state1.env, nameL)) {
          Some(typeInfo) =>
            match (typeInfo.infection) {
              Some(_) => {
                let rec unifyNominalArgs = (
                  xs: List<Types.Type>,
                  ys: List<Types.Type>,
                  st: InferState,
                ) => match ((xs, ys)) {
                  ([], []) => st,
                  ([x, ...xRest], [y, ...yRest]) =>
                    unifyNominalArgs(xRest, yRest, unify(x, y, origin, st)),
                  _ =>
                    addTypeMark(
                      st,
                      TypeMismatch,
                      origin,
                      CoreAst.Inconsistent,
                      "Type error: nominal arity mismatch"
                    ),
                }
                unifyNominalArgs(argsL, argsR, state1)
              },
              None => {
                let rec unifyNominalArgs = (
                  xs: List<Types.Type>,
                  ys: List<Types.Type>,
                  st: InferState,
                ) => match ((xs, ys)) {
                ([], []) => st,
                ([x, ...xRest], [y, ...yRest]) =>
                  unifyNominalArgs(xRest, yRest, unify(x, y, origin, st)),
                _ =>
                  addTypeMark(
                    st,
                    TypeMismatch,
                    origin,
                    CoreAst.Inconsistent,
                    "Type error: nominal arity mismatch"
                  ),
                }
                unifyNominalArgs(argsL, argsR, state1)
              },
            },
          None => {
            let rec unifyNominalArgs = (
              xs: List<Types.Type>,
              ys: List<Types.Type>,
              st: InferState,
            ) => match ((xs, ys)) {
            ([], []) => st,
            ([x, ...xRest], [y, ...yRest]) =>
              unifyNominalArgs(xRest, yRest, unify(x, y, origin, st)),
            _ =>
              addTypeMark(
                st,
                TypeMismatch,
                origin,
                CoreAst.Inconsistent,
                "Type error: nominal arity mismatch"
              ),
            }
            unifyNominalArgs(argsL, argsR, state1)
          },
        }
      } else {
        addTypeMark(
          state1,
          TypeMismatch,
          origin,
          CoreAst.Inconsistent,
          "Type error: cannot unify nominal types"
        )
      },
    _ =>
      addTypeMark(
        state1,
        TypeMismatch,
        origin,
        CoreAst.Inconsistent,
        "Type error (" ++ origin.description ++ "): cannot unify "
          ++ renderType(l, state1)
          ++ " with "
          ++ renderType(r, state1)
      ),
  }
}

let unifyForNode = (
  nodeId: Number,
  description: String,
  left: Types.Type,
  right: Types.Type,
  state: InferState,
) => unify(left, right, originForNode(nodeId, description), state)

let recordNodeType = (id: Number, t: Types.Type, state: InferState) => {
  let applied = apply(state, t)
  Map.set(id, applied, state.nodeTypes)
  applied
}

let handleMatchApplication = (
  fnExpr: CoreAst.FnExpr,
  argType: Types.Type,
  state: InferState,
) => {
  match (Map.get(fnExpr.node.id, state.matchArms)) {
    Some(armInfos) => match (armInfos) {
      [] => state,
      [first, ..._] => {
        match (Env.lookupType(state.env, first.typeName)) {
          None =>
            addTypeMark(
              state,
              Internal,
              originForNode(fnExpr.node.id, "match scrutinee"),
              CoreAst.Internal("unknown nominal type"),
              "Type error: unknown nominal type " ++ first.typeName
            ),
          Some(typeInfo) => {
            let (paramTypes, _paramMap, nextVar) = Layer1Expr.instantiateTypeParams(
              typeInfo.typeParams,
              state.nextVar
            )
            let state1 = { ...state, nextVar }
            let scrutineeType = Types.TNominal(typeInfo.name, paramTypes)
            unifyForNode(
              fnExpr.node.id,
              "match scrutinee",
              argType,
              scrutineeType,
              state1
            )
          },
        }
      },
    },
    None => state,
  }
}

let lookupEnv = (name: CoreAst.Name, state: InferState) => {
  match (Env.lookupValue(state.env, name.text)) {
    Some(entry) => {
      let (inst, nextVar) = Types.instantiate(entry.scheme, state.nextVar)
      let flow1 = Flow.recordExprIdentities(state.flow, name.node.id, entry.identities)
      let flow1b =
        if (entry.scopeId != state.flow.currentScopeId && entry.bindingKind != Flow.BuiltinBinding) {
          Flow.noteCapture(flow1, entry.bindingId)
        } else {
          flow1
        }
      let flow2 = List.reduce(
        (flowAcc: Flow.FlowState, domainEntry: (String, List<Number>)) => {
          let (domain, identityIds) = domainEntry
          List.reduce(
            (flowInner: Flow.FlowState, identityId: Number) =>
              Flow.recordIdentityUsage(
                flowInner,
                domain,
                identityId,
                name.node.id,
                entry.bindingId
              ),
            flowAcc,
            identityIds
          )
        },
        flow1b,
        Map.toList(entry.identities)
      )
      (
        {
          ty: Types.applySubstType(state.subst, inst),
          bindingId: entry.bindingId,
          scopeId: entry.scopeId,
          identities: entry.identities,
        }: LookupResult,
        { ...state, nextVar, flow: flow2 },
      )
    },
    None => {
      let (unknownType, state1) = freshVar(state)
      let marked = addTypeMark(
        state1,
        UnknownIdentifier,
        originForNode(name.node.id, "unknown identifier"),
        CoreAst.FreeVar(name),
        "Type error: unknown identifier " ++ name.text
      )
      (
        {
          ty: unknownType,
          bindingId: -1,
          scopeId: state.flow.currentScopeId,
          identities: Flow.emptyDomainIdentities(),
        }: LookupResult,
        marked,
      )
    },
  }
}

let lookupQualifiedProjection = (
  baseName: CoreAst.Name,
  fieldName: String,
  state: InferState,
) =>
  match (Env.lookupValue(state.env, baseName.text ++ "." ++ fieldName)) {
    Some(entry) => {
      let (inst, nextVar) = Types.instantiate(entry.scheme, state.nextVar)
      Some((
        {
          ty: Types.applySubstType(state.subst, inst),
          bindingId: entry.bindingId,
          scopeId: entry.scopeId,
          identities: entry.identities,
        }: LookupResult,
        { ...state, nextVar }
      ))
    },
    None => None,
  }

let cloneEnvValues = (values: Types.Env) => {
  let cloned = Types.emptyEnv()
  Map.forEach((name, scheme) => {
    Map.set(name, scheme, cloned)
  }, values)
  cloned
}

let typeFromAnnotation = (annotation: CoreAst.TypeExpr) =>
  Layer1Expr.typeExprToType(annotation, Map.make())

let exprIdentitiesForNode = (state: InferState, nodeId: Number) =>
  match (Map.get(nodeId, state.flow.exprIdentities)) {
    Some(identities) => identities,
    None => Flow.emptyDomainIdentities(),
  }

let withBinding = (
  name: String,
  scheme: Types.Scheme,
  bindingKind: Flow.BindingKind,
  identities: Flow.DomainIdentities,
  state: InferState,
  fn: InferState => (Types.Type, InferState),
) => {
  let previous = Env.lookupValue(state.env, name)
  let (entry, flow1) = Flow.bindScheme(
    state.flow,
    scheme,
    bindingKind,
    identities=identities
  )
  let flow2 = Flow.registerBindingInfo(
    flow1,
    entry.bindingId,
    name,
    entry.scopeId,
    entry.bindingKind
  )
  let envWithBinding = Env.defineValueEntry(state.env, name, entry)
  let stateWithBinding = { ...state, env: envWithBinding, flow: flow2 }
  let (resultType, stateAfter) = fn(stateWithBinding)
  let restoredEnv = match (previous) {
    Some(prevEntry) => Env.defineValueEntry(stateAfter.env, name, prevEntry),
    None => Env.removeValue(stateAfter.env, name),
  }
  (resultType, { ...stateAfter, env: restoredEnv })
}

let withFreshScope = (
  state: InferState,
  fn: InferState => (Types.Type, InferState),
) => {
  let (scopeId, flow1) = Flow.freshScopeId(state.flow)
  let previousScopeId = state.flow.currentScopeId
  let scopedState = { ...state, flow: Flow.setCurrentScope(flow1, scopeId) }
  let (result, stateAfter) = fn(scopedState)
  (
    result,
    { ...stateAfter, flow: Flow.setCurrentScope(stateAfter.flow, previousScopeId) }
  )
}

let rec withPatternBindingsKind = (
  pattern: CoreAst.Pattern,
  expectedType: Types.Type,
  bindingKind: Flow.BindingKind,
  state: InferState,
  fn: InferState => (Types.Type, InferState),
) => {
  let monoScheme: Types.Scheme = { quantifiers: [], ty: expectedType }
  match (pattern.kind) {
    CoreAst.Var(name) => {
      let applied = apply(state, expectedType)
      Map.set(pattern.node.id, applied, state.nodeTypes)
      Map.set(name.node.id, applied, state.nodeTypes)
      withBinding(
        name.text,
        monoScheme,
        bindingKind,
        Flow.emptyDomainIdentities(),
        state,
        st => {
          let st1 = if (bindingKind == Flow.ParamBinding) {
            match (Env.lookupValue(st.env, name.text)) {
              Some(entry) => {
                let flowNext = Flow.noteFunctionParamBinding(st.flow, entry.bindingId)
                { ...st, flow: flowNext }
              },
              None => st,
            }
          } else {
            st
          }
          fn(st1)
        }
      )
    },
    CoreAst.Pin(name) => {
      let (pinLookup, state1) = lookupEnv(name, state)
      let state2 = unifyForNode(
        pattern.node.id,
        "pinned pattern",
        expectedType,
        pinLookup.ty,
        state1
      )
      let appliedPattern = apply(state2, expectedType)
      let appliedName = apply(state2, pinLookup.ty)
      Map.set(pattern.node.id, appliedPattern, state2.nodeTypes)
      Map.set(name.node.id, appliedName, state2.nodeTypes)
      fn(state2)
    },
    CoreAst.Lit(_) => {
      let (litType, stateLit) = match (pattern.kind) {
        CoreAst.Lit(CoreAst.Int(value)) => {
          let (numericTy, st1) = freshVar(state)
          let st2 = recordNumericIntLiteral(
            st1,
            numericTy,
            value,
            originForNode(pattern.node.id, "literal pattern numeric")
          )
          (numericTy, st2)
        },
        CoreAst.Lit(CoreAst.Bool(_)) => (Types.TBool, state),
        CoreAst.Lit(CoreAst.Str(_)) => (Types.TString, state),
        CoreAst.Lit(CoreAst.Byte(_)) => (Types.TByte, state),
        CoreAst.Lit(CoreAst.Char(_)) => (Types.TChar, state),
        CoreAst.Lit(CoreAst.Unit) => (Types.TVoid, state),
        _ => (Types.TNumber, state),
      }
      let state1 = unifyForNode(
        pattern.node.id,
        "literal pattern",
        expectedType,
        litType,
        stateLit
      )
      fn(state1)
    },
    CoreAst.Tuple(items) => {
      let rec freshTupleTypes = (
        remaining: List<CoreAst.Pattern>,
        st: InferState,
        acc: List<(CoreAst.Pattern, Types.Type)>,
      ) =>
        match (remaining) {
          [] => (List.reverse(acc), st),
          [item, ...rest] => {
            let (itemType, st1) = freshVar(st)
            freshTupleTypes(rest, st1, [(item, itemType), ...acc])
          },
        }

      let (itemPairs, state1) = freshTupleTypes(items, state, [])
      let tupleType = Types.TTuple(List.map(((_item, itemType)) => itemType, itemPairs))
      let state2 = unifyForNode(
        pattern.node.id,
        "tuple pattern",
        expectedType,
        tupleType,
        state1
      )

      let rec bindTupleItems = (
        pairs: List<(CoreAst.Pattern, Types.Type)>,
        st: InferState,
      ) =>
        match (pairs) {
          [] => fn(st),
          [(itemPattern, itemType), ...rest] =>
            withPatternBindingsKind(
              itemPattern,
              itemType,
              bindingKind,
              st,
              stNext => bindTupleItems(rest, stNext)
            ),
        }

      bindTupleItems(itemPairs, state2)
    },
    CoreAst.Constructor(name, items) => {
      let (ctorLookup, state1) = lookupEnv(name, state)
      let ctorType = ctorLookup.ty
      let (ctorArgs, ctorResult) = Layer1Patterns.flattenFunctionType(ctorType)
      let state2 = unifyForNode(
        pattern.node.id,
        "constructor pattern",
        expectedType,
        ctorResult,
        state1
      )

      let baseItemTypes = match ((ctorArgs, items)) {
        ([], []) => [],
        ([only], _) when List.length(items) > 1 => match (apply(state2, only)) {
          Types.TTuple(tupleItems) when List.length(tupleItems) == List.length(items) =>
            tupleItems,
          _ => [only],
        },
        _ => ctorArgs,
      }

      let arityMessage =
        "Constructor pattern arity mismatch for "
          ++ name.text
          ++ " (expected "
          ++ toString(List.length(baseItemTypes))
          ++ ", got "
          ++ toString(List.length(items))
          ++ ")"

      let rec freshTypes = (
        remaining: List<CoreAst.Pattern>,
        st: InferState,
        acc: List<Types.Type>,
      ) =>
        match (remaining) {
          [] => (List.reverse(acc), st),
          [_item, ...rest] => {
            let (ty, st1) = freshVar(st)
            freshTypes(rest, st1, [ty, ...acc])
          },
        }

      let (itemTypes, state3) = if (
        List.length(baseItemTypes) == List.length(items)
      ) {
        (baseItemTypes, state2)
      } else {
        let marked = addTypeMark(
          state2,
          TypeMismatch,
          originForNode(pattern.node.id, "constructor pattern arity"),
          CoreAst.PatternError,
          arityMessage
        )
        freshTypes(items, marked, [])
      }

      let rec zip = (
        pats: List<CoreAst.Pattern>,
        tys: List<Types.Type>,
        acc: List<(CoreAst.Pattern, Types.Type)>,
      ) => match ((pats, tys)) {
        ([], []) => List.reverse(acc),
        ([pat, ...patRest], [ty, ...tyRest]) =>
          zip(patRest, tyRest, [(pat, ty), ...acc]),
        _ => [],
      }

      let itemPairs = zip(items, itemTypes, [])

      let rec bindItems = (
        pairs: List<(CoreAst.Pattern, Types.Type)>,
        st: InferState,
      ) => match (pairs) {
        [] => fn(st),
        [(itemPattern, itemType), ...rest] =>
          withPatternBindingsKind(
            itemPattern,
            itemType,
            bindingKind,
            st,
            stNext => bindItems(rest, stNext)
          ),
      }

      bindItems(itemPairs, state3)
    },
    _ => fn(state),
  }
}

let collectNumericConstraintVars = (state: InferState) => {
  let seen: Map.Map<Number, Bool> = Map.make()
  let addTypeVars = (ty: Types.Type) =>
    List.forEach((id: Number) => {
      Map.set(id, true, seen)
      void
    }, Types.freeVars(Types.applySubstType(state.subst, ty)))
  List.forEach((constraint: Constraints.Constraint) => {
    match (constraint) {
      Constraints.Numeric(spec, _origin) =>
        match (spec) {
          Constraints.IsNumeric(ty) => addTypeVars(ty),
          Constraints.IntLiteral(ty, _value) => addTypeVars(ty),
        },
      _ => void,
    }
  }, state.constraints)
  seen
}

let normalizeNumericTypeForGeneralize = (ty: Types.Type, state: InferState) => {
  let numericVars = collectNumericConstraintVars(state)
  let rec rewrite = (current: Types.Type) =>
    match (Types.applySubstType(state.subst, current)) {
      Types.TVar(id) =>
        if (Map.get(id, numericVars) != None) {
          Types.TNumber
        } else {
          Types.TVar(id)
        },
      Types.TFun(a, b) => Types.TFun(rewrite(a), rewrite(b)),
      Types.TTuple(items) => Types.TTuple(List.map(rewrite, items)),
      Types.TNominal(name, args) => Types.TNominal(name, List.map(rewrite, args)),
      other => other,
    }
  rewrite(ty)
}

let functionCallMode = (clauses: List<CoreAst.FnClause>) =>
  match (clauses) {
    [
      {
        param: { kind: CoreAst.Lit(CoreAst.Unit), _ },
        _,
      },
    ] => Flow.UnitThunk,
    _ => Flow.UnaryValue,
  }

let normalizeNumericTypeWithVarSet = (
  ty: Types.Type,
  subst: Types.Subst,
  numericVars: Map.Map<Number, Bool>,
) => {
  let rec rewrite = (current: Types.Type) =>
    match (Types.applySubstType(subst, current)) {
      Types.TVar(id) =>
        if (Map.get(id, numericVars) != None) {
          Types.TNumber
        } else {
          Types.TVar(id)
        },
      Types.TFun(a, b) => Types.TFun(rewrite(a), rewrite(b)),
      Types.TTuple(items) => Types.TTuple(List.map(rewrite, items)),
      Types.TNominal(name, args) => Types.TNominal(name, List.map(rewrite, args)),
      other => other,
    }
  rewrite(ty)
}

let rec inferExpr = (expr: CoreAst.Expr, state: InferState) => {
  match (expr.kind) {
    CoreAst.Mark(_, inner) => inferExpr(inner, state),
    CoreAst.Lit(CoreAst.Int(value)) => {
      let (numericTy, state1) = freshVar(state)
      let state2 = recordNumericIntLiteral(
        state1,
        numericTy,
        value,
        originForNode(expr.node.id, "integer literal")
      )
      let t = recordNodeType(expr.node.id, numericTy, state2)
      (t, state2)
    },
    CoreAst.Lit(CoreAst.Bool(_)) => {
      let t = recordNodeType(expr.node.id, Types.TBool, state)
      (t, state)
    },
    CoreAst.Lit(CoreAst.Str(_)) => {
      let t = recordNodeType(expr.node.id, Types.TString, state)
      (t, state)
    },
    CoreAst.Lit(CoreAst.Byte(_)) => {
      let t = recordNodeType(expr.node.id, Types.TByte, state)
      (t, state)
    },
    CoreAst.Lit(CoreAst.Char(_)) => {
      let t = recordNodeType(expr.node.id, Types.TChar, state)
      (t, state)
    },
    CoreAst.Lit(CoreAst.Unit) => {
      let t = recordNodeType(expr.node.id, Types.TVoid, state)
      (t, state)
    },
    CoreAst.Ident(name) => {
      let (lookup, state1) = lookupEnv(name, state)
      let flow1 = Flow.recordExprIdentities(state1.flow, expr.node.id, lookup.identities)
      let state2 = { ...state1, flow: flow1 }
      let tRecorded = recordNodeType(expr.node.id, lookup.ty, state2)
      (tRecorded, state2)
    },
    CoreAst.Annotate(valueExpr, annotation) => {
      let (valueType, state1) = inferExpr(valueExpr, state)
      let annotationType = typeFromAnnotation(annotation)
      let state2 = unifyForNode(
        expr.node.id,
        "expression annotation",
        valueType,
        annotationType,
        state1
      )
      let annotatedType = apply(state2, annotationType)
      let tRecorded = recordNodeType(expr.node.id, annotatedType, state2)
      (tRecorded, state2)
    },
    CoreAst.Hole(_) => {
      let t = Types.THole(expr.node.id)
      let state1 = state
      let tRecorded = recordNodeType(expr.node.id, t, state1)
      (tRecorded, state1)
    },
    CoreAst.Fn(fnExpr) => {
      let stateWithMatch = recordMatchArms(fnExpr, state)
      let clauses = List.filterMap(
        (item: CoreAst.FnItem) => match (item.kind) {
          CoreAst.Clause(clause) => Some(clause),
          _ => None,
        },
        fnExpr.items
      )
      let stateFn = if (clauses == []) {
        addTypeMark(
          stateWithMatch,
          Internal,
          originForNode(expr.node.id, "function clauses"),
          CoreAst.Internal("empty function clauses"),
          "Type error: empty function clauses"
        )
      } else {
        stateWithMatch
      }
      let (paramType, state1) = freshVar(stateFn)
      let (resultType, state2) = freshVar(state1)
      let callMode = functionCallMode(clauses)
      let (_ignoredType, stFn) = withFreshScope(
        state2,
        scopedState => {
          let currentScopeId = scopedState.flow.currentScopeId
          let (_fnId, scopedState1) = {
            let (_newFnId, nextFlow) = Flow.beginFunction(
              scopedState.flow,
              expr.node.id,
              currentScopeId,
              callMode
            )
            (_newFnId, { ...scopedState, flow: nextFlow })
          }
          let rec inferClauses = (remaining: List<CoreAst.FnClause>, st: InferState) =>
            match (remaining) {
              [] => st,
              [clause, ...rest] => {
                let (_ignoredType, nextState) = withPatternBindingsKind(
                  clause.param,
                  paramType,
                  Flow.ParamBinding,
                  st,
                  st1 => {
                    let st2 = match (clause.guard) {
                      Some(guardExpr) => {
                        let (guardType, stGuard) = inferExpr(guardExpr, st1)
                        unifyForNode(
                          clause.node.id,
                          "function clause guard",
                          guardType,
                          Types.TBool,
                          stGuard
                        )
                      },
                    None => st1,
                  }
                  let (bodyType, st3) = inferExpr(clause.body, st2)
                    let st4 = unifyForNode(
                      clause.node.id,
                      "function clause result",
                      bodyType,
                      resultType,
                      st3
                    )
                    let nextState = inferClauses(rest, st4)
                    (apply(nextState, resultType), nextState)
                  }
                )
                nextState
              },
            }
          let nextState = inferClauses(clauses, scopedState1)
          let flowFinal = Flow.endFunction(nextState.flow)
          let finalState = { ...nextState, flow: flowFinal }
          (apply(finalState, resultType), finalState)
        }
      )
      let fnType = Types.TFun(apply(stFn, paramType), apply(stFn, resultType))
      let tRecorded = recordNodeType(expr.node.id, fnType, stFn)
      (tRecorded, stFn)
    },
    CoreAst.Apply(callee, arg) => {
      match ((callee.kind, arg.kind)) {
        (CoreAst.Apply(innerCallee, targetExpr), _) =>
          match (innerCallee.kind) {
            CoreAst.Ident(fnName) when fnName.text == "project" =>
              match (arg.kind) {
                CoreAst.Lit(CoreAst.Str(fieldName)) => {
                  match (targetExpr.kind) {
                    CoreAst.Ident(baseName) =>
                      match (lookupQualifiedProjection(baseName, fieldName, state)) {
                        Some((qualifiedLookup, state1)) => {
                          let tRecorded = recordNodeType(expr.node.id, qualifiedLookup.ty, state1)
                          (tRecorded, state1)
                        },
                        None => {
                          let (targetType, state1) = inferExpr(targetExpr, state)
                          let (fieldType, state2) = freshVar(state1)
                          let state3 = match (apply(state2, targetType)) {
                            Types.TNominal(typeName, typeArgs) =>
                              match (resolveNominalRecordFields(typeName, typeArgs, state2)) {
                                Some(fields) =>
                                  match (findRecordFieldType(fields, fieldName)) {
                                    Some(existingType) =>
                                      unifyForNode(
                                        expr.node.id,
                                        "record projection field",
                                        fieldType,
                                        existingType,
                                        state2
                                      ),
                                    None =>
                                      addTypeMark(
                                        state2,
                                        TypeMismatch,
                                        originForNode(expr.node.id, "record projection missing field"),
                                        CoreAst.Inconsistent,
                                        "Type error: unknown record field " ++ fieldName
                                      ),
                                  },
                                None =>
                                  inferProjectionFromCarrierContext(
                                    expr.node.id,
                                    targetType,
                                    fieldName,
                                    fieldType,
                                    state2,
                                    unify
                                  ),
                              },
                            Types.TVar(_) => inferProjectionFromFieldContext(
                              expr.node.id,
                              targetType,
                              fieldName,
                              fieldType,
                              state2,
                              unify
                            ),
                            Types.THole(_) => inferProjectionFromFieldContext(
                              expr.node.id,
                              targetType,
                              fieldName,
                              fieldType,
                              state2,
                              unify
                            ),
                            _ =>
                              addTypeMark(
                                state2,
                                TypeMismatch,
                                originForNode(expr.node.id, "record projection"),
                                CoreAst.Inconsistent,
                                "Type error: projection expects a nominal record value"
                              ),
                          }
                          let resolved = apply(state3, fieldType)
                          let tRecorded = recordNodeType(expr.node.id, resolved, state3)
                          (tRecorded, state3)
                        },
                      },
                    _ => {
                      let (targetType, state1) = inferExpr(targetExpr, state)
                      let (fieldType, state2) = freshVar(state1)
                      let state3 = match (apply(state2, targetType)) {
                        Types.TNominal(typeName, typeArgs) =>
                          match (resolveNominalRecordFields(typeName, typeArgs, state2)) {
                            Some(fields) =>
                              match (findRecordFieldType(fields, fieldName)) {
                                Some(existingType) =>
                                  unifyForNode(
                                    expr.node.id,
                                    "record projection field",
                                    fieldType,
                                    existingType,
                                    state2
                                  ),
                                None =>
                                  addTypeMark(
                                    state2,
                                    TypeMismatch,
                                    originForNode(expr.node.id, "record projection missing field"),
                                    CoreAst.Inconsistent,
                                    "Type error: unknown record field " ++ fieldName
                                  ),
                              },
                            None =>
                              inferProjectionFromCarrierContext(
                                expr.node.id,
                                targetType,
                                fieldName,
                                fieldType,
                                state2,
                                unify
                              ),
                          },
                        Types.TVar(_) => inferProjectionFromFieldContext(
                          expr.node.id,
                          targetType,
                          fieldName,
                          fieldType,
                          state2,
                          unify
                        ),
                        Types.THole(_) => inferProjectionFromFieldContext(
                          expr.node.id,
                          targetType,
                          fieldName,
                          fieldType,
                          state2,
                          unify
                        ),
                        _ =>
                          addTypeMark(
                            state2,
                            TypeMismatch,
                            originForNode(expr.node.id, "record projection"),
                            CoreAst.Inconsistent,
                            "Type error: projection expects a nominal record value"
                          ),
                      }
                      let resolved = apply(state3, fieldType)
                      let tRecorded = recordNodeType(expr.node.id, resolved, state3)
                      (tRecorded, state3)
                    },
                  }
                },
                _ => {
                  let (tUnknown, state1) = freshVar(state)
                  let state2 = addTypeMark(
                    state1,
                    TypeMismatch,
                    originForNode(expr.node.id, "record projection field"),
                    CoreAst.Inconsistent,
                    "Type error: record projection expects string field name"
                  )
                  let tRecorded = recordNodeType(expr.node.id, tUnknown, state2)
                  (tRecorded, state2)
                },
              },
            _ => {
              inferFunctionApplication(expr.node.id, callee, arg, state)
            },
          },
        (CoreAst.Ident(fnName), CoreAst.Tuple([targetExpr, fieldExpr])) when fnName.text == "project" =>
          match (fieldExpr.kind) {
            CoreAst.Lit(CoreAst.Str(fieldName)) => {
              match (targetExpr.kind) {
                CoreAst.Ident(baseName) =>
                  match (lookupQualifiedProjection(baseName, fieldName, state)) {
                    Some((qualifiedLookup, state1)) => {
                      let tRecorded = recordNodeType(expr.node.id, qualifiedLookup.ty, state1)
                      (tRecorded, state1)
                    },
                    None => {
                      let (targetType, state1) = inferExpr(targetExpr, state)
                      let (fieldType, state2) = freshVar(state1)
                      let state3 = match (apply(state2, targetType)) {
                        Types.TNominal(typeName, typeArgs) =>
                          match (resolveNominalRecordFields(typeName, typeArgs, state2)) {
                            Some(fields) =>
                              match (findRecordFieldType(fields, fieldName)) {
                                Some(existingType) =>
                                  unifyForNode(
                                    expr.node.id,
                                    "record projection field",
                                    fieldType,
                                    existingType,
                                    state2
                                  ),
                                None =>
                                  addTypeMark(
                                    state2,
                                    TypeMismatch,
                                    originForNode(expr.node.id, "record projection missing field"),
                                    CoreAst.Inconsistent,
                                    "Type error: unknown record field " ++ fieldName
                                  ),
                              },
                            None =>
                              addTypeMark(
                                state2,
                                TypeMismatch,
                                originForNode(expr.node.id, "record projection nominal"),
                                CoreAst.Inconsistent,
                                "Type error: projection expects a nominal record value"
                              ),
                          },
                        Types.TVar(_) => inferProjectionFromFieldContext(
                          expr.node.id,
                          targetType,
                          fieldName,
                          fieldType,
                          state2,
                          unify
                        ),
                        Types.THole(_) => inferProjectionFromFieldContext(
                          expr.node.id,
                          targetType,
                          fieldName,
                          fieldType,
                          state2,
                          unify
                        ),
                        _ =>
                          addTypeMark(
                            state2,
                            TypeMismatch,
                            originForNode(expr.node.id, "record projection"),
                            CoreAst.Inconsistent,
                            "Type error: projection expects a nominal record value"
                          ),
                      }
                      let resolved = apply(state3, fieldType)
                      let tRecorded = recordNodeType(expr.node.id, resolved, state3)
                      (tRecorded, state3)
                    },
                  },
                _ => {
                  let (targetType, state1) = inferExpr(targetExpr, state)
                  let (fieldType, state2) = freshVar(state1)
                  let state3 = match (apply(state2, targetType)) {
                    Types.TNominal(typeName, typeArgs) =>
                      match (resolveNominalRecordFields(typeName, typeArgs, state2)) {
                        Some(fields) =>
                          match (findRecordFieldType(fields, fieldName)) {
                            Some(existingType) =>
                              unifyForNode(
                                expr.node.id,
                                "record projection field",
                                fieldType,
                                existingType,
                                state2
                              ),
                            None =>
                              addTypeMark(
                                state2,
                                TypeMismatch,
                                originForNode(expr.node.id, "record projection missing field"),
                                CoreAst.Inconsistent,
                                "Type error: unknown record field " ++ fieldName
                              ),
                          },
                        None =>
                          addTypeMark(
                            state2,
                            TypeMismatch,
                            originForNode(expr.node.id, "record projection nominal"),
                            CoreAst.Inconsistent,
                            "Type error: projection expects a nominal record value"
                          ),
                      },
                    Types.TVar(_) => inferProjectionFromFieldContext(
                      expr.node.id,
                      targetType,
                      fieldName,
                      fieldType,
                      state2,
                      unify
                    ),
                    Types.THole(_) => inferProjectionFromFieldContext(
                      expr.node.id,
                      targetType,
                      fieldName,
                      fieldType,
                      state2,
                      unify
                    ),
                    _ =>
                      addTypeMark(
                        state2,
                        TypeMismatch,
                        originForNode(expr.node.id, "record projection"),
                        CoreAst.Inconsistent,
                        "Type error: projection expects a nominal record value"
                      ),
                  }
                  let resolved = apply(state3, fieldType)
                  let tRecorded = recordNodeType(expr.node.id, resolved, state3)
                  (tRecorded, state3)
                },
              }
            },
            _ => {
              let (tUnknown, state1) = freshVar(state)
              let state2 = addTypeMark(
                state1,
                TypeMismatch,
                originForNode(expr.node.id, "record projection field"),
                CoreAst.Inconsistent,
                "Type error: record projection expects string field name"
              )
              let tRecorded = recordNodeType(expr.node.id, tUnknown, state2)
              (tRecorded, state2)
            },
          },
        (CoreAst.Ident(typeName), CoreAst.RecordLit(items)) =>
          match (Env.lookupType(state.env, typeName.text)) {
            Some(typeInfo) =>
              match (typeInfo.recordFields) {
                Some(_) => {
                  let (paramTypes, _paramMap, nextVar) = Layer1Expr.instantiateTypeParams(
                    typeInfo.typeParams,
                    state.nextVar
                  )
                  let nominalType = Types.TNominal(typeInfo.name, paramTypes)
                  let state0 = { ...state, nextVar }
                  let rec collectFields = (
                    remaining: List<CoreAst.RecordItem>,
                    st: InferState,
                    acc: List<(String, Types.Type)>,
                  ) =>
                    match (remaining) {
                      [] => (List.reverse(acc), st),
                      [item, ...rest] => match (item) {
                        CoreAst.Field(fieldName, valueExpr) => {
                          let (valueType, st1) = inferExpr(valueExpr, st)
                          collectFields(rest, st1, [(fieldName.text, valueType), ...acc])
                        },
                        CoreAst.Spread(valueExpr) => {
                          let (spreadType, st1) = inferExpr(valueExpr, st)
                          match (apply(st1, spreadType)) {
                            Types.TNominal(typeName, typeArgs) =>
                              match (resolveNominalRecordFields(typeName, typeArgs, st1)) {
                                Some(spreadFields) =>
                                  collectFields(rest, st1, List.append(List.reverse(spreadFields), acc)),
                                None => {
                                  let st2 = addTypeMark(
                                    st1,
                                    TypeMismatch,
                                    originForNode(expr.node.id, "record spread"),
                                    CoreAst.Inconsistent,
                                    "Type error: record spread expects a nominal record value"
                                  )
                                  collectFields(rest, st2, acc)
                                },
                              },
                            _ => {
                              let st2 = addTypeMark(
                                st1,
                                TypeMismatch,
                                originForNode(expr.node.id, "record spread"),
                                CoreAst.Inconsistent,
                                "Type error: record spread expects a nominal record value"
                              )
                              collectFields(rest, st2, acc)
                            },
                          }
                        },
                      },
                    }
                  let (fields, state1) = collectFields(items, state0, [])
                  let state2 = validateRecordLiteralAgainstNominal(
                    expr.node.id,
                    fields,
                    nominalType,
                    state1,
                    unify
                  )
                  let tRecorded = recordNodeType(expr.node.id, nominalType, state2)
                  (tRecorded, state2)
                },
                None => {
                  inferFunctionApplication(expr.node.id, callee, arg, state)
                },
              },
            None => {
              inferFunctionApplication(expr.node.id, callee, arg, state)
            },
          },
        _ => {
          inferFunctionApplication(expr.node.id, callee, arg, state)
        },
      }
    },
    CoreAst.Let(binding, body) => {
      match (binding.name.kind) {
        CoreAst.Var(name) | CoreAst.Pin(name) => {
          let (placeholder, stateSeed) = freshVar(state)
          let seedScheme: Types.Scheme = { quantifiers: [], ty: placeholder }
          let (tValueRaw, state1) = withBinding(
            name.text,
            seedScheme,
            Flow.RecBinding,
            Flow.emptyDomainIdentities(),
            stateSeed,
            st => inferExpr(binding.value, st)
          )
          let state2 = unifyForNode(
            binding.node.id,
            "recursive/local binding",
            placeholder,
            tValueRaw,
            state1
          )
          let state3 = match (binding.annotation) {
            Some(annotation) =>
              unifyForNode(
                binding.node.id,
                "binding annotation",
                tValueRaw,
                typeFromAnnotation(annotation),
                state2
              ),
            None => state2,
          }
          let tValue = match (binding.annotation) {
            Some(annotation) => apply(state3, typeFromAnnotation(annotation)),
            None => apply(state3, tValueRaw),
          }
          let tValueFinal = normalizeNumericTypeForGeneralize(tValue, state3)
          logState("let.preGeneralize", state3, nodeId=binding.node.id)
          let scheme = Types.generalize(
            Env.snapshotValues(state3.env),
            state3.subst,
            tValueFinal
          )
          let valueIdentities = exprIdentitiesForNode(state3, binding.value.node.id)
          let (tBody, state3) = withBinding(
            name.text,
            scheme,
            Flow.LetBinding,
            valueIdentities,
            state3,
            st => inferExpr(body, st)
          )
          let tRecorded = recordNodeType(expr.node.id, tBody, state3)
          (tRecorded, state3)
        },
        _ => {
          let (tValueRaw, state1) = inferExpr(binding.value, state)
          let state2 = match (binding.annotation) {
            Some(annotation) =>
              unifyForNode(
                binding.node.id,
                "binding annotation",
                tValueRaw,
                typeFromAnnotation(annotation),
                state1
              ),
            None => state1,
          }
          let tValue = match (binding.annotation) {
            Some(annotation) => apply(state2, typeFromAnnotation(annotation)),
            None => apply(state2, tValueRaw),
          }
          let tValueFinal = normalizeNumericTypeForGeneralize(tValue, state2)
          logState("let.preGeneralize", state2, nodeId=binding.node.id)
          let scheme = Types.generalize(
            Env.snapshotValues(state2.env),
            state2.subst,
            tValueFinal
          )
          let (instType, nextVar) = Types.instantiate(scheme, state2.nextVar)
          let state3 = { ...state2, nextVar }
          let (tBody, state4) = withPatternBindingsKind(
            binding.name,
            instType,
            Flow.PatternBinding,
            state3,
            st => inferExpr(body, st)
          )
          let tRecorded = recordNodeType(expr.node.id, tBody, state4)
          (tRecorded, state4)
        },
      }
    },
    CoreAst.If(cond, thenExpr, elseOpt) => {
      let (tCond, state1) = inferExpr(cond, state)
      let (tThen, state2) = inferExpr(thenExpr, state1)
      let (tElse, state3) = match (elseOpt) {
        None => (Types.TVoid, state2),
        Some(e) => inferExpr(e, state2),
      }
      let state4 = unifyForNode(
        expr.node.id,
        "if condition",
        tCond,
        Types.TBool,
        state3
      )
      let state5 = unifyForNode(
        expr.node.id,
        "if branches",
        tThen,
        tElse,
        state4
      )
      let t = recordNodeType(expr.node.id, tThen, state5)
      (t, state5)
    },
    CoreAst.Tuple(exprs) => {
      let (types, state1) = inferExprList(exprs, state)
      let t = recordNodeType(expr.node.id, Types.TTuple(types), state1)
      (t, state1)
    },
    CoreAst.RecordLit(items) => {
      let rec collectProvidedFields = (
        remaining: List<CoreAst.RecordItem>,
        st: InferState,
        acc: List<(String, Types.Type)>,
      ) =>
        match (remaining) {
          [] => (List.reverse(acc), st),
          [item, ...rest] => match (item) {
            CoreAst.Field(fieldName, valueExpr) => {
              let (valueType, st1) = inferExpr(valueExpr, st)
              collectProvidedFields(rest, st1, [(fieldName.text, valueType), ...acc])
            },
            CoreAst.Spread(valueExpr) => {
              let (_spreadType, st1) = inferExpr(valueExpr, st)
              collectProvidedFields(rest, st1, acc)
            },
          },
        }
      let (fields, state1) = collectProvidedFields(items, state, [])
      let (recordType, state2) = inferNominalRecordContext(expr.node.id, fields, state1, unify)
      let t = recordNodeType(expr.node.id, recordType, state2)
      (t, state2)
    },
    _ => {
      let (t, state1) = freshVar(state)
      let tRecorded = recordNodeType(expr.node.id, t, state1)
      (tRecorded, state1)
    },
  }
}
and inferFunctionApplication = (
  exprNodeId: Number,
  callee: CoreAst.Expr,
  arg: CoreAst.Expr,
  state: InferState,
) => {
  let rec calleeIsFnLiteral = (expr: CoreAst.Expr) =>
    match (expr.kind) {
      CoreAst.Fn(_) => true,
      CoreAst.Mark(_, inner) => calleeIsFnLiteral(inner),
      _ => false,
    }
  let (tCallee, state1) = inferExpr(callee, state)
  let (tArg, state2) = inferExpr(arg, state1)
  let (normalizedArgType, wraps) = normalizeArgForCallee(tCallee, tArg, state2)
  let (selectedWrapOpt, state2a) =
    if (calleeIsFnLiteral(callee)) {
      (None, state2)
    } else {
      chooseCarrierWrap(wraps, exprNodeId, state2)
    }
  let (tRes, state3) = freshVar(state2a)
  let state4 = unifyForNode(
    exprNodeId,
    "function application",
    tCallee,
    Types.TFun(normalizedArgType, tRes),
    state3
  )
  let state5 = match (callee.kind) {
    CoreAst.Fn(fnExpr) => handleMatchApplication(fnExpr, normalizedArgType, state4),
    _ => state4,
  }
  let state6 = match (callee.kind) {
    CoreAst.Ident(name) =>
      applyOpRuleAtCall(exprNodeId, name.text, tCallee, tArg, tRes, state5),
    _ => state5,
  }
  let state6a = match (callee.kind) {
    CoreAst.Ident(name) =>
      applyNumericDomainAtCall(exprNodeId, name.text, normalizedArgType, tRes, state6),
    _ => state6,
  }
  let state6b = match (callee.kind) {
    CoreAst.Ident(name) when isNumericBinaryOp(name.text) =>
      unifyForNode(
        exprNodeId,
        "numeric arithmetic default",
        tRes,
        Types.TNumber,
        state6a
      ),
    _ => state6a,
  }
  let tAppliedBase = apply(state6b, tRes)
  let (tApplied, state7) = match (selectedWrapOpt) {
    Some(wrap) => (
      wrapResultWithCarrier(tAppliedBase, wrap, state6b),
      noteEffectEvent(
        state6b,
        exprNodeId,
        "propagation",
        "charged by "
          ++ wrap.typeName
          ++ " (domain "
          ++ wrap.domain
          ++ ") via argument propagation"
      ),
    ),
    None => (tAppliedBase, state6b),
  }
  let tRecorded = recordNodeType(exprNodeId, tApplied, state7)
  (tRecorded, state7)
}
and inferExprList = (exprs: List<CoreAst.Expr>, state: InferState) => {
  match (exprs) {
    [] => ([], state),
    [expr, ...rest] => {
      let (t, state1) = inferExpr(expr, state)
      let (restTypes, state2) = inferExprList(rest, state1)
      ([t, ...restTypes], state2)
    },
  }
}

let inferBindingValue = (binding: CoreAst.LetBinding, state: InferState) => {
  let annotationTypeOpt = match (binding.annotation) {
    Some(annotation) => Some(typeFromAnnotation(annotation)),
    None => None,
  }
  let (valueType, state1) = match ((annotationTypeOpt, binding.value.kind)) {
    (Some(expectedType), CoreAst.RecordLit(items)) => {
      let rec collectFields = (
        remaining: List<CoreAst.RecordItem>,
        st: InferState,
        acc: List<(String, Types.Type)>,
      ) =>
        match (remaining) {
          [] => (List.reverse(acc), st),
          [item, ...rest] => match (item) {
            CoreAst.Field(fieldName, valueExpr) => {
              let (valueType, st1) = inferExpr(valueExpr, st)
              collectFields(rest, st1, [(fieldName.text, valueType), ...acc])
            },
            CoreAst.Spread(valueExpr) => {
              let (spreadType, st1) = inferExpr(valueExpr, st)
              match (apply(st1, spreadType)) {
                Types.TNominal(typeName, typeArgs) =>
                  match (resolveNominalRecordFields(typeName, typeArgs, st1)) {
                    Some(spreadFields) =>
                      collectFields(rest, st1, List.append(List.reverse(spreadFields), acc)),
                    None => {
                      let st2 = addTypeMark(
                        st1,
                        TypeMismatch,
                        originForNode(binding.value.node.id, "record spread"),
                        CoreAst.Inconsistent,
                        "Type error: record spread expects a nominal record value"
                      )
                      collectFields(rest, st2, acc)
                    },
                  },
                _ => {
                  let st2 = addTypeMark(
                    st1,
                    TypeMismatch,
                    originForNode(binding.value.node.id, "record spread"),
                    CoreAst.Inconsistent,
                    "Type error: record spread expects a nominal record value"
                  )
                  collectFields(rest, st2, acc)
                },
              }
            },
          },
        }
      let (fields, st1) = collectFields(items, state, [])
      let st2 = validateRecordLiteralAgainstNominal(binding.value.node.id, fields, expectedType, st1, unify)
      (expectedType, st2)
    },
    _ => inferExpr(binding.value, state),
  }
  let state2 = match (annotationTypeOpt) {
    Some(annotationType) =>
      unifyForNode(
        binding.node.id,
        "binding annotation",
        valueType,
        annotationType,
        state1
      ),
    None => state1,
  }
  let appliedValueType0 = match (annotationTypeOpt) {
    Some(annotationType) => apply(state2, annotationType),
    None => apply(state2, valueType),
  }
  let (appliedValueType, state3a) = (appliedValueType0, state2)
  let state3 = match (binding.name.kind) {
    CoreAst.Var(name) => {
      Map.set(binding.name.node.id, appliedValueType, state3a.nodeTypes)
      Map.set(name.node.id, appliedValueType, state3a.nodeTypes)
      state3a
    },
    CoreAst.Pin(name) => {
      Map.set(binding.name.node.id, appliedValueType, state3a.nodeTypes)
      Map.set(name.node.id, appliedValueType, state3a.nodeTypes)
      state3a
    },
    _ => state3a,
  }
  let state4 = emitTypeInfectionConstraints(
    binding.node.id,
    "binding infection",
    appliedValueType,
    state3
  )
  (appliedValueType, state4)
}

let inferLetBinding = (binding: CoreAst.LetBinding, state: InferState) => {
  let declaredNameOpt = match (binding.name.kind) {
    CoreAst.Var(name) => Some(name),
    CoreAst.Pin(name) => Some(name),
    CoreAst.Constructor(name, _) => Some(name),
    _ => None,
  }
  let (tValue, state1) = inferBindingValue(binding, state)
  let tValueFinal = normalizeNumericTypeForGeneralize(tValue, state1)
  logState("letBinding.preGeneralize", state1, nodeId=binding.node.id)
  let scheme = Types.generalize(
    Env.snapshotValues(state1.env),
    state1.subst,
    tValueFinal
  )
  let name = Layer1Expr.bindingName(binding)
  match (declaredNameOpt) {
    Some(nameDecl) when isReservedValueName(nameDecl.text) =>
      addReservedNameMark(state1, nameDecl.node, nameDecl.text),
    _ =>
      if (isReservedValueName(name)) {
        addReservedNameMark(state1, binding.name.node, name)
      } else {
        let identities = exprIdentitiesForNode(state1, binding.value.node.id)
        let (entry, flow1) = Flow.bindScheme(
          state1.flow,
          scheme,
          Flow.LetBinding,
          identities=identities
        )
        let flow2 = Flow.registerBindingInfo(
          flow1,
          entry.bindingId,
          name,
          entry.scopeId,
          entry.bindingKind
        )
        Env.defineValueEntry(state1.env, name, entry)
        Map.set(name, scheme, state1.topBindings)
        Map.set(name, tValue, state1.topBindingRawTypes)
        { ...state1, flow: flow2, topBindingRawTypes: state1.topBindingRawTypes }
      },
  }
}

let rec withPatternBindings = (
  pattern: CoreAst.Pattern,
  expectedType: Types.Type,
  state: InferState,
  fn: InferState => (Types.Type, InferState),
) => withPatternBindingsKind(pattern, expectedType, Flow.PatternBinding, state, fn)

let rec findBindingByName = (
  name: String,
  bindings: List<CoreAst.LetBinding>,
) =>
  match (bindings) {
    [] => None,
    [binding, ...rest] =>
      if (Layer1Expr.bindingName(binding) == name) {
        Some(binding)
      } else {
        findBindingByName(name, rest)
      },
  }

let inferRecursiveBindings = (bindings: List<CoreAst.LetBinding>, state: InferState) => {
  let rec collectAllowed = (
    remaining: List<CoreAst.LetBinding>,
    keptRev: List<CoreAst.LetBinding>,
    st: InferState,
  ) =>
    match (remaining) {
      [] => (List.reverse(keptRev), st),
      [binding, ...rest] => {
        let declaredNameOpt = match (binding.name.kind) {
          CoreAst.Var(nameDecl) => Some(nameDecl),
          CoreAst.Pin(nameDecl) => Some(nameDecl),
          CoreAst.Constructor(nameDecl, _) => Some(nameDecl),
          _ => None,
        }
        match (declaredNameOpt) {
          Some(nameDecl) when isReservedValueName(nameDecl.text) =>
            collectAllowed(
              rest,
              keptRev,
              addReservedNameMark(st, nameDecl.node, nameDecl.text)
            ),
          _ => {
            let name = Layer1Expr.bindingName(binding)
            if (isReservedValueName(name)) {
              collectAllowed(
                rest,
                keptRev,
                addReservedNameMark(st, binding.name.node, name)
              )
            } else {
              collectAllowed(rest, [binding, ...keptRev], st)
            }
          },
        }
      },
    }

  let (allowedBindings, state0) = collectAllowed(bindings, [], state)
  if (allowedBindings == []) {
    state0
  } else {
  let baseValues = cloneEnvValues(Env.snapshotValues(state.env))
  let seed = Layer1Bindings.seedRecursivePlaceholders(allowedBindings, state0.nextVar)
  let placeholders = seed.placeholders
  let state1 = List.reduce(
    (stAcc: InferState, pair: (String, Types.Type)) => {
      let (name, placeholderType) = pair
      let (entry, flow1) = Flow.bindScheme(
        stAcc.flow,
        { quantifiers: [], ty: placeholderType }: Types.Scheme,
        Flow.RecBinding,
        identities=Flow.emptyDomainIdentities()
      )
      let flow2 = Flow.registerBindingInfo(
        flow1,
        entry.bindingId,
        name,
        entry.scopeId,
        entry.bindingKind
      )
      let env1 = Env.defineValueEntry(stAcc.env, name, entry)
      { ...stAcc, env: env1, flow: flow2 }
    },
    { ...state0, nextVar: seed.nextVar },
    placeholders
  )

  let rec inferBodies = (remaining: List<CoreAst.LetBinding>, st: InferState) =>
    match (remaining) {
      [] => st,
      [binding, ...rest] => {
        let name = Layer1Expr.bindingName(binding)
        let (placeholderType, st0) = match (Layer1Bindings.lookupPlaceholder(name, placeholders)) {
          Some(t) => (t, st),
          None => {
            let (fallback, st1) = freshVar(st)
            let st2 = addTypeMark(
              st1,
              Internal,
              originForNode(binding.node.id, "recursive placeholder"),
              CoreAst.Internal("missing recursive placeholder"),
              "Type error: missing placeholder for recursive binding " ++ name
            )
            (fallback, st2)
          },
        }
        let (valueType, st1) = inferBindingValue(binding, st0)
        let st2 = unifyForNode(
          binding.node.id,
          "recursive binding",
          placeholderType,
          valueType,
          st1
        )
        inferBodies(rest, st2)
      },
    }

  let state2 = inferBodies(allowedBindings, state1)
  logState("rec.preFinalize", state2)

  let rec finalize = (remaining: List<(String, Types.Type)>, st: InferState) =>
    match (remaining) {
      [] => st,
      [(name, placeholderType), ...rest] => {
        let schemeType = normalizeNumericTypeForGeneralize(placeholderType, st)
        let scheme = Types.generalize(baseValues, st.subst, schemeType)
        let identities = match (findBindingByName(name, allowedBindings)) {
          Some(binding) => exprIdentitiesForNode(st, binding.value.node.id),
          None => Flow.emptyDomainIdentities(),
        }
        let (entry, flow1) = Flow.bindScheme(
          st.flow,
          scheme,
          Flow.RecBinding,
          identities=identities
        )
        let flow2 = Flow.registerBindingInfo(
          flow1,
          entry.bindingId,
          name,
          entry.scopeId,
          entry.bindingKind
        )
        Env.defineValueEntry(st.env, name, entry)
        Map.set(name, scheme, st.topBindings)
        Map.set(name, placeholderType, st.topBindingRawTypes)
        finalize(rest, { ...st, flow: flow2, topBindingRawTypes: st.topBindingRawTypes })
      },
    }

  finalize(placeholders, state2)
  }
}

let registerTypeDecl = (decl: CoreAst.TypeDecl, state: InferState) => {
  if (isReservedValueName(decl.name.text)) {
    addReservedNameMark(state, decl.name.node, decl.name.text)
  } else {
    let hasReservedCtor = match (decl.body) {
      CoreAst.Variant(ctors) => {
        let rec existsReservedCtor = (
          items: List<(CoreAst.Name, Option<CoreAst.TypeExpr>, Option<CoreAst.Annotation>)>
        ) =>
          match (items) {
            [] => false,
            [(ctorName, _payload, _ann), ...rest] =>
              isReservedValueName(ctorName.text) || existsReservedCtor(rest),
          }
        existsReservedCtor(ctors)
      },
      _ => false,
    }
    if (hasReservedCtor) {
      let offendingNode = match (decl.body) {
        CoreAst.Variant(ctors) => {
          let rec firstReservedCtorNode = (
            items: List<(CoreAst.Name, Option<CoreAst.TypeExpr>, Option<CoreAst.Annotation>)>
          ) =>
            match (items) {
              [] => decl.name.node,
              [(ctorName, _payload, _ann), ...rest] =>
                if (isReservedValueName(ctorName.text)) {
                  ctorName.node
                } else {
                  firstReservedCtorNode(rest)
                },
            }
          firstReservedCtorNode(ctors)
        },
        _ => decl.name.node,
      }
      addReservedNameMark(state, offendingNode, "Panic")
    } else {
  let prepared = Layer1Decl.prepareTypeDecl(decl, state.nextVar)
  let env1 = Env.registerType(state.env, prepared.info)
  List.forEach(((name, scheme): (String, Types.Scheme)) => {
    Env.defineValue(env1, name, scheme)
    void
  }, prepared.constructorSchemes)
  { ...state, nextVar: prepared.nextVar, env: env1 }
    }
  }
}

let registerRecordDecl = (decl: CoreAst.RecordDecl, state: InferState) => {
  let info = Layer1Decl.prepareRecordDecl(decl)
  let env1 = Env.registerType(state.env, info)
  { ...state, env: env1 }
}

let inferTopItems = (items: List<CoreAst.TopItem>, state: InferState) =>
  Layer1Top.inferTopItems(
    items,
    state,
    (dg, st) =>
      Layer1Top.inferDeclGroup(
        dg,
        st,
        (ld, groupKind, stDecl) => match (groupKind) {
          CoreAst.LetGroup(CoreAst.Rec) =>
            inferRecursiveBindings(ld.bindings, stDecl),
          _ =>
            Layer1Bindings.inferLetBindingsSequential(
              ld.bindings,
              stDecl,
              inferLetBinding
            ),
        },
        registerTypeDecl,
        (decl, stDecl) => match (decl) {
          CoreAst.RecordDecl(recordDecl) => registerRecordDecl(recordDecl, stDecl),
          _ => {
            let nextRegistry = InfectionRegistry.mergeDecl(stDecl.infectionRegistry, decl)
            { ...stDecl, infectionRegistry: nextRegistry }
          },
        }
      ),
    (_item, st) => st
  )

let solveConstraints = (state: InferState) => {
  let isConcreteConflict = (left: Types.Type, right: Types.Type) => {
    let rec loop = (a: Types.Type, b: Types.Type) =>
      match ((a, b)) {
        (Types.THole(_), _) => false,
        (_, Types.THole(_)) => false,
        (Types.TVar(_), _) => false,
        (_, Types.TVar(_)) => false,
        (Types.TNumber, Types.TNumber) => false,
        (Types.TNumber, Types.TNominal(name, [])) when Types.isNumericNominalName(name) => false,
        (Types.TNominal(name, []), Types.TNumber) when Types.isNumericNominalName(name) => false,
        (Types.TBool, Types.TBool) => false,
        (Types.TString, Types.TString) => false,
        (Types.TByte, Types.TByte) => false,
        (Types.TChar, Types.TChar) => false,
        (Types.TVoid, Types.TVoid) => false,
        (Types.TFun(a1, b1), Types.TFun(a2, b2)) => loop(a1, a2) || loop(b1, b2),
        (Types.TTuple(xs), Types.TTuple(ys)) =>
          if (List.length(xs) != List.length(ys)) {
            true
          } else {
            let rec anyConflict = (leftItems: List<Types.Type>, rightItems: List<Types.Type>) =>
              match ((leftItems, rightItems)) {
                ([], []) => false,
                ([xh, ...xt], [yh, ...yt]) => loop(xh, yh) || anyConflict(xt, yt),
                _ => true,
            }
            anyConflict(xs, ys)
          },
        (Types.TNominal(nameL, argsL), Types.TNominal(nameR, argsR)) =>
          if (nameL != nameR || List.length(argsL) != List.length(argsR)) {
            true
          } else {
            let rec anyConflict = (leftItems: List<Types.Type>, rightItems: List<Types.Type>) =>
              match ((leftItems, rightItems)) {
                ([], []) => false,
                ([xh, ...xt], [yh, ...yt]) => loop(xh, yh) || anyConflict(xt, yt),
                _ => true,
              }
            anyConflict(argsL, argsR)
          },
        _ => true,
      }
    loop(left, right)
  }

  let addUnfillableHoleMarks = (
    marksState: InferState,
    solvedSubst: Types.Subst,
  ) =>
    List.reduce(
      (acc: InferState, entry: (Number, List<HoleObservation>)) => {
        let (holeId, observations) = entry
        let normalized = List.map(
          (obs: HoleObservation) =>
            {
              observed: Types.applySubstType(solvedSubst, obs.observed),
              origin: obs.origin,
            }: HoleObservation,
          observations
        )
        let rec hasConflict = (remaining: List<HoleObservation>) =>
          match (remaining) {
            [] => false,
            [head, ...tail] => {
              let pairConflict = List.some(
                (other: HoleObservation) =>
                  isConcreteConflict(head.observed, other.observed),
                tail
              )
              pairConflict || hasConflict(tail)
            },
          }
        if (hasConflict(normalized)) {
          addTypeMark(
            acc,
            UnfillableHole,
            Constraints.makeOrigin(holeId, "unfillable hole"),
            CoreAst.UnfillableHole,
            "Type error: unfillable hole"
          )
        } else {
          acc
        }
      },
      marksState,
      Map.toList(marksState.holeObservations)
    )

  // Hazel-style layering: Layer 1 has already enforced HM equality constraints.
  // Layer 2 handles only deferred domain-style constraints.
  let deferred = List.filter((constraint: Constraints.Constraint) =>
    match (constraint) {
      Constraints.Domain(_, _) => true,
      Constraints.Numeric(_, _) => true,
      _ => false,
    }, state.constraints)

  let solverState = List.reduce(
    (acc, constraint) => Solver.addConstraint(acc, constraint),
    Solver.withSubst(state.subst),
    List.reverse(deferred)
  )
  match (Solver.solve(solverState)) {
    Ok(result) => {
      Env.applySubst(state.env, result.subst)
      let numericVars = collectNumericConstraintVars(state)
      let solvedNodeTypes = Map.make()
      Map.forEach((id, ty) => {
        let solved = normalizeNumericTypeWithVarSet(ty, result.subst, numericVars)
        Map.set(id, solved, solvedNodeTypes)
      }, state.nodeTypes)
      let solvedTopBindings = Map.make()
      List.forEach(((name, scheme): (String, Types.Scheme)) => {
        let solvedTyFromScheme = normalizeNumericTypeWithVarSet(scheme.ty, result.subst, numericVars)
        let solvedTy = if (scheme.quantifiers == []) {
          match (Map.get(name, state.topBindingRawTypes)) {
            Some(rawTy) => normalizeNumericTypeWithVarSet(rawTy, result.subst, numericVars),
            None => solvedTyFromScheme,
          }
        } else {
          solvedTyFromScheme
        }
        Map.set(name, { ...scheme, ty: solvedTy }: Types.Scheme, solvedTopBindings)
      }, Map.toList(state.topBindings))

      let solvedState = {
        ...state,
        subst: result.subst,
        nodeTypes: solvedNodeTypes,
        topBindings: solvedTopBindings,
        constraints: result.domainConstraints,
      }
      addUnfillableHoleMarks(solvedState, result.subst)
    },
    Err(Solver.Occurs(origin)) =>
      addTypeMark(
        state,
        OccursCycle,
        origin,
        CoreAst.OccursCheck,
        "Type error: occurs check failed"
      ),
    Err(Solver.CannotUnify(left, right, origin)) =>
      addTypeMark(
        state,
        TypeMismatch,
        origin,
        CoreAst.Inconsistent,
        "Type error (" ++ origin.description ++ "): cannot unify "
          ++ Types.typeToReadableString(left)
          ++ " with "
          ++ Types.typeToReadableString(right)
      ),
    Err(Solver.NumericViolation(origin, message)) =>
      addTypeMark(
        state,
        TypeMismatch,
        origin,
        CoreAst.Inconsistent,
        "Type error (" ++ origin.description ++ "): " ++ message
      ),
  }
}

provide let inferProgram = (program: CoreAst.Program) => {
  let state = makeInitialState()
  let inferred = inferTopItems(program.items, state)
  solveConstraints(inferred)
}

provide let inferProgramWithEnv = (program: CoreAst.Program, env: Types.Env) => {
  let baseEnv = seedBuiltinValues(Env.empty())
  Map.forEach((name, scheme) => {
    Env.defineValue(baseEnv, name, scheme)
    void
  }, env)
  let state = { ...makeInitialState(), env: baseEnv }
  let inferred = inferTopItems(program.items, state)
  solveConstraints(inferred)
}

provide let inferProgramWithTypingEnv = (
  program: CoreAst.Program,
  env: Types.Env,
  importedTypes: Map.Map<String, Env.TypeInfo>,
) => {
  let baseEnv = seedBuiltinValues(Env.empty())
  Map.forEach((name, scheme) => {
    Env.defineValue(baseEnv, name, scheme)
    void
  }, env)
  List.forEach(((typeName, info): (String, Env.TypeInfo)) => {
    if (Env.lookupType(baseEnv, typeName) == None) {
      Env.registerType(baseEnv, info)
      void
    } else {
      void
    }
  }, Map.toList(importedTypes))
  let state = { ...makeInitialState(), env: baseEnv }
  let inferred = inferTopItems(program.items, state)
  solveConstraints(inferred)
}

provide let inferProgramLayer1 = (program: CoreAst.Program) => {
  let state = makeInitialState()
  inferTopItems(program.items, state)
}

provide let inferProgramLayer1WithEnv = (program: CoreAst.Program, env: Types.Env) => {
  let baseEnv = seedBuiltinValues(Env.empty())
  Map.forEach((name, scheme) => {
    Env.defineValue(baseEnv, name, scheme)
    void
  }, env)
  let state = { ...makeInitialState(), env: baseEnv }
  inferTopItems(program.items, state)
}

provide let inferProgramLayer2 = (state: InferState) => solveConstraints(state)
