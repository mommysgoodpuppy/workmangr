let chooseCarrierWrap = (
  wraps: List<InfectionCarrierWrap>,
  callNodeId: Number,
  state: InferState,
) => {
  let (selectedWrap, nextState) = Layer2Infection.chooseCarrierWrap(
    List.map(toLayer2Wrap, wraps),
    callNodeId,
    toMarksState(state)
  )
  (
    match (selectedWrap) {
      Some(wrap) => Some(fromLayer2Wrap(wrap)),
      None => None,
    },
    fromMarksState(nextState),
  )
}

