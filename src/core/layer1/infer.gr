let toMarksState = (state: InferState) => state
let fromMarksState = (state: Layer1InferState.InferState) => state

let mut inferDebugEnabled: Bool = false

provide let setInferDebug = (enabled: Bool) => {
  inferDebugEnabled = enabled
}

let inferDebug = (message: String) => {
  if (inferDebugEnabled) {
    let _ = File.fdWrite(File.stderr, Bytes.fromString("[Infer] " ++ message ++ "\n"))
    void
  } else {
    void
  }
}

let mapSize = (m) => List.length(Map.toList(m))

let isReservedValueName = (name: String) => name == "Panic"

let reservedNameError = (name: String) =>
  "Type error: reserved identifier " ++ name ++ " cannot be declared"

let renderType = (t: Types.Type, state: InferState) =>
  Types.typeToReadableString(Types.applySubstType(state.subst, t))

let renderOrigin = (origin: Constraints.Origin) =>
  Constraints.originToString(origin)

let renderOriginTrail = (origins: List<Constraints.Origin>) =>
  match (origins) {
    [] => "<none>",
    _ => Array.join(" <= ", Array.fromList(List.map(renderOrigin, origins))),
  }

let recentOrigins = (state: InferState, n: Number) => {
  let recent = List.filterMap((constraint: Constraints.Constraint) =>
    match (constraint) {
      Constraints.Equality(_, _, o) => Some(o),
      Constraints.Domain(_, o) => Some(o),
      Constraints.Numeric(_, o) => Some(o),
    }, state.constraints)
  let rec take = (items: List<Constraints.Origin>, count: Number, acc: List<Constraints.Origin>) =>
    if (count <= 0) {
      List.reverse(acc)
    } else {
      match (items) {
        [] => List.reverse(acc),
        [head, ...tail] => take(tail, count - 1, [head, ...acc]),
      }
    }
  take(recent, n, [])
}

let tracePatternStep = (
  label: String,
  pattern: CoreAst.Pattern,
  expectedType: Types.Type,
  state: InferState,
) => {
  inferDebug(
    label
      ++ " patternNode="
      ++ toString(pattern.node.id)
      ++ " expected="
      ++ renderType(expectedType, state)
  )
}

let seedBuiltinValues = (env: Env.TypingEnv) => {
  let intType = Types.TNominal("Int", [])
  let boolType = Types.TBool
  let charType = Types.TChar
  let stringType = Types.TString
  let voidType = Types.TVoid
  let listCharType = Types.TNominal("List", [charType])
  let orderingType = Types.TNominal("Ordering", [])
  let tNum = Types.TVar(0)
  let binaryInt: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([intType, intType]), intType),
  }
  let binaryNumeric: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TTuple([tNum, tNum]), tNum),
  }
  let binaryEq: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TTuple([Types.TVar(0), Types.TVar(0)]), boolType),
  }
  let cmpNumeric: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TTuple([tNum, tNum]), boolType),
  }
  let unaryBool: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(boolType, boolType),
  }
  let cmpInt: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([intType, intType]), orderingType),
  }
  let nativeStringFromLiteral: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(stringType, stringType),
  }
  let nativeStringToList: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(stringType, listCharType),
  }
  let nativeListToString: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(listCharType, stringType),
  }
  let nativeStrFromLiteral: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(stringType, listCharType),
  }
  let nativeCharEq: Types.Scheme = {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([charType, charType]), boolType),
  }
  let nativePrint: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(Types.TVar(0), voidType),
  }
  let panicValue: Types.Scheme = {
    quantifiers: [0],
    ty: Types.TFun(stringType, Types.TVar(0)),
  }
  let define = (name: String, scheme: Types.Scheme) => {
    Env.defineValue(env, name, scheme)
    void
  }
  Env.defineValue(env, "nativeAdd", binaryInt)
  Env.defineValue(env, "nativeSub", binaryInt)
  Env.defineValue(env, "nativeMul", binaryInt)
  Env.defineValue(env, "nativeDiv", binaryInt)
  Env.defineValue(env, "nativeCmpInt", cmpInt)
  Env.defineValue(env, "nativeStringFromLiteral", nativeStringFromLiteral)
  Env.defineValue(env, "nativeStringToList", nativeStringToList)
  Env.defineValue(env, "nativeListToString", nativeListToString)
  Env.defineValue(env, "nativeStrFromLiteral", nativeStrFromLiteral)
  Env.defineValue(env, "nativeCharEq", nativeCharEq)
  Env.defineValue(env, "nativePrint", nativePrint)
  Env.defineValue(env, "print", nativePrint)
  Env.defineValue(env, "Panic", panicValue)
  // Temporary builtin operator support until std-based operator resolution lands.
  define("+", binaryNumeric)
  define("-", binaryNumeric)
  define("*", binaryNumeric)
  define("/", binaryNumeric)
  define("%", binaryNumeric)
  define("==", binaryEq)
  define("!=", binaryEq)
  define(">", cmpNumeric)
  define("<", cmpNumeric)
  define(">=", cmpNumeric)
  define("<=", cmpNumeric)
  define("!", unaryBool)
  define("not", unaryBool)
  define("&&", {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([boolType, boolType]), boolType),
  })
  define("||", {
    quantifiers: [],
    ty: Types.TFun(Types.TTuple([boolType, boolType]), boolType),
  })
  env
}

let logState = (label: String, state: InferState, nodeId: Number=-1) => {
  inferDebug(
    label
      ++ " node="
      ++ toString(nodeId)
      ++ " env="
      ++ toString(mapSize(Env.snapshotValues(state.env)))
      ++ " subst="
      ++ toString(mapSize(state.subst))
      ++ " constraints="
      ++ toString(List.length(state.constraints))
      ++ " marks="
      ++ toString(List.length(state.marks))
      ++ " nextVar="
      ++ toString(state.nextVar)
  )
}

