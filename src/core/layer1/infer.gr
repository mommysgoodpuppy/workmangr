record ProvidedRecordField {
  name: String,
  nameOrigin: Constraints.Origin,
  valueType: Types.Type,
  valueOrigin: Constraints.Origin,
}

let recordCtx_findRecordFieldType = Layer1RecordCtx.findRecordFieldType
let recordCtx_resolveNominalRecordFields = Layer1RecordCtx.resolveNominalRecordFields
let recordCtx_hasRecordField = Layer1RecordCtx.hasRecordField
let recordCtx_inferNominalRecordContext = Layer1RecordCtx.inferNominalRecordContext
let recordCtx_inferProjectionFromFieldContext = Layer1RecordCtx.inferProjectionFromFieldContext
let recordCtx_inferProjectionFromCarrierContext = Layer1RecordCtx.inferProjectionFromCarrierContext
let recordCtx_validateRecordLiteralAgainstNominal = Layer1RecordCtx.validateRecordLiteralAgainstNominal

let toRecordCtxProvidedField = (field: ProvidedRecordField) => {
  {
    name: field.name,
    nameOrigin: field.nameOrigin,
    valueType: field.valueType,
    valueOrigin: field.valueOrigin,
  }: Layer1RecordCtx.ProvidedRecordField
}

let toRecordCtxProvidedFields = (fields: List<ProvidedRecordField>) =>
  List.map(toRecordCtxProvidedField, fields)

let recordCtxFindRecordFieldType = (
  fields: List<(String, Types.Type)>,
  fieldName: String,
) => recordCtx_findRecordFieldType(fields, fieldName)

let recordCtxResolveNominalRecordFields = (
  typeName: String,
  args: List<Types.Type>,
  state: InferState,
) => recordCtx_resolveNominalRecordFields(typeName, args, toMarksState(state))

let recordCtxHasRecordField = (fields: List<(String, Types.Type)>, fieldName: String) =>
  recordCtx_hasRecordField(fields, fieldName)

let recordCtxInferNominalRecordContext = (
  literalNodeId: Number,
  providedFields: List<ProvidedRecordField>,
  state: InferState,
  unifyBlameFn: (
    Types.Type,
    Types.Type,
    Constraints.Origin,
    Option<Constraints.Origin>,
    InferState,
  ) => InferState,
) => {
  let bridgeUnify = (
    left: Types.Type,
    right: Types.Type,
    origin: Constraints.Origin,
    blame: Option<Constraints.Origin>,
    marksState: Layer1InferState.InferState,
  ) => {
    let inferState = fromMarksState(marksState)
    let nextInfer = unifyBlameFn(left, right, origin, blame, inferState)
    toMarksState(nextInfer)
  }
  let (ty, nextState) = recordCtx_inferNominalRecordContext(
    literalNodeId,
    toRecordCtxProvidedFields(providedFields),
    toMarksState(state),
    bridgeUnify
  )
  (ty, fromMarksState(nextState))
}

let recordCtxInferProjectionFromFieldContext = (
  literalNodeId: Number,
  targetType: Types.Type,
  targetBlame: Option<Constraints.Origin>,
  fieldName: String,
  fieldType: Types.Type,
  fieldBlame: Option<Constraints.Origin>,
  state: InferState,
  unifyBlameFn: (
    Types.Type,
    Types.Type,
    Constraints.Origin,
    Option<Constraints.Origin>,
    InferState,
  ) => InferState,
) => {
  let bridgeUnify = (
    left: Types.Type,
    right: Types.Type,
    origin: Constraints.Origin,
    blame: Option<Constraints.Origin>,
    marksState: Layer1InferState.InferState,
  ) => {
    let inferState = fromMarksState(marksState)
    let nextInfer = unifyBlameFn(left, right, origin, blame, inferState)
    toMarksState(nextInfer)
  }
  let out = recordCtx_inferProjectionFromFieldContext(
    literalNodeId,
    targetType,
    targetBlame,
    fieldName,
    fieldType,
    fieldBlame,
    toMarksState(state),
    bridgeUnify
  )
  fromMarksState(out)
}

let recordCtxInferProjectionFromCarrierContext = (
  literalNodeId: Number,
  targetType: Types.Type,
  targetBlame: Option<Constraints.Origin>,
  fieldName: String,
  fieldType: Types.Type,
  fieldBlame: Option<Constraints.Origin>,
  state: InferState,
  unifyBlameFn: (
    Types.Type,
    Types.Type,
    Constraints.Origin,
    Option<Constraints.Origin>,
    InferState,
  ) => InferState,
) =>
  {
  let bridgeUnify = (
    left: Types.Type,
    right: Types.Type,
    origin: Constraints.Origin,
    blame: Option<Constraints.Origin>,
    marksState: Layer1InferState.InferState,
  ) => {
    let inferState = fromMarksState(marksState)
    let nextInfer = unifyBlameFn(left, right, origin, blame, inferState)
    toMarksState(nextInfer)
  }
  let classifyCarrierValueType = (ty: Types.Type, marksState: Layer1InferState.InferState) =>
    match (classifyInfectiousNominal(ty, fromMarksState(marksState))) {
      Some((valueType, _wrap)) => Some(valueType),
      None => None,
    }
  let wrapFieldTypeForCarrier = (
    carrierType: Types.Type,
    fieldTy: Types.Type,
    marksState: Layer1InferState.InferState,
  ) =>
    match (classifyInfectiousNominal(carrierType, fromMarksState(marksState))) {
      Some((_valueType, wrap)) =>
        Some(wrapResultWithCarrier(fieldTy, wrap, fromMarksState(marksState))),
      None => None,
    }
  let out = recordCtx_inferProjectionFromCarrierContext(
    literalNodeId,
    targetType,
    targetBlame,
    fieldName,
    fieldType,
    fieldBlame,
    toMarksState(state),
    bridgeUnify,
    classifyCarrierValueType,
    wrapFieldTypeForCarrier
  )
  fromMarksState(out)
  }

let recordCtxValidateRecordLiteralAgainstNominal = (
  literalNodeId: Number,
  fields: List<ProvidedRecordField>,
  expectedType: Types.Type,
  state: InferState,
  unifyBlameFn: (
    Types.Type,
    Types.Type,
    Constraints.Origin,
    Option<Constraints.Origin>,
    InferState,
  ) => InferState,
) => {
  let bridgeUnify = (
    left: Types.Type,
    right: Types.Type,
    origin: Constraints.Origin,
    blame: Option<Constraints.Origin>,
    marksState: Layer1InferState.InferState,
  ) => {
    let inferState = fromMarksState(marksState)
    let nextInfer = unifyBlameFn(left, right, origin, blame, inferState)
    toMarksState(nextInfer)
  }
  let out = recordCtx_validateRecordLiteralAgainstNominal(
    literalNodeId,
    toRecordCtxProvidedFields(fields),
    expectedType,
    toMarksState(state),
    bridgeUnify
  )
  fromMarksState(out)
}

